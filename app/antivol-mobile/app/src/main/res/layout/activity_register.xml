<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#02000e"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <!-- Logo & Title -->
        <LinearLayout
            android:id="@+id/layoutHeader"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="8dp">

            <TextView
                android:id="@+id/tvLogoIcon"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:text="&#x1f6e1;"
                android:textSize="28sp"
                android:textColor="#ffffff"
                android:gravity="center"
                android:background="@drawable/bg_gradient_primary" />

            <TextView
                android:id="@+id/tvAppName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textColor="@color/accent_blue"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/tvSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/register_subtitle"
                android:textColor="@color/text_muted"
                android:textSize="13sp"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Title -->
        <TextView
            android:id="@+id/tvRegisterTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/register_title"
            android:textColor="@color/text_white"
            android:textSize="20sp"
            android:gravity="center"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@+id/layoutHeader"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Nom Label -->
        <TextView
            android:id="@+id/lblNom"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/register_lastname"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@+id/tvRegisterTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Nom Input -->
        <EditText
            android:id="@+id/etNom"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:background="@drawable/edittext_bg"
            android:inputType="textPersonName"
            android:paddingHorizontal="16dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_muted"
            android:hint="@string/register_lastname"
            android:layout_marginTop="6dp"
            app:layout_constraintTop_toBottomOf="@+id/lblNom"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Prénom Label -->
        <TextView
            android:id="@+id/lblPrenom"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/register_firstname"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginTop="14dp"
            app:layout_constraintTop_toBottomOf="@+id/etNom"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Prénom Input -->
        <EditText
            android:id="@+id/etPrenom"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:background="@drawable/edittext_bg"
            android:inputType="textPersonName"
            android:paddingHorizontal="16dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_muted"
            android:hint="@string/register_firstname"
            android:layout_marginTop="6dp"
            app:layout_constraintTop_toBottomOf="@+id/lblPrenom"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Email Label -->
        <TextView
            android:id="@+id/lblEmail"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/login_email"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginTop="14dp"
            app:layout_constraintTop_toBottomOf="@+id/etPrenom"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Email Input -->
        <EditText
            android:id="@+id/etEmail"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:background="@drawable/edittext_bg"
            android:inputType="textEmailAddress"
            android:paddingHorizontal="16dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_muted"
            android:hint="@string/login_email"
            android:importantForAutofill="yes"
            android:autofillHints="emailAddress"
            android:layout_marginTop="6dp"
            app:layout_constraintTop_toBottomOf="@+id/lblEmail"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Téléphone Label -->
        <TextView
            android:id="@+id/lblTelephone"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/register_phone"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginTop="14dp"
            app:layout_constraintTop_toBottomOf="@+id/etEmail"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Téléphone Input -->
        <EditText
            android:id="@+id/etTelephone"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:background="@drawable/edittext_bg"
            android:inputType="phone"
            android:paddingHorizontal="16dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_muted"
            android:hint="@string/register_phone"
            android:layout_marginTop="6dp"
            app:layout_constraintTop_toBottomOf="@+id/lblTelephone"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Password Label -->
        <TextView
            android:id="@+id/lblPassword"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/login_password"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginTop="14dp"
            app:layout_constraintTop_toBottomOf="@+id/etTelephone"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Password Input -->
        <EditText
            android:id="@+id/etPassword"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:background="@drawable/edittext_bg"
            android:inputType="textPassword"
            android:paddingHorizontal="16dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_muted"
            android:hint="@string/login_password"
            android:importantForAutofill="yes"
            android:autofillHints="password"
            android:layout_marginTop="6dp"
            app:layout_constraintTop_toBottomOf="@+id/lblPassword"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Confirmer Label -->
        <TextView
            android:id="@+id/lblConfirm"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/register_password_confirm"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginTop="14dp"
            app:layout_constraintTop_toBottomOf="@+id/etPassword"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Confirmer Input -->
        <EditText
            android:id="@+id/etConfirmPassword"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:background="@drawable/edittext_bg"
            android:inputType="textPassword"
            android:paddingHorizontal="16dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_muted"
            android:hint="@string/register_password_confirm"
            android:layout_marginTop="6dp"
            app:layout_constraintTop_toBottomOf="@+id/lblConfirm"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Error Text -->
        <TextView
            android:id="@+id/tvError"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textColor="@color/accent_red"
            android:textSize="13sp"
            android:gravity="center"
            android:visibility="gone"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@+id/etConfirmPassword"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Register Button -->
        <Button
            android:id="@+id/btnRegister"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:text="@string/register_button"
            android:textColor="#ffffff"
            android:textSize="16sp"
            android:textStyle="bold"
            android:onClick="register"
            android:background="@drawable/bg_gradient_primary"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@+id/tvError"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Login Link -->
        <TextView
            android:id="@+id/tvLoginLink"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/register_has_account"
            android:textColor="@color/accent_blue"
            android:textSize="14sp"
            android:gravity="center"
            android:onClick="goToLogin"
            android:clickable="true"
            android:focusable="true"
            android:padding="12dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="24dp"
            app:layout_constraintTop_toBottomOf="@+id/tvError"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
