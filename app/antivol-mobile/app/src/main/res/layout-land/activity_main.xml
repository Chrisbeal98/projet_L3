<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#02000e"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Header row -->
        <LinearLayout
            android:id="@+id/layoutHeader"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="4dp">

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#3b82f6" />

            <TextView
                android:id="@+id/tvUserEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="12sp"
                android:textColor="#64748b"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/tvDeviceId"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/device_id"
                android:textSize="13sp"
                android:textColor="#ef4444"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Stats Grid -->
        <LinearLayout
            android:id="@+id/layoutStats"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="4"
            app:layout_constraintTop_toBottomOf="@+id/layoutHeader"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="#1e293b"
                android:padding="8dp"
                android:layout_marginEnd="3dp">

                <TextView
                    android:id="@+id/tvStatsDevices"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#3b82f6" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/stats_appareils"
                    android:textSize="10sp"
                    android:textColor="#64748b"
                    android:gravity="center" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="#1e293b"
                android:padding="8dp"
                android:layout_marginHorizontal="3dp">

                <TextView
                    android:id="@+id/tvStatsAlertes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#ef4444" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/stats_alertes"
                    android:textSize="10sp"
                    android:textColor="#64748b"
                    android:gravity="center" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="#1e293b"
                android:padding="8dp"
                android:layout_marginHorizontal="3dp">

                <TextView
                    android:id="@+id/tvStatsVol"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#f59e0b" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/stats_voles"
                    android:textSize="10sp"
                    android:textColor="#64748b"
                    android:gravity="center" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="#1e293b"
                android:padding="8dp"
                android:layout_marginStart="3dp">

                <TextView
                    android:id="@+id/tvStatsLocked"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#22c55e" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/stats_verrouilles"
                    android:textSize="10sp"
                    android:textColor="#64748b"
                    android:gravity="center" />
            </LinearLayout>
        </LinearLayout>

        <!-- Navigation Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardActions"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#1e293b"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:layout_constraintTop_toBottomOf="@+id/layoutStats"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/nav_dashboard"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#f1f5f9"
                    android:layout_marginBottom="8dp"
                    android:layout_marginStart="4dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="5">

                    <LinearLayout
                        android:id="@+id/navDevices"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="4dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground">
                        <TextView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:text="📱"
                            android:textSize="16sp"
                            android:gravity="center"
                            android:background="#1a3b82f6" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/nav_appareils"
                            android:textSize="10sp"
                            android:textColor="#94a3b8"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/navAlerts"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="4dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground">
                        <TextView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:text="🔔"
                            android:textSize="16sp"
                            android:gravity="center"
                            android:background="#1aef4444" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/nav_alertes"
                            android:textSize="10sp"
                            android:textColor="#94a3b8"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/navZones"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="4dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground">
                        <TextView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:text="⚠"
                            android:textSize="16sp"
                            android:gravity="center"
                            android:background="#1af59e0b" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/nav_zones"
                            android:textSize="10sp"
                            android:textColor="#94a3b8"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/navLocation"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="4dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground">
                        <TextView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:text="📍"
                            android:textSize="16sp"
                            android:gravity="center"
                            android:background="#1a22c55e" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/nav_localisation"
                            android:textSize="10sp"
                            android:textColor="#94a3b8"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/navProfile"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="4dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground">
                        <TextView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:text="👤"
                            android:textSize="16sp"
                            android:gravity="center"
                            android:background="#1af59e0b" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/nav_profil"
                            android:textSize="10sp"
                            android:textColor="#94a3b8"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Status Card - left side -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#1e293b"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnActivate"
            app:layout_constraintTop_toBottomOf="@id/cardActions"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="8dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="14dp">

                <TextView
                    android:id="@+id/tvCardStatusTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/device_status"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#f1f5f9"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:id="@+id/lblImei"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/device_imei"
                    android:textColor="#64748b"
                    android:textSize="13sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvCardStatusTitle"
                    android:layout_marginTop="10dp" />

                <TextView
                    android:id="@+id/tvImei"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textColor="#f1f5f9"
                    android:textStyle="bold"
                    android:textSize="13sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBaseline_toBaselineOf="@id/lblImei" />

                <View
                    android:id="@+id/divider1"
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:background="#334155"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/lblImei"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:id="@+id/lblStatus"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/device_status_label"
                    android:textColor="#64748b"
                    android:textSize="13sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/divider1"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textColor="#22c55e"
                    android:textStyle="bold"
                    android:textSize="13sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBaseline_toBaselineOf="@id/lblStatus" />

                <View
                    android:id="@+id/divider2"
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:background="#334155"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/lblStatus"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:id="@+id/lblLocked"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/device_locked_label"
                    android:textColor="#64748b"
                    android:textSize="13sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/divider2"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:id="@+id/tvLocked"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textColor="#22c55e"
                    android:textStyle="bold"
                    android:textSize="13sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBaseline_toBaselineOf="@id/lblLocked" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>

        <!-- Right column buttons -->
        <Button
            android:id="@+id/btnActivate"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:text="@string/btn_activate_admin"
            android:textSize="12sp"
            android:textStyle="bold"
            android:backgroundTint="#ef4444"
            android:textColor="#ffffff"
            android:onClick="activateAdmin"
            app:layout_constraintStart_toEndOf="@id/cardStatus"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cardActions"
            android:layout_marginTop="8dp"
            android:layout_marginStart="8dp" />

        <Button
            android:id="@+id/btnRegister"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:text="@string/btn_register_device"
            android:textSize="12sp"
            android:textStyle="bold"
            android:backgroundTint="#3b82f6"
            android:textColor="#ffffff"
            android:onClick="registerDevice"
            android:visibility="gone"
            app:layout_constraintStart_toEndOf="@id/cardStatus"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btnActivate"
            android:layout_marginTop="6dp"
            android:layout_marginStart="8dp" />

        <Button
            android:id="@+id/btnStart"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:text="@string/btn_start_monitoring"
            android:textSize="12sp"
            android:textStyle="bold"
            android:backgroundTint="#22c55e"
            android:textColor="#ffffff"
            android:onClick="startMonitoring"
            android:visibility="gone"
            app:layout_constraintStart_toEndOf="@id/cardStatus"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btnRegister"
            android:layout_marginTop="6dp"
            android:layout_marginStart="8dp" />

        <Button
            android:id="@+id/btnStop"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:text="@string/btn_stop_monitoring"
            android:textSize="12sp"
            android:textStyle="bold"
            android:backgroundTint="#ef4444"
            android:textColor="#ffffff"
            android:onClick="stopMonitoring"
            android:visibility="gone"
            app:layout_constraintStart_toEndOf="@id/cardStatus"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btnStart"
            android:layout_marginTop="6dp"
            android:layout_marginStart="8dp" />

        <!-- Log section -->
        <TextView
            android:id="@+id/tvLogLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/log_title"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#f1f5f9"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cardStatus"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="2dp" />

        <ScrollView
            android:id="@+id/scrollView"
            android:layout_width="0dp"
            android:layout_height="120dp"
            android:background="#000000"
            android:padding="8dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvLogLabel">

            <TextView
                android:id="@+id/tvLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#22c55e"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:text="@string/app_ready" />
        </ScrollView>

        <!-- Bottom row -->
        <TextView
            android:id="@+id/tvUnlockHint"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/unlock_code_hint"
            android:textSize="10sp"
            android:textColor="#64748b"
            android:gravity="center"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/scrollView"
            android:layout_marginTop="6dp" />

        <Button
            android:id="@+id/btnLogout"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:text="@string/btn_logout"
            android:textSize="13sp"
            android:backgroundTint="#ef4444"
            android:textColor="#ffffff"
            android:onClick="logout"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnSettings"
            app:layout_constraintTop_toBottomOf="@id/tvUnlockHint"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="6dp"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnSettings"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:text="@string/btn_settings"
            android:textSize="13sp"
            android:backgroundTint="#334155"
            android:textColor="#f1f5f9"
            app:layout_constraintStart_toEndOf="@id/btnLogout"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvUnlockHint"
            android:layout_marginTop="8dp"
            android:layout_marginStart="6dp"
            android:layout_marginBottom="8dp" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
