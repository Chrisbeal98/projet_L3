<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#02000e"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <TextView
            android:id="@+id/tvSettingsTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/settings_title"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#3b82f6"
            android:gravity="center"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="24dp" />

        <!-- User Info Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardUser"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#1e293b"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvSettingsTitle"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_user_label"
                    android:textSize="13sp"
                    android:textColor="#64748b"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvUserEmail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textSize="16sp"
                    android:textColor="#f1f5f9"
                    android:textStyle="bold" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Server URL -->
        <TextView
            android:id="@+id/lblApiUrl"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/settings_server_url"
            android:textColor="#94a3b8"
            android:textSize="13sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cardUser"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/etApiUrl"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:hint="http://192.168.44.35:8000/api"
            android:textColor="#f1f5f9"
            android:backgroundTint="#3b82f6"
            android:inputType="textUri"
            android:importantForAutofill="no"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/lblApiUrl"
            android:layout_marginBottom="16dp" />

        <!-- Device ID -->
        <TextView
            android:id="@+id/lblDeviceId"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/settings_device_id"
            android:textColor="#94a3b8"
            android:textSize="13sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/etApiUrl"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/etAppareilId"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:hint="@string/settings_device_hint"
            android:inputType="number"
            android:textColor="#f1f5f9"
            android:backgroundTint="#3b82f6"
            android:importantForAutofill="no"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/lblDeviceId"
            android:layout_marginBottom="24dp" />

        <Button
            android:id="@+id/btnSave"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:text="@string/btn_save"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="#22c55e"
            android:textColor="#ffffff"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/etAppareilId"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnLogout"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:text="@string/btn_logout"
            android:textSize="16sp"
            android:backgroundTint="#ef4444"
            android:textColor="#ffffff"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btnSave"
            android:layout_marginBottom="24dp" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
