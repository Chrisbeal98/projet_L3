msgid "file"
msgstr "kōnae"

msgid "directory"
msgstr "whaiaronga"

msgid "path"
msgstr "ara"

#, python-brace-format
msgid "{name} {filename!r} does not exist."
msgstr "{name} {filename!r} kāore i te tīariari."

#, python-brace-format
msgid "{name} {filename!r} is a file."
msgstr "Ko {name} {filename!r} he kōnae."

#, python-brace-format
msgid "{name} {filename!r} is a directory."
msgstr "Ko {name} {filename!r} he whaiaronga."

#, python-brace-format
msgid "{name} {filename!r} is not readable."
msgstr "{name} {filename!r} kaore e taea te panui."

#, python-brace-format
msgid "{name} {filename!r} is not writable."
msgstr "{name} {filename!r} kaore e taea te tuhi."

#, python-brace-format
msgid "{name} {filename!r} is not executable."
msgstr "{name} {filename!r} kaore e taea te kawe."

#, python-brace-format
msgid "{len_type} values are required, but {len_value} was given."
msgstr "Ko nga uara {len_type} e hiahiatia ana, engari ko {len_value} i hoatu."

#, python-brace-format
msgid "Unknown standard stream '{name}'"
msgstr "Rere paerewa '{name}' tē mōhiotia"

msgid "This field is required."
msgstr "Me hiahia tenei mara."

#, python-brace-format
msgid "File does not have an approved extension: {extensions}"
msgstr "Karekau he toronga kua whakaaetia: {extensions}"

msgid "File does not have an approved extension."
msgstr "Karekau he toronga kua whakaaetia."

#, python-brace-format
msgid "File must be between {min_size} and {max_size} bytes."
msgstr "Me noho te kōnae i waenga i te {min_size} me te {max_size} paita."

#, python-format
msgid "Invalid field name '%s'."
msgstr "I muhu te ingoa mara '%s'."

#, python-format
msgid "Field must be equal to %(other_name)s."
msgstr "Me rite te mara ki te %(other_name)s."

#, python-format
msgid "Field must be at least %(min)d character long."
msgstr "Kia %(min)d te roa o te roanga o te waahi."

#, python-format
msgid "Field cannot be longer than %(max)d character."
msgstr "Kaua e roa ake te mara i te %(max)d pūāhua."

#, python-format
msgid "Field must be exactly %(max)d character long."
msgstr "Me tino %(max)d te roa o te apure."

#, python-format
msgid "Field must be between %(min)d and %(max)d characters long."
msgstr "Me noho te āpure i waenga i te %(min)d me te %(max)d pūāhua te roa."

#, python-format
msgid "Number must be at least %(min)s."
msgstr "Ko te nama me %(min)s iti rawa."

#, python-format
msgid "Number must be at most %(max)s."
msgstr "Me nui rawa te nama %(max)s."

#, python-format
msgid "Number must be between %(min)s and %(max)s."
msgstr "Me noho te tau i waenga i te %(min)s me te %(max)s."

msgid "Invalid input."
msgstr "Tāuru muhu."

msgid "Invalid email address."
msgstr "Wāhitau īmēra muhu."

msgid "Invalid IP address."
msgstr "Wāhitau IP muhu."

msgid "Invalid Mac address."
msgstr "Wāhitau Mac muhu."

msgid "Invalid URL."
msgstr "URL muhu."

msgid "Invalid UUID."
msgstr "UUID muhu."

#, python-format
msgid "Invalid value, must be one of: %(values)s."
msgstr "Uara muhu, me noho tetahi o: %(values)s."

#, python-format
msgid "Invalid value, can't be any of: %(values)s."
msgstr "He uara muhu, kaore e taea tetahi o: %(values)s."

msgid "This field cannot be edited."
msgstr "Kāore e taea te whakatika tēnei āpure."

msgid "This field is disabled and cannot have a value."
msgstr "Kua monoa tenei apure kaore e taea te whai uara."

msgid "Invalid CSRF Token."
msgstr "Tohu CSRF muhu."

msgid "CSRF token missing."
msgstr "Kei te ngaro te tohu CSRF."

msgid "CSRF failed."
msgstr "I rahua te CSRF."

msgid "CSRF token expired."
msgstr "Kua pau te tohu CSRF."

msgid "Invalid Choice: could not coerce."
msgstr "Kōwhiringa Muhu: kaore i taea te tohe."

msgid "Choices cannot be None."
msgstr "Ko nga whiringa kaore e taea te Kore."

msgid "Not a valid choice."
msgstr "Ehara i te whiriwhiri tika."

msgid "Invalid choice(s): one or more data inputs could not be coerced."
msgstr ""
"Kōwhiringa muhu: kotahi, nui ake ranei nga whakaurunga raraunga kaore i "
"taea te akiaki."

#, python-format
msgid "'%(value)s' is not a valid choice for this field."
msgstr "Ehara te '%(value)s' i te whiringa whaimana mo tenei mara."

msgid "Not a valid datetime value."
msgstr "Ehara i te uara wa wa tika."

msgid "Not a valid date value."
msgstr "Ehara i te uara ra whaimana."

msgid "Not a valid time value."
msgstr "Ehara i te uara wa tika."

msgid "Not a valid week value."
msgstr "Ehara i te uara wiki whaimana."

msgid "Not a valid integer value."
msgstr "Ehara i te uara tauoti whaimana."

msgid "Not a valid decimal value."
msgstr "Ehara i te uara ira whaimana."

msgid "Not a valid float value."
msgstr "Ehara i te uara rewa whaimana."

