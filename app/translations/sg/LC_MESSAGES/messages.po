msgstr "{valeur} ayeke na yâ ti range {range} pëpe."

#, python-brace-format
msgid "{value!r} is not a valid boolean. Recognized values: {states}"
msgstr ""
"{valeur!r} ayeke pëpe mbeni boolean so ayeke na lege ni. A hinga akota "
"ye: {a-état}"

#, python-brace-format
msgid "{value!r} is not a valid UUID."
msgstr "{valeur!r} ayeke pëpe mbeni UUID so ayeke na lege ni."

msgid "file"
msgstr "mbeti"

msgid "directory"
msgstr "répertoire"

msgid "path"
msgstr "lege"

#, python-brace-format
msgid "{name} {filename!r} does not exist."
msgstr "{iri} {iri ti fichier!r} ayeke dä pëpe."

#, python-brace-format
msgid "{name} {filename!r} is a file."
msgstr "{iri} {iri ti fichier!r} ayeke mbeni fichier."

#, python-brace-format
msgid "{name} {filename!r} is a directory."
msgstr "{iri} {iri ti fichier!r} ayeke mbeni répertoire."

#, python-brace-format
msgid "{name} {filename!r} is not readable."
msgstr "{iri} {iri ti fichier!r} ayeke ye ti dikongo ni pëpe."

#, python-brace-format
msgid "{name} {filename!r} is not writable."
msgstr "{iri} {iri ti fichier!r} ayeke ye ti sungo mbeti pepe."

#, python-brace-format
msgid "{name} {filename!r} is not executable."
msgstr "{iri} {iri ti fichier!r} ayeke sara kua pëpe."

#, python-brace-format
msgid "{len_type} values are required, but {len_value} was given."
msgstr "{len_type} a yeke hunda, me {len_valeur} a yeke."

#, python-brace-format
msgid "Unknown standard stream '{name}'"
msgstr "A hinga pepe stream ti standard '{iri}'"

msgid "This field is required."
msgstr "A hunda ti sara ni."

#, python-brace-format
msgid "File does not have an approved extension: {extensions}"
msgstr "Fichier ni ayeke na mbeni extension so a yeda na ni pëpe: {extensions}"

msgid "File does not have an approved extension."
msgstr "Fichier ni ayeke na mbeni extension so a yeda na ni pëpe."

#, python-brace-format
msgid "File must be between {min_size} and {max_size} bytes."
msgstr "A lingbi fichier ni aduti na popo ti {mini_taille} na {max_taille} octets."

#, python-format
msgid "Invalid field name '%s'."
msgstr "Iri ti ndo ni ayeke '%s'."

#, python-format
msgid "Field must be equal to %(other_name)s."
msgstr "A lingbi ndo ni aduti legeoko na %(mbeni_iri)s."

#, python-format
msgid "Field must be at least %(min)d character long."
msgstr "A lingbi ndo ni aduti kamême %(min)d ti atënë."

#, python-format
msgid "Field cannot be longer than %(max)d character."
msgstr "Field alingbi ti duti yongoro ahon %(max)d pëpe."

#, python-format
msgid "Field must be exactly %(max)d character long."
msgstr "A lingbi ndo ni aduti mbilimbili %(max)d ti atënë."

#, python-format
msgid "Field must be between %(min)d and %(max)d characters long."
msgstr "A lingbi ndo ni aduti na popo ti %(min)d na %(max)d ti akota tënë."

#, python-format
msgid "Number must be at least %(min)s."
msgstr "A lingbi wungo ni aduti kamême %(min)s."

#, python-format
msgid "Number must be at most %(max)s."
msgstr "A lingbi wungo ni aduti mingi ahon %(max)s."

#, python-format
msgid "Number must be between %(min)s and %(max)s."
msgstr "A lingbi wungo ni aduti na popo ti %(min)s na %(max)s."

msgid "Invalid input."
msgstr "Input so ayeke na lege ni pëpe."

msgid "Invalid email address."
msgstr "Adresse e-mail so ayeke na lege ni pëpe."

msgid "Invalid IP address."
msgstr "Adresse IP so ayeke na lege ni pëpe."

msgid "Invalid Mac address."
msgstr "Adresse ti Mac so ayeke na lege ni pëpe."

msgid "Invalid URL."
msgstr "URL so ayeke na lege ni pëpe."

msgid "Invalid UUID."
msgstr "UUID so ayeke na lege ni pëpe."

#, python-format
msgid "Invalid value, must be one of: %(values)s."
msgstr ""
"Valeur so ayeke na lege ni pëpe, a lingbi ti duti mbeni oko ti: "
"%(valeur)s."

#, python-format
msgid "Invalid value, can't be any of: %(values)s."
msgstr ""
"Valeur so ayeke na lege ni pëpe, alingbi ti duti pëpe mbeni oko ti: "
"%(valeur)s."

msgid "This field cannot be edited."
msgstr "A lingbi ti leke yâ ti aye so pëpe."

msgid "This field is disabled and cannot have a value."
msgstr "A yeke na lege ni ti tene a lingbi ti duti na mbeni ngere pëpe."

msgid "Invalid CSRF Token."
msgstr "Jeton ti CSRF so ayeke na lege ni pëpe."

msgid "CSRF token missing."
msgstr "CSRF jeton ni ayeke dä pëpe."

msgid "CSRF failed."
msgstr "CSRF asala kusala."

msgid "CSRF token expired."
msgstr "CSRF jeton ni ahunzi."

msgid "Invalid Choice: could not coerce."
msgstr "Choix so ayeke na lege ni pëpe: alingbi pëpe ti gbu zo na ngangu."

msgid "Choices cannot be None."
msgstr "Asoro alingbi pëpe ti duti Mbeni oko pëpe."

msgid "Not a valid choice."
msgstr "A yeke pëpe mbeni nzoni ye ti soro."

msgid "Invalid choice(s): one or more data inputs could not be coerced."
msgstr ""
"Choix(s) so ayeke na lege ni pëpe: a lingbi pëpe ti gbu zo na ngangu ti "
"sû asango oko wala mingi."

#, python-format
msgid "'%(value)s' is not a valid choice for this field."
msgstr "'%(valeur)s' ayeke pëpe mbeni nzoni ye ti soro ni ndali ti ndo so."

msgid "Not a valid datetime value."
msgstr "A yeke pëpe mbeni ngele ti date-heure so ayeke na lege ni."

msgid "Not a valid date value."
msgstr "A yeke pëpe mbeni ngele ti date so ayeke na lege ni."

msgid "Not a valid time value."
msgstr "A yeke pëpe mbeni ngele ti ngoi so ayeke na lege ni."

msgid "Not a valid week value."
msgstr "A yeke pëpe mbeni ngele ti yenga so ayeke na lege ni."

msgid "Not a valid integer value."
msgstr "A yeke pëpe mbeni ngele ti wungo kue so ayeke na lege ni."

msgid "Not a valid decimal value."
msgstr "A yeke pëpe mbeni ngele ti décimal so ayeke na lege ni."

msgid "Not a valid float value."
msgstr "A yeke pëpe mbeni ngele ti flotteur so ayeke na lege ni."

