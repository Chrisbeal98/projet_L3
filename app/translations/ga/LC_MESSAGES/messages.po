msgstr "Ní mheaitseálann {value!r} an fhormáid {format}."

#, python-brace-format
msgid "{value!r} is not a valid {number_type}."
msgstr "Ní {number_type} bailí é {value!r}."

#, python-brace-format
msgid "{value} is not in the range {range}."
msgstr "Níl {value} sa raon {raon}."

#, python-brace-format
msgid "{value!r} is not a valid boolean. Recognized values: {states}"
msgstr "Ní Boole bailí é {value!r}. Luachanna aitheanta: {states}"

#, python-brace-format
msgid "{value!r} is not a valid UUID."
msgstr "Ní UUID bailí é {value!r}."

msgid "file"
msgstr "comhad"

msgid "directory"
msgstr "eolaire"

msgid "path"
msgstr "cosán"

#, python-brace-format
msgid "{name} {filename!r} does not exist."
msgstr "Níl {name} {filename!r} ann."

#, python-brace-format
msgid "{name} {filename!r} is a file."
msgstr "Is comhad é {name} {filename!r}."

#, python-brace-format
msgid "{name} {filename!r} is a directory."
msgstr "Is eolaire é {name} {filename!r}."

#, python-brace-format
msgid "{name} {filename!r} is not readable."
msgstr "Níl {name} {filename!r} inléite."

#, python-brace-format
msgid "{name} {filename!r} is not writable."
msgstr "Níl {name} {filename!r} inscríofa."

#, python-brace-format
msgid "{name} {filename!r} is not executable."
msgstr "Níl {name} {filename!r} inrite."

#, python-brace-format
msgid "{len_type} values are required, but {len_value} was given."
msgstr "Tá {len_type} luachanna ag teastáil, ach tugadh {len_value}."

#, python-brace-format
msgid "Unknown standard stream '{name}'"
msgstr "Sruth caighdeánach anaithnid '{name}'"

msgid "This field is required."
msgstr "Tá an réimse seo ag teastáil."

#, python-brace-format
msgid "File does not have an approved extension: {extensions}"
msgstr "Níl iarmhír ceadaithe ag an gcomhad: {extensions}"

msgid "File does not have an approved extension."
msgstr "Níl iarmhír ceadaithe ag an gcomhad."

#, python-brace-format
msgid "File must be between {min_size} and {max_size} bytes."
msgstr "Caithfidh an comhad a bheith idir {min_size} agus {max_size} beart."

#, python-format
msgid "Invalid field name '%s'."
msgstr "Ainm réimse neamhbhailí '%s'."

#, python-format
msgid "Field must be equal to %(other_name)s."
msgstr "Caithfidh an réimse a bheith cothrom le %(other_name)s."

#, python-format
msgid "Field must be at least %(min)d character long."
msgstr "Caithfidh an réimse a bheith %(nóim)d carachtar ar a laghad."

#, python-format
msgid "Field cannot be longer than %(max)d character."
msgstr "Ní féidir leis an réimse a bheith níos faide ná %(max)d carachtar."

#, python-format
msgid "Field must be exactly %(max)d character long."
msgstr "Caithfidh an réimse a bheith díreach %(max)d carachtar ar fad."

#, python-format
msgid "Field must be between %(min)d and %(max)d characters long."
msgstr "Caithfidh an réimse a bheith idir %(min)d agus %(max)d carachtar ar fad."

#, python-format
msgid "Number must be at least %(min)s."
msgstr "Caithfidh an uimhir a bheith %(nóim)s ar a laghad."

#, python-format
msgid "Number must be at most %(max)s."
msgstr "Caithfidh an uimhir a bheith %(max)s ar a mhéad."

#, python-format
msgid "Number must be between %(min)s and %(max)s."
msgstr "Caithfidh an uimhir a bheith idir %(nóim)s agus %(uas)s."

msgid "Invalid input."
msgstr "Ionchur neamhbhailí."

msgid "Invalid email address."
msgstr "Seoladh ríomhphoist neamhbhailí."

msgid "Invalid IP address."
msgstr "Seoladh IP neamhbhailí."

msgid "Invalid Mac address."
msgstr "Seoladh Mac neamhbhailí."

msgid "Invalid URL."
msgstr "URL neamhbhailí."

msgid "Invalid UUID."
msgstr "UUID neamhbhailí."

#, python-format
msgid "Invalid value, must be one of: %(values)s."
msgstr "Luach neamhbhailí, caithfidh sé a bheith mar cheann de: %(values)s."

#, python-format
msgid "Invalid value, can't be any of: %(values)s."
msgstr "Luach neamhbhailí, ní féidir é a bheith mar cheann ar bith de: %(values)s."

msgid "This field cannot be edited."
msgstr "Ní féidir an réimse seo a chur in eagar."

msgid "This field is disabled and cannot have a value."
msgstr "Tá an réimse seo díchumasaithe agus ní féidir luach a bheith leis."

msgid "Invalid CSRF Token."
msgstr "Comhartha CSRF neamhbhailí."

msgid "CSRF token missing."
msgstr "Comhartha CSRF in easnamh."

msgid "CSRF failed."
msgstr "Theip ar CSRF."

msgid "CSRF token expired."
msgstr "chomhartha CSRF imithe in éag."

msgid "Invalid Choice: could not coerce."
msgstr "Rogha Neamhbhailí: níorbh fhéidir comhéigean a dhéanamh."

msgid "Choices cannot be None."
msgstr "Ní féidir Roghanna a bheith Ceann ar bith."

msgid "Not a valid choice."
msgstr "Ní rogha bhailí é."

msgid "Invalid choice(s): one or more data inputs could not be coerced."
msgstr ""
"Rogha neamhbhailí: níorbh fhéidir ionchur sonraí amháin nó níos mó a chur"
" i bhfeidhm."

#, python-format
msgid "'%(value)s' is not a valid choice for this field."
msgstr "Ní rogha bhailí é '%(value)s' don réimse seo."

msgid "Not a valid datetime value."
msgstr "Ní luach dáta bailí é."

msgid "Not a valid date value."
msgstr "Ní luach dáta bailí é."

msgid "Not a valid time value."
msgstr "Ní luach ama bailí é."

msgid "Not a valid week value."
msgstr "Ní luach bailí seachtaine é."

msgid "Not a valid integer value."
msgstr "Ní luach slánuimhir bailí é."

msgid "Not a valid decimal value."
msgstr "Ní luach deachúlach bailí é."

