msgstr "Lapangan kudu paling sethithik %(min)d karakter."

#, python-format
msgid "Field cannot be longer than %(max)d character."
msgstr "Kolom ora bisa luwih saka %(maks)d karakter."

#, python-format
msgid "Field must be exactly %(max)d character long."
msgstr "Lapangan kudu persis %(maks)d karakter dawa."

#, python-format
msgid "Field must be between %(min)d and %(max)d characters long."
msgstr "Lapangan kudu antarane %(min)d lan %(maks)d karakter."

#, python-format
msgid "Number must be at least %(min)s."
msgstr "Jumlah kudu paling sethithik %(min)s."

#, python-format
msgid "Number must be at most %(max)s."
msgstr "Nomer kudu paling akeh %(maks)s."

#, python-format
msgid "Number must be between %(min)s and %(max)s."
msgstr "Jumlah kudu antarane %(min)s lan %(maks)s."

msgid "Invalid input."
msgstr "Input ora sah."

msgid "Invalid email address."
msgstr "Alamat email ora sah."

msgid "Invalid IP address."
msgstr "Alamat IP ora sah."

msgid "Invalid Mac address."
msgstr "Alamat Mac ora bener."

msgid "Invalid URL."
msgstr "URL ora valid."

msgid "Invalid UUID."
msgstr "UUID ora valid."

#, python-format
msgid "Invalid value, must be one of: %(values)s."
msgstr "Nilai ora valid, kudu salah siji saka: %(nilai)s."

#, python-format
msgid "Invalid value, can't be any of: %(values)s."
msgstr "Nilai ora valid, ora bisa dadi: %(nilai)s."

msgid "This field cannot be edited."
msgstr "Bidang iki ora bisa diowahi."

msgid "This field is disabled and cannot have a value."
msgstr "Lapangan iki dipatèni lan ora bisa duwe nilai."

msgid "Invalid CSRF Token."
msgstr "Token CSRF ora sah."

msgid "CSRF token missing."
msgstr "Token CSRF ilang."

msgid "CSRF failed."
msgstr "CSRF gagal."

msgid "CSRF token expired."
msgstr "Token CSRF kadaluwarsa."

msgid "Invalid Choice: could not coerce."
msgstr "Pilihan ora sah: ora bisa meksa."

msgid "Choices cannot be None."
msgstr "Pilihan ora bisa None."

msgid "Not a valid choice."
msgstr "Ora pilihan sing bener."

msgid "Invalid choice(s): one or more data inputs could not be coerced."
msgstr "Pilihan ora bener: siji utawa luwih input data ora bisa dipeksa."

#, python-format
msgid "'%(value)s' is not a valid choice for this field."
msgstr "'%(value)s' dudu pilihan sing bener kanggo kolom iki."

msgid "Not a valid datetime value."
msgstr "Ora nilai datetime bener."

msgid "Not a valid date value."
msgstr "Ora nilai tanggal bener."

msgid "Not a valid time value."
msgstr "Ora nilai wektu sing bener."

msgid "Not a valid week value."
msgstr "Ora regane minggu sing bener."

msgid "Not a valid integer value."
msgstr "Ora nilai integer sing bener."

msgid "Not a valid decimal value."
msgstr "Ora angka desimal sing bener."

msgid "Not a valid float value."
msgstr "Ora nilai float sing bener."

