#, python-brace-format
msgid "Choice({choices})"
msgstr "ಆಯ್ಕೆ({choices})"

#, python-brace-format
msgid "{value!r} does not match the format {format}."
msgstr "{value!r} ಫಾರ್ಮ್ಯಾಟ್ {format} ಗೆ ಹೊಂದಿಕೆಯಾಗುವುದಿಲ್ಲ."

#, python-brace-format
msgid "{value!r} is not a valid {number_type}."
msgstr "{value!r} ಮಾನ್ಯವಾದ {number_type} ಅಲ್ಲ."

#, python-brace-format
msgid "{value} is not in the range {range}."
msgstr "{value} {range} ವ್ಯಾಪ್ತಿಯಲ್ಲಿಲ್ಲ."

#, python-brace-format
msgid "{value!r} is not a valid boolean. Recognized values: {states}"
msgstr "{value!r} ಮಾನ್ಯವಾದ ಬೂಲಿಯನ್ ಅಲ್ಲ. ಗುರುತಿಸಲಾದ ಮೌಲ್ಯಗಳು: {ರಾಜ್ಯಗಳು}"

#, python-brace-format
msgid "{value!r} is not a valid UUID."
msgstr "{value!r} ಮಾನ್ಯವಾದ UUID ಅಲ್ಲ."

msgid "file"
msgstr "ಕಡತ"

msgid "directory"
msgstr "ಡೈರೆಕ್ಟರಿ"

msgid "path"
msgstr "ಮಾರ್ಗ"

#, python-brace-format
msgid "{name} {filename!r} does not exist."
msgstr "{name} {filename!r} ಅಸ್ತಿತ್ವದಲ್ಲಿಲ್ಲ."

#, python-brace-format
msgid "{name} {filename!r} is a file."
msgstr "{name} {filename!r} ಒಂದು ಫೈಲ್ ಆಗಿದೆ."

#, python-brace-format
msgid "{name} {filename!r} is a directory."
msgstr "{name} {filename!r} ಒಂದು ಡೈರೆಕ್ಟರಿಯಾಗಿದೆ."

#, python-brace-format
msgid "{name} {filename!r} is not readable."
msgstr "{name} {filename!r} ಅನ್ನು ಓದಲಾಗುವುದಿಲ್ಲ."

#, python-brace-format
msgid "{name} {filename!r} is not writable."
msgstr "{name} {filename!r} ಬರೆಯಲು ಸಾಧ್ಯವಿಲ್ಲ."

#, python-brace-format
msgid "{name} {filename!r} is not executable."
msgstr "{name} {filename!r} ಅನ್ನು ಕಾರ್ಯಗತಗೊಳಿಸಲಾಗುವುದಿಲ್ಲ."

#, python-brace-format
msgid "{len_type} values are required, but {len_value} was given."
msgstr "{len_type} ಮೌಲ್ಯಗಳು ಅಗತ್ಯವಿದೆ, ಆದರೆ {len_value} ನೀಡಲಾಗಿದೆ."

#, python-brace-format
msgid "Unknown standard stream '{name}'"
msgstr "ಅಜ್ಞಾತ ಪ್ರಮಾಣಿತ ಸ್ಟ್ರೀಮ್ '{name}'"

msgid "This field is required."
msgstr "ಈ ಕ್ಷೇತ್ರದ ಅಗತ್ಯವಿದೆ."

#, python-brace-format
msgid "File does not have an approved extension: {extensions}"
msgstr "ಫೈಲ್ ಅನುಮೋದಿತ ವಿಸ್ತರಣೆಯನ್ನು ಹೊಂದಿಲ್ಲ: {extensions}"

msgid "File does not have an approved extension."
msgstr "ಫೈಲ್ ಅನುಮೋದಿತ ವಿಸ್ತರಣೆಯನ್ನು ಹೊಂದಿಲ್ಲ."

#, python-brace-format
msgid "File must be between {min_size} and {max_size} bytes."
msgstr "ಫೈಲ್ {min_size} ಮತ್ತು {max_size} ಬೈಟ್‌ಗಳ ನಡುವೆ ಇರಬೇಕು."

#, python-format
msgid "Invalid field name '%s'."
msgstr "ಅಮಾನ್ಯ ಕ್ಷೇತ್ರ ಹೆಸರು '%s'."

#, python-format
msgid "Field must be equal to %(other_name)s."
msgstr "ಕ್ಷೇತ್ರವು %(other_name)s ಗೆ ಸಮನಾಗಿರಬೇಕು."

#, python-format
msgid "Field must be at least %(min)d character long."
msgstr "ಕ್ಷೇತ್ರವು ಕನಿಷ್ಠ %(ನಿಮಿಷ)d ಅಕ್ಷರ ಉದ್ದವಿರಬೇಕು."

#, python-format
msgid "Field cannot be longer than %(max)d character."
msgstr "ಕ್ಷೇತ್ರವು %(max)d ಅಕ್ಷರಕ್ಕಿಂತ ಉದ್ದವಾಗಿರಬಾರದು."

#, python-format
msgid "Field must be exactly %(max)d character long."
msgstr "ಕ್ಷೇತ್ರವು ನಿಖರವಾಗಿ %(ಗರಿಷ್ಠ)d ಅಕ್ಷರ ಉದ್ದವಿರಬೇಕು."

#, python-format
msgid "Field must be between %(min)d and %(max)d characters long."
msgstr "ಕ್ಷೇತ್ರವು %(min)d ಮತ್ತು %(max)d ಅಕ್ಷರಗಳ ನಡುವೆ ಇರಬೇಕು."

#, python-format
msgid "Number must be at least %(min)s."
msgstr "ಸಂಖ್ಯೆಯು ಕನಿಷ್ಠ %(ನಿಮಿಷ)s ಆಗಿರಬೇಕು."

#, python-format
msgid "Number must be at most %(max)s."
msgstr "ಸಂಖ್ಯೆಯು ಹೆಚ್ಚೆಂದರೆ %(ಗರಿಷ್ಠ)s ಆಗಿರಬೇಕು."

#, python-format
msgid "Number must be between %(min)s and %(max)s."
msgstr "ಸಂಖ್ಯೆಯು %(ನಿಮಿಷ) ಮತ್ತು %(ಗರಿಷ್ಠ)ಗಳ ನಡುವೆ ಇರಬೇಕು."

msgid "Invalid input."
msgstr "ಅಮಾನ್ಯ ಇನ್‌ಪುಟ್."

msgid "Invalid email address."
msgstr "ಅಮಾನ್ಯ ಇಮೇಲ್ ವಿಳಾಸ."

msgid "Invalid IP address."
msgstr "ಅಮಾನ್ಯ IP ವಿಳಾಸ."

msgid "Invalid Mac address."
msgstr "ಅಮಾನ್ಯ ಮ್ಯಾಕ್ ವಿಳಾಸ."

msgid "Invalid URL."
msgstr "ಅಮಾನ್ಯ URL."

msgid "Invalid UUID."
msgstr "ಅಮಾನ್ಯ UUID."

#, python-format
msgid "Invalid value, must be one of: %(values)s."
msgstr "ಅಮಾನ್ಯ ಮೌಲ್ಯ, ಇವುಗಳಲ್ಲಿ ಒಂದಾಗಿರಬೇಕು: %(ಮೌಲ್ಯಗಳು)s."

#, python-format
msgid "Invalid value, can't be any of: %(values)s."
msgstr "ಅಮಾನ್ಯ ಮೌಲ್ಯ, ಇವುಗಳಲ್ಲಿ ಯಾವುದೂ ಇರುವಂತಿಲ್ಲ: %(ಮೌಲ್ಯಗಳು)s."

msgid "This field cannot be edited."
msgstr "ಈ ಕ್ಷೇತ್ರವನ್ನು ಸಂಪಾದಿಸಲಾಗುವುದಿಲ್ಲ."

msgid "This field is disabled and cannot have a value."
msgstr "ಈ ಕ್ಷೇತ್ರವನ್ನು ನಿಷ್ಕ್ರಿಯಗೊಳಿಸಲಾಗಿದೆ ಮತ್ತು ಮೌಲ್ಯವನ್ನು ಹೊಂದಲು ಸಾಧ್ಯವಿಲ್ಲ."

msgid "Invalid CSRF Token."
msgstr "ಅಮಾನ್ಯ CSRF ಟೋಕನ್."

msgid "CSRF token missing."
msgstr "CSRF ಟೋಕನ್ ಕಾಣೆಯಾಗಿದೆ."

msgid "CSRF failed."
msgstr "CSRF ವಿಫಲವಾಗಿದೆ."

msgid "CSRF token expired."
msgstr "CSRF ಟೋಕನ್ ಅವಧಿ ಮುಗಿದಿದೆ."

msgid "Invalid Choice: could not coerce."
msgstr "ಅಮಾನ್ಯ ಆಯ್ಕೆ: ಒತ್ತಾಯಿಸಲು ಸಾಧ್ಯವಾಗಲಿಲ್ಲ."

msgid "Choices cannot be None."
msgstr "ಆಯ್ಕೆಗಳು ಯಾವುದೂ ಇರಬಾರದು."

msgid "Not a valid choice."
msgstr "ಮಾನ್ಯವಾದ ಆಯ್ಕೆಯಲ್ಲ."

msgid "Invalid choice(s): one or more data inputs could not be coerced."
msgstr ""
"ಅಮಾನ್ಯವಾದ ಆಯ್ಕೆ(ಗಳು): ಒಂದು ಅಥವಾ ಹೆಚ್ಚಿನ ಡೇಟಾ ಇನ್‌ಪುಟ್‌ಗಳನ್ನು ಒತ್ತಾಯಿಸಲು "
"ಸಾಧ್ಯವಿಲ್ಲ."

#, python-format
msgid "'%(value)s' is not a valid choice for this field."
msgstr "'%(value)s' ಈ ಕ್ಷೇತ್ರಕ್ಕೆ ಮಾನ್ಯವಾದ ಆಯ್ಕೆಯಾಗಿಲ್ಲ."

msgid "Not a valid datetime value."
msgstr "ಮಾನ್ಯವಾದ ದಿನಾಂಕದ ಮೌಲ್ಯವಲ್ಲ."

msgid "Not a valid date value."
msgstr "ಮಾನ್ಯವಾದ ದಿನಾಂಕ ಮೌಲ್ಯವಲ್ಲ."

msgid "Not a valid time value."
msgstr "ಮಾನ್ಯವಾದ ಸಮಯದ ಮೌಲ್ಯವಲ್ಲ."

msgid "Not a valid week value."
msgstr "ಮಾನ್ಯವಾದ ವಾರದ ಮೌಲ್ಯವಲ್ಲ."

msgid "Not a valid integer value."
msgstr "ಮಾನ್ಯವಾದ ಪೂರ್ಣಾಂಕ ಮೌಲ್ಯವಲ್ಲ."

msgid "Not a valid decimal value."
msgstr "ಮಾನ್ಯವಾದ ದಶಮಾಂಶ ಮೌಲ್ಯವಲ್ಲ."

msgid "Not a valid float value."
msgstr "ಮಾನ್ಯವಾದ ಫ್ಲೋಟ್ ಮೌಲ್ಯವಲ್ಲ."

