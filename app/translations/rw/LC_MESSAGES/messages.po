msgstr "izina} {filename! r} ni ububiko."

#, python-brace-format
msgid "{name} {filename!r} is not readable."
msgstr "izina} {filename! r} ntabwo isomeka."

#, python-brace-format
msgid "{name} {filename!r} is not writable."
msgstr "izina} {izina ryizina! r} ntabwo ryandikwa."

#, python-brace-format
msgid "{name} {filename!r} is not executable."
msgstr "izina} {filename! r} ntabwo bikorwa."

#, python-brace-format
msgid "{len_type} values are required, but {len_value} was given."
msgstr "{len_type} indangagaciro zirakenewe, ariko {len_gaciro} yatanzwe."

#, python-brace-format
msgid "Unknown standard stream '{name}'"
msgstr "Inzira isanzwe itazwi '{izina}'"

msgid "This field is required."
msgstr "Uyu murima urakenewe."

#, python-brace-format
msgid "File does not have an approved extension: {extensions}"
msgstr "Idosiye ntabwo ifite umugereka wemewe: {kwagura}"

msgid "File does not have an approved extension."
msgstr "Idosiye ntabwo ifite umugereka wemewe."

#, python-brace-format
msgid "File must be between {min_size} and {max_size} bytes."
msgstr "Idosiye igomba kuba hagati ya {min_size} na {max_size} bytes."

#, python-format
msgid "Invalid field name '%s'."
msgstr "Izina ryumwanya utemewe '% s'."

#, python-format
msgid "Field must be equal to %(other_name)s."
msgstr "Umwanya ugomba kuba uhwanye na% (andi_izina) s."

#, python-format
msgid "Field must be at least %(min)d character long."
msgstr "Umwanya ugomba kuba byibuze% (min) d inyuguti ndende."

#, python-format
msgid "Field cannot be longer than %(max)d character."
msgstr "Umwanya ntushobora kurenza% (max) d inyuguti."

#, python-format
msgid "Field must be exactly %(max)d character long."
msgstr "Umwanya ugomba kuba rwose% (max) d inyuguti ndende."

#, python-format
msgid "Field must be between %(min)d and %(max)d characters long."
msgstr "Umwanya ugomba kuba hagati ya% (min) d na% (max) d inyuguti ndende."

#, python-format
msgid "Number must be at least %(min)s."
msgstr "Umubare ugomba kuba byibuze% (min) s."

#, python-format
msgid "Number must be at most %(max)s."
msgstr "Umubare ugomba kuba kuri byinshi% (max) s."

#, python-format
msgid "Number must be between %(min)s and %(max)s."
msgstr "Umubare ugomba kuba hagati ya% (min) s na% (max) s."

msgid "Invalid input."
msgstr "Iyinjiza ritemewe."

msgid "Invalid email address."
msgstr "Aderesi imeri itemewe."

msgid "Invalid IP address."
msgstr "Aderesi ya IP itemewe."

msgid "Invalid Mac address."
msgstr "Aderesi ya Mac itemewe."

msgid "Invalid URL."
msgstr "URL itemewe."

msgid "Invalid UUID."
msgstr "UUID itemewe."

#, python-format
msgid "Invalid value, must be one of: %(values)s."
msgstr "Agaciro katemewe, kagomba kuba umwe muri:% (indangagaciro) s."

#, python-format
msgid "Invalid value, can't be any of: %(values)s."
msgstr "Agaciro katemewe, ntigashobora kuba na kimwe muri:% (indangagaciro) s."

msgid "This field cannot be edited."
msgstr "Uyu murima ntushobora guhindurwa."

msgid "This field is disabled and cannot have a value."
msgstr "Uyu murima urahagaritswe kandi ntushobora kugira agaciro."

msgid "Invalid CSRF Token."
msgstr "CSRF itemewe."

msgid "CSRF token missing."
msgstr "Ikimenyetso cya CSRF cyabuze."

msgid "CSRF failed."
msgstr "CSRF yananiwe."

msgid "CSRF token expired."
msgstr "Ikimenyetso cya CSRF cyararangiye."

msgid "Invalid Choice: could not coerce."
msgstr "Guhitamo bitemewe: ntibishobora guhatira."

msgid "Choices cannot be None."
msgstr "Guhitamo ntibishobora."

msgid "Not a valid choice."
msgstr "Ntabwo ari amahitamo yemewe."

msgid "Invalid choice(s): one or more data inputs could not be coerced."
msgstr ""
"Guhitamo bitemewe: kimwe cyangwa byinshi byinjira byinjira ntibishobora "
"guhatirwa."

#, python-format
msgid "'%(value)s' is not a valid choice for this field."
msgstr "'% (agaciro) s' ntabwo ari amahitamo yemewe kuri uyu murima."

msgid "Not a valid datetime value."
msgstr "Ntabwo agaciro kemewe."

msgid "Not a valid date value."
msgstr "Ntabwo ari itariki yemewe."

msgid "Not a valid time value."
msgstr "Ntabwo ari igihe cyemewe."

msgid "Not a valid week value."
msgstr "Ntabwo ari icyumweru cyemewe."

msgid "Not a valid integer value."
msgstr "Ntabwo ari agaciro keza."

msgid "Not a valid decimal value."
msgstr "Ntabwo agaciro kemewe."

msgid "Not a valid float value."
msgstr "Ntabwo agaciro kareremba."

