msgstr "{value!r} tekwatagana na nkola {format}."

#, python-brace-format
msgid "{value!r} is not a valid {number_type}."
msgstr "{value!r} si {ekika_namba} ekituufu."

#, python-brace-format
msgid "{value} is not in the range {range}."
msgstr "{omuwendo} teguli mu bbanga {range}."

#, python-brace-format
msgid "{value!r} is not a valid boolean. Recognized values: {states}"
msgstr "{value!r} si boolean entuufu. Emiwendo egimanyiddwa: {states}"

#, python-brace-format
msgid "{value!r} is not a valid UUID."
msgstr "{value!r} si UUID entuufu."

msgid "file"
msgstr "fayilo"

msgid "directory"
msgstr "dayirekita"

msgid "path"
msgstr "ekkubo"

#, python-brace-format
msgid "{name} {filename!r} does not exist."
msgstr "{erinnya} {erinnya lya fayiro!r} tewali."

#, python-brace-format
msgid "{name} {filename!r} is a file."
msgstr "{erinnya} {erinnya lya fayiro!r} ye fayiro."

#, python-brace-format
msgid "{name} {filename!r} is a directory."
msgstr "{erinnya} {erinnya lya fayiro!r} ye dayirekita."

#, python-brace-format
msgid "{name} {filename!r} is not readable."
msgstr "{erinnya} {erinnya lya fayiro!r} tekisomebwa."

#, python-brace-format
msgid "{name} {filename!r} is not writable."
msgstr "{erinnya} {erinnya lya fayiro!r} tekiwandiikibwa."

#, python-brace-format
msgid "{name} {filename!r} is not executable."
msgstr "{erinnya} {erinnya lya fayiro!r} tesobola kukolebwa."

#, python-brace-format
msgid "{len_type} values are required, but {len_value} was given."
msgstr "{len_type} emiwendo gyetaagisa, naye {len_value} yaweebwa."

#, python-brace-format
msgid "Unknown standard stream '{name}'"
msgstr "Omugga ogutamanyiddwa '{erinnya}'."

msgid "This field is required."
msgstr "Ennimiro eno yeetaagibwa."

#, python-brace-format
msgid "File does not have an approved extension: {extensions}"
msgstr "Fayiro terina ekyongereza ekikkirizibwa: {extensions}"

msgid "File does not have an approved extension."
msgstr "Fayiro terina kwongerako kukkirizibwa."

#, python-brace-format
msgid "File must be between {min_size} and {max_size} bytes."
msgstr "Fayiro erina okuba wakati wa {min_size} ne {max_size} bytes."

#, python-format
msgid "Invalid field name '%s'."
msgstr "Erinnya ly'ennimiro eritali ntuufu '%s'."

#, python-format
msgid "Field must be equal to %(other_name)s."
msgstr "Ennimiro erina okwenkana %(other_name)s."

#, python-format
msgid "Field must be at least %(min)d character long."
msgstr "Ennimiro erina okuba nga waakiri ennukuta %(min)d obuwanvu."

#, python-format
msgid "Field cannot be longer than %(max)d character."
msgstr "Ennimiro teyinza kuba mpanvu okusinga %(max)d character."

#, python-format
msgid "Field must be exactly %(max)d character long."
msgstr "Ennimiro erina okuba nga ddala %(max)d obuwanvu bw'ennukuta."

#, python-format
msgid "Field must be between %(min)d and %(max)d characters long."
msgstr "Ennimiro erina okuba wakati w'ennukuta %(min)d ne %(max)d obuwanvu."

#, python-format
msgid "Number must be at least %(min)s."
msgstr "Ennamba erina okuba waakiri %(min)s."

#, python-format
msgid "Number must be at most %(max)s."
msgstr "Omuwendo gulina okuba nga gusinga %(max)s."

#, python-format
msgid "Number must be between %(min)s and %(max)s."
msgstr "Omuwendo gulina okuba wakati wa %(min)s ne %(max)s."

msgid "Invalid input."
msgstr "Okuyingiza okutali kutuufu."

msgid "Invalid email address."
msgstr "Endagiriro ya email etali ntuufu."

msgid "Invalid IP address."
msgstr "Endagiriro ya IP etali ntuufu."

msgid "Invalid Mac address."
msgstr "Endagiriro ya Mac etali ntuufu."

msgid "Invalid URL."
msgstr "URL etali ntuufu."

msgid "Invalid UUID."
msgstr "UUID etali ntuufu."

#, python-format
msgid "Invalid value, must be one of: %(values)s."
msgstr "Omuwendo ogutali mutuufu, gulina okuba gumu ku: %(values)s."

#, python-format
msgid "Invalid value, can't be any of: %(values)s."
msgstr "Omuwendo ogutali mutuufu, teguyinza kuba gwonna ku: %(values)s."

msgid "This field cannot be edited."
msgstr "Ennimiro eno tesobola kulongoosebwa."

msgid "This field is disabled and cannot have a value."
msgstr "Ennimiro eno eremeddwa era tesobola kuba na muwendo."

msgid "Invalid CSRF Token."
msgstr "Akabonero ka CSRF akatali katuufu."

msgid "CSRF token missing."
msgstr "Akabonero ka CSRF kaabuze."

msgid "CSRF failed."
msgstr "CSRF eremereddwa."

msgid "CSRF token expired."
msgstr "Akabonero ka CSRF kaggwaako."

msgid "Invalid Choice: could not coerce."
msgstr "Invalid Choice: teyasobodde kukaka."

msgid "Choices cannot be None."
msgstr "Okulonda tekuyinza kuba Tewali."

msgid "Not a valid choice."
msgstr "Si kulonda kutuufu."

msgid "Invalid choice(s): one or more data inputs could not be coerced."
msgstr ""
"Okulonda (s) okutali kutuufu: okuyingiza data emu oba eziwera "
"tekwasobodde kukakibwa."

#, python-format
msgid "'%(value)s' is not a valid choice for this field."
msgstr "'%(value)s' si kulonda kutuufu ku nnimiro eno."

msgid "Not a valid datetime value."
msgstr "Si muwendo gwa datetime omutuufu."

msgid "Not a valid date value."
msgstr "Si muwendo gwa lunaku mutuufu."

msgid "Not a valid time value."
msgstr "Si muwendo gwa kiseera mutuufu."

msgid "Not a valid week value."
msgstr "Si muwendo gwa wiiki omutuufu."

msgid "Not a valid integer value."
msgstr "Si muwendo gwa namba enzijuvu omutuufu."

msgid "Not a valid decimal value."
msgstr "Si muwendo gwa decimal omutuufu."

msgid "Not a valid float value."
msgstr "Si muwendo gwa float omutuufu."

