#, python-brace-format
msgid "Choice({choices})"
msgstr "Pagpili({mga pagpili})"

#, python-brace-format
msgid "{value!r} does not match the format {format}."
msgstr "An {value!r} dae nakakatugma sa format na {format}."

#, python-brace-format
msgid "{value!r} is not a valid {number_type}."
msgstr "An {value!r} bakong balidong {number_type}."

#, python-brace-format
msgid "{value} is not in the range {range}."
msgstr "An {halaga} mayo sa sakop na {sakop}."

#, python-brace-format
msgid "{value!r} is not a valid boolean. Recognized values: {states}"
msgstr "An {value!r} bakong balidong boolean. Mga midbid na halaga: {mga estado}"

#, python-brace-format
msgid "{value!r} is not a valid UUID."
msgstr "An {value!r} bakong balidong UUID."

msgid "file"
msgstr "dokumento"

msgid "directory"
msgstr "direktoryo"

msgid "path"
msgstr "dalan"

#, python-brace-format
msgid "{name} {filename!r} does not exist."
msgstr "{pangaran} {pangaran nin sagunson!r} dai nag-eeksister."

#, python-brace-format
msgid "{name} {filename!r} is a file."
msgstr "{pangaran} {pangaran nin sagunson!r} sarong sagunson."

#, python-brace-format
msgid "{name} {filename!r} is a directory."
msgstr "An {name} {filename!r} sarong direktoryo."

#, python-brace-format
msgid "{name} {filename!r} is not readable."
msgstr "{pangaran} {pangaran nin sagunson!r} dae mababasa.'"

#, python-brace-format
msgid "{name} {filename!r} is not writable."
msgstr "{pangaran} {pangaran nin sagunson!r} dai pwedeng isurat."

#, python-brace-format
msgid "{name} {filename!r} is not executable."
msgstr "{name} {filename!r} dai pwedeng gibohon."

#, python-brace-format
msgid "{len_type} values are required, but {len_value} was given."
msgstr "An mga halaga kan {len_type} kaipuhan, alagad an {len_value} itinao."

#, python-brace-format
msgid "Unknown standard stream '{name}'"
msgstr "Dai aram na pamantayan na sulog '{name}'"

msgid "This field is required."
msgstr "Kaipuhan an larangan na ini."

#, python-brace-format
msgid "File does not have an approved extension: {extensions}"
msgstr "An sagunson mayo nin inaprobaran na ekstensyon: {extensions}"

msgid "File does not have an approved extension."
msgstr "An sagunson mayo nin aprobadong ekstensyon."

#, python-brace-format
msgid "File must be between {min_size} and {max_size} bytes."
msgstr ""
"An sagunson dapat nasa pag-oltanan kan {min_size} asin {max_size} na mga "
"byte."

#, python-format
msgid "Invalid field name '%s'."
msgstr "Bakong balido an pangaran kan larangan na '%s'."

#, python-format
msgid "Field must be equal to %(other_name)s."
msgstr "An larangan dapat na katumbas kan %(other_name)s."

#, python-format
msgid "Field must be at least %(min)d character long."
msgstr "An field dapat na dai mababa sa %(min)d na karakter an laba."

#, python-format
msgid "Field cannot be longer than %(max)d character."
msgstr "An field dai pwedeng mas halawig pa sa %(max)d na karakter."

#, python-format
msgid "Field must be exactly %(max)d character long."
msgstr "An field dapat eksaktong %(max)d na karakter an laba."

#, python-format
msgid "Field must be between %(min)d and %(max)d characters long."
msgstr ""
"An field dapat nasa pag-ultanan kan %(min)d asin %(max)d na mga karakter "
"an laba."

#, python-format
msgid "Number must be at least %(min)s."
msgstr "An numero dapat dai mababa sa %(min)s."

#, python-format
msgid "Number must be at most %(max)s."
msgstr "An numero dapat na pinakadakol sa %(max)s."

#, python-format
msgid "Number must be between %(min)s and %(max)s."
msgstr "An numero dapat nasa pag-ultanan kan %(min)s asin %(max)s."

msgid "Invalid input."
msgstr "Bakong balidong input."

msgid "Invalid email address."
msgstr "Bakong balidong email address."

msgid "Invalid IP address."
msgstr "Bakong balidong IP address."

msgid "Invalid Mac address."
msgstr "Bakong balidong Mac address."

msgid "Invalid URL."
msgstr "Bakong balidong URL."

msgid "Invalid UUID."
msgstr "Bakong balidong UUID."

#, python-format
msgid "Invalid value, must be one of: %(values)s."
msgstr "Bakong balidong halaga, dapat saro sa: %(mga halaga)s."

#, python-format
msgid "Invalid value, can't be any of: %(values)s."
msgstr "Bakong balidong halaga, dai pwedeng magin arin man sa: %(mga halaga)s."

msgid "This field cannot be edited."
msgstr "An larangan na ini dae puwedeng iliwat.'"

msgid "This field is disabled and cannot have a value."
msgstr "An larangan na ini dai napapagana asin dae pwedeng magkaigwa nin halaga."

msgid "Invalid CSRF Token."
msgstr "Bakong balidong CSRF Token."

msgid "CSRF token missing."
msgstr "Nawawara an token kan CSRF."

msgid "CSRF failed."
msgstr "Napalpak an CSRF."

msgid "CSRF token expired."
msgstr "An CSRF token nag-expire."

msgid "Invalid Choice: could not coerce."
msgstr "Bakong balidong Pagpili: dai kayang piriton."

msgid "Choices cannot be None."
msgstr "An mga pagpili dai pwedeng Mayo."

msgid "Not a valid choice."
msgstr "Bakong balidong pagpili."

msgid "Invalid choice(s): one or more data inputs could not be coerced."
msgstr ""
"Bakong balidong pagpili: saro o labi pang mga input nin datos dai pwedeng"
" piriton."

#, python-format
msgid "'%(value)s' is not a valid choice for this field."
msgstr "An '%(value)s' bakong balidong pagpili para sa larangan na ini.'"

msgid "Not a valid datetime value."
msgstr "Bakong balidong halaga nin petsa-oras."

msgid "Not a valid date value."
msgstr "Bakong balidong halaga nin petsa."

msgid "Not a valid time value."
msgstr "Bakong balidong halaga nin oras."

msgid "Not a valid week value."
msgstr "Bakong balidong halaga kan semana."

msgid "Not a valid integer value."
msgstr "Bakong balidong halaga nin integer."

msgid "Not a valid decimal value."
msgstr "Bakong balidong desimal na halaga."

msgid "Not a valid float value."
msgstr "Bakong balidong float value."

