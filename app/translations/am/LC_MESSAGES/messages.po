#, python-brace-format
msgid "File does not have an approved extension: {extensions}"
msgstr "ፋይሉ የጸደቀ ቅጥያ የለውም፡ {extensions}"

#, python-brace-format
msgid "File must be between {min_size} and {max_size} bytes."
msgstr "ፋይሉ በ{min_size} እና {max_size} ባይት መካከል መሆን አለበት።"

msgid "Gestion centralisée du système AntiVol"
