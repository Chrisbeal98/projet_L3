#, python-brace-format
msgid "Unknown color {colour!r}"
msgstr "Dath neo-aithnichte {color!r}"

msgid "Press any key to continue..."
msgstr "Brùth iuchair sam bith gus leantainn air adhart ..."

#, python-brace-format
msgid "Choose from:\\n\\t{choices}"
msgstr "Tagh o:\\n\\t{roghainnean}"

#, python-brace-format
msgid "{value!r} is not {choice}."
msgstr "Chan e {roghainn} a tha ann an {value!r}."

#, python-brace-format
msgid "Choice({choices})"
msgstr "Roghainn ({roghainnean})"

#, python-brace-format
msgid "{value!r} does not match the format {format}."
msgstr "Chan eil {value!r} a' freagairt ris an fhòrmat {format}."

#, python-brace-format
msgid "{value!r} is not a valid {number_type}."
msgstr "Chan e {number_type} dligheach a tha ann an {value!r}."

#, python-brace-format
msgid "{value} is not in the range {range}."
msgstr "Chan eil {value} san raon {raon}."

#, python-brace-format
msgid "{value!r} is not a valid boolean. Recognized values: {states}"
msgstr ""
"Chan e boolean dligheach a tha ann an {value!r}. Luachan aithnichte: "
"{states}"

#, python-brace-format
msgid "{value!r} is not a valid UUID."
msgstr "Chan e UUID dligheach a tha ann an {value!r}."

msgid "file"
msgstr "faidhle"

msgid "directory"
msgstr "eòlaire"

msgid "path"
msgstr "slighe"

#, python-brace-format
msgid "{name} {filename!r} does not exist."
msgstr "Chan eil {name} {filename!r} ann."

#, python-brace-format
msgid "{name} {filename!r} is a file."
msgstr "'S e faidhle a tha ann an {name} {filename!r}."

#, python-brace-format
msgid "{name} {filename!r} is a directory."
msgstr "Tha {name} {filename!r} na eòlaire."

#, python-brace-format
msgid "{name} {filename!r} is not readable."
msgstr "Chan eil {name} {filename!r} ri leughadh."

#, python-brace-format
msgid "{name} {filename!r} is not writable."
msgstr "Chan urrainn {name} {filename!r} a sgrìobhadh."

#, python-brace-format
msgid "{name} {filename!r} is not executable."
msgstr "Chan eil {name} {filename!r} so-ghnìomhaichte."

#, python-brace-format
msgid "{len_type} values are required, but {len_value} was given."
msgstr "Tha feum air {len_type} luachan, ach chaidh {len_value} a thoirt seachad."

#, python-brace-format
msgid "Unknown standard stream '{name}'"
msgstr "Sruth àbhaisteach neo-aithnichte '{name}'"

msgid "This field is required."
msgstr "Tha feum air an raon seo."

#, python-brace-format
msgid "File does not have an approved extension: {extensions}"
msgstr "Chan eil leudachan ceadaichte aig an fhaidhle: {extensions}"

msgid "File does not have an approved extension."
msgstr "Chan eil leudachadh ceadaichte aig an fhaidhle."

#, python-brace-format
msgid "File must be between {min_size} and {max_size} bytes."
msgstr "Feumaidh am faidhle a bhith eadar {min_size} agus {max_size} bytes."

#, python-format
msgid "Invalid field name '%s'."
msgstr "Ainm-raoin mì-dhligheach '%s'."

#, python-format
msgid "Field must be equal to %(other_name)s."
msgstr "Feumaidh an raon a bhith co-ionnan ri %(other_name)s."

#, python-format
msgid "Field must be at least %(min)d character long."
msgstr "Feumaidh an raon a bhith co-dhiù %(min)d caractar a dh’fhaid."

#, python-format
msgid "Field cannot be longer than %(max)d character."
msgstr "Chan fhaod an raon a bhith nas fhaide na %(max)d caractar."

#, python-format
msgid "Field must be exactly %(max)d character long."
msgstr "Feumaidh an raon a bhith dìreach %(max)d caractar a dh’fhaid."

#, python-format
msgid "Field must be between %(min)d and %(max)d characters long."
msgstr "Feumaidh an raon a bhith eadar %(min)d agus %(max)d caractar a dh’fhaid."

#, python-format
msgid "Number must be at least %(min)s."
msgstr "Feumaidh an àireamh a bhith co-dhiù %(min)s."

#, python-format
msgid "Number must be at most %(max)s."
msgstr "Feumaidh an àireamh a bhith aig a’ char as motha %(max)s."

#, python-format
msgid "Number must be between %(min)s and %(max)s."
msgstr "Feumaidh an àireamh a bhith eadar %(min)s agus %(max)s."

msgid "Invalid input."
msgstr "Cuir a-steach mì-dhligheach."

msgid "Invalid email address."
msgstr "Seòladh puist-d mì-dhligheach."

msgid "Invalid IP address."
msgstr "Seòladh IP mì-dhligheach."

msgid "Invalid Mac address."
msgstr "Seòladh Mac mì-dhligheach."

msgid "Invalid URL."
msgstr "URL mì-dhligheach."

msgid "Invalid UUID."
msgstr "UUID mì-dhligheach."

#, python-format
msgid "Invalid value, must be one of: %(values)s."
msgstr "Luach mì-dhligheach, feumaidh e bhith mar aon de: %(values)s."

#, python-format
msgid "Invalid value, can't be any of: %(values)s."
msgstr "Luach mì-dhligheach, chan urrainn dha a bhith ann de: %(values)s."

msgid "This field cannot be edited."
msgstr "Chan urrainnear an raon seo a dheasachadh."

msgid "This field is disabled and cannot have a value."
msgstr "Tha an raon seo à comas agus chan urrainn dha luach a bhith ann."

msgid "Invalid CSRF Token."
msgstr "Comharra CSRF mì-dhligheach."

msgid "CSRF token missing."
msgstr "tòcan CSRF a dhìth."

msgid "CSRF failed."
msgstr "Dh'fhàillig CSRF."

msgid "CSRF token expired."
msgstr "Thàinig crìoch air tòcan CSRF."

msgid "Invalid Choice: could not coerce."
msgstr "Roghainn mì-dhligheach: cha b' urrainn dhuinn co-èigneachadh."

msgid "Choices cannot be None."
msgstr "Chan fhaod roghainnean a bhith idir."

msgid "Not a valid choice."
msgstr "Chan e roghainn dligheach."

msgid "Invalid choice(s): one or more data inputs could not be coerced."
msgstr ""
"Roghainn neo-dhligheach: cha b’ urrainn dhuinn aon no barrachd a chuir "
"a-steach dàta a cho-èigneachadh."

#, python-format
msgid "'%(value)s' is not a valid choice for this field."
msgstr "Chan eil '%(value)s' 'na roghainn dhligheach airson an raoin seo."

msgid "Not a valid datetime value."
msgstr "Chan e luach ceann-latha dligheach a th’ ann."

msgid "Not a valid date value."
msgstr "Chan e luach ceann-latha dligheach."

msgid "Not a valid time value."
msgstr "Chan e luach ùine dligheach a th’ ann."

msgid "Not a valid week value."
msgstr "Chan e luach seachdaineach dligheach."

msgid "Not a valid integer value."
msgstr "Chan e luach iomlan iomlan a th’ ann."

msgid "Not a valid decimal value."
msgstr "Chan e luach deicheach dligheach."

msgid "Not a valid float value."
msgstr "Chan e luach fleòdraidh dligheach a th’ ann."

