#, python-brace-format
msgid "File must be between {min_size} and {max_size} bytes."
msgstr "Triem moat tusken {min_size} en {max_size} bytes wêze."

#, python-format
msgid "Invalid field name '%s'."
msgstr "Unjildige fjildnamme '%s'."

#, python-format
msgid "Field must be equal to %(other_name)s."
msgstr "It fjild moat lyk wêze oan %(other_name)s."

#, python-format
msgid "Field must be at least %(min)d character long."
msgstr "It fjild moat op syn minst %(min)d karakter lang wêze."

#, python-format
msgid "Field cannot be longer than %(max)d character."
msgstr "Fjild kin net langer wêze as %(max)d karakter."

#, python-format
msgid "Field must be exactly %(max)d character long."
msgstr "It fjild moat krekt %(max)d karakter lang wêze."

#, python-format
msgid "Field must be between %(min)d and %(max)d characters long."
msgstr "It fjild moat tusken %(min)d en %(max)d tekens lang wêze."

#, python-format
msgid "Number must be at least %(min)s."
msgstr "It nûmer moat op syn minst %(min)s wêze."

#, python-format
msgid "Number must be at most %(max)s."
msgstr "It nûmer moat op syn heechst %(max)s wêze."

#, python-format
msgid "Number must be between %(min)s and %(max)s."
msgstr "It nûmer moat tusken %(min)s en %(max)s wêze."

msgid "Invalid input."
msgstr "Unjildige ynfier."

msgid "Invalid email address."
msgstr "Unjildich e-postadres."

msgid "Invalid IP address."
msgstr "Unjildich IP-adres."

msgid "Invalid Mac address."
msgstr "Unjildich Mac-adres."

msgid "Invalid URL."
msgstr "Unjildige URL."

msgid "Invalid UUID."
msgstr "Unjildige UUID."

#, python-format
msgid "Invalid value, must be one of: %(values)s."
msgstr "Unjildige wearde, moat ien fan wêze: %(wearden)s."

#, python-format
msgid "Invalid value, can't be any of: %(values)s."
msgstr "Unjildige wearde, kin net ien wêze fan: %(wearden)s."

msgid "This field cannot be edited."
msgstr "Dit fjild kin net bewurke wurde."

msgid "This field is disabled and cannot have a value."
msgstr "Dit fjild is útskeakele en kin gjin wearde hawwe."

msgid "Invalid CSRF Token."
msgstr "Unjildige CSRF Token."

msgid "CSRF token missing."
msgstr "CSRF token mist."

msgid "CSRF failed."
msgstr "CSRF mislearre."

msgid "CSRF token expired."
msgstr "CSRF token ferrûn."

msgid "Invalid Choice: could not coerce."
msgstr "Unjildige kar: koe net twinge."

msgid "Choices cannot be None."
msgstr "Keuzes kinne gjin gjin wêze."

msgid "Not a valid choice."
msgstr "Net in jildige kar."

msgid "Invalid choice(s): one or more data inputs could not be coerced."
msgstr "Unjildige kar(s): ien of mear gegevensynputs koene net twongen wurde."

#, python-format
msgid "'%(value)s' is not a valid choice for this field."
msgstr "'%(value)s' is gjin jildige kar foar dit fjild."

msgid "Not a valid datetime value."
msgstr "Net in jildige datetime wearde."

msgid "Not a valid date value."
msgstr "Gjin jildige datumwearde."

msgid "Not a valid time value."
msgstr "Gjin jildige tiidwearde."

msgid "Not a valid week value."
msgstr "Net in jildige wike wearde."

msgid "Not a valid integer value."
msgstr "Net in jildige hiele getal wearde."

msgid "Not a valid decimal value."
msgstr "Net in jildige desimale wearde."

msgid "Not a valid float value."
msgstr "Net in jildige floatwearde."

