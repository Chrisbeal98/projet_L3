#, python-format
msgid "Field must be exactly %(max)d character long."
msgstr "El campo debe tener exactamente %(max)d caracteres."

#, python-format
msgid "Field must be between %(min)d and %(max)d characters long."
msgstr "El campo debe tener entre %(min)d y %(max)d caracteres."

#, python-format
msgid "Number must be at least %(min)s."
msgstr "El número debe ser al menos %(min)s."

#, python-format
msgid "Number must be at most %(max)s."
msgstr "El número debe ser como máximo %(max)s."

#, python-format
msgid "Number must be between %(min)s and %(max)s."
msgstr "El número debe estar entre %(min)s y %(max)s."

msgid "Invalid input."
msgstr "Entrada no válida."

msgid "Invalid email address."
msgstr "Dirección de correo electrónico no válida."

msgid "Invalid IP address."
msgstr "Dirección IP no válida."

msgid "Invalid Mac address."
msgstr "Dirección Mac no válida."

msgid "Invalid URL."
msgstr "URL no válida."

msgid "Invalid UUID."
msgstr "UUID no válido."

#, python-format
msgid "Invalid value, must be one of: %(values)s."
msgstr "Valor no válido, debe ser uno de: %(values)s."

#, python-format
msgid "Invalid value, can't be any of: %(values)s."
msgstr "Valor no válido, no puede ser ninguno de: %(values)s."

msgid "This field cannot be edited."
msgstr "Este campo no se puede editar."

msgid "This field is disabled and cannot have a value."
msgstr "Este campo está deshabilitado y no puede tener un valor."

msgid "Invalid CSRF Token."
msgstr "Token CSRF no válido."

msgid "CSRF token missing."
msgstr "Falta el token CSRF."

msgid "CSRF failed."
msgstr "CSRF falló."

msgid "CSRF token expired."
msgstr "El token CSRF expiró."

msgid "Invalid Choice: could not coerce."
msgstr "Elección no válida: no se pudo coaccionar."

msgid "Choices cannot be None."
msgstr "Las opciones no pueden ser Ninguna."

msgid "Not a valid choice."
msgstr "No es una elección válida."

msgid "Invalid choice(s): one or more data inputs could not be coerced."
msgstr ""
"Elección(es) no válida(s): una o más entradas de datos no se pudieron "
"forzar."

#, python-format
msgid "'%(value)s' is not a valid choice for this field."
msgstr "'%(value)s' no es una opción válida para este campo."

msgid "Not a valid datetime value."
msgstr "No es un valor de fecha y hora válido."

msgid "Not a valid date value."
msgstr "No es un valor de fecha válido."

msgid "Not a valid time value."
msgstr "No es un valor de tiempo válido."

msgid "Not a valid week value."
msgstr "No es un valor de semana válido."

msgid "Not a valid integer value."
msgstr "No es un valor entero válido."

msgid "Not a valid decimal value."
msgstr "No es un valor decimal válido."

msgid "Not a valid float value."
msgstr "No es un valor flotante válido."

