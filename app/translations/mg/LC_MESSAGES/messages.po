msgstr "{name} {filename!r} dia tsy misy."

#, python-brace-format
msgid "{name} {filename!r} is a file."
msgstr "{name} {filename!r} dia rakitra."

#, python-brace-format
msgid "{name} {filename!r} is a directory."
msgstr "{name} {filename!r} dia lahatahiry iray."

#, python-brace-format
msgid "{name} {filename!r} is not readable."
msgstr "{name} {filename!r} dia tsy azo vakina."

#, python-brace-format
msgid "{name} {filename!r} is not writable."
msgstr "{name} {filename!r} dia tsy azo soratana."

#, python-brace-format
msgid "{name} {filename!r} is not executable."
msgstr "{name} {filename!r} dia tsy azo tanterahina."

#, python-brace-format
msgid "{len_type} values are required, but {len_value} was given."
msgstr "Ilaina ny sanda {len_type}, fa nomena ny {len_value}."

#, python-brace-format
msgid "Unknown standard stream '{name}'"
msgstr "'{name}' tsy fantatra"

msgid "This field is required."
msgstr "Tsy maintsy fenoina ity saha ity."

#, python-brace-format
msgid "File does not have an approved extension: {extensions}"
msgstr "Tsy manana fanitarana ankatoavina ny rakitra: {extensions}"

msgid "File does not have an approved extension."
msgstr "Tsy manana fanitarana nankatoavina ny rakitra."

#, python-brace-format
msgid "File must be between {min_size} and {max_size} bytes."
msgstr ""
"Ny rakitra dia tsy maintsy eo anelanelan'ny {min_size} sy {max_size} "
"bytes."

#, python-format
msgid "Invalid field name '%s'."
msgstr "Anarana saha tsy mety '%s'."

#, python-format
msgid "Field must be equal to %(other_name)s."
msgstr "Ny saha dia tsy maintsy mitovy amin'ny %(other_name)s."

#, python-format
msgid "Field must be at least %(min)d character long."
msgstr "Ny saha dia tsy maintsy %(min)d fara-fahakeliny ny halavany."

#, python-format
msgid "Field cannot be longer than %(max)d character."
msgstr "Ny saha dia tsy afaka mihoatra ny %(max)d tarehintsoratra."

#, python-format
msgid "Field must be exactly %(max)d character long."
msgstr "Tokony ho %(max)d ny halavan'ny saha."

#, python-format
msgid "Field must be between %(min)d and %(max)d characters long."
msgstr "Tokony ho eo anelanelan'ny %(min)d sy %(max)d tarehintsoratra ny saha."

#, python-format
msgid "Number must be at least %(min)s."
msgstr "Ny isa dia tsy maintsy farafahakeliny %(min)s."

#, python-format
msgid "Number must be at most %(max)s."
msgstr "Ny isa dia tokony ho %(max)s fara-fahakeliny."

#, python-format
msgid "Number must be between %(min)s and %(max)s."
msgstr "Ny isa dia tsy maintsy eo anelanelan'ny %(min)s sy %(max)s."

msgid "Invalid input."
msgstr "Fampidirana tsy mety."

msgid "Invalid email address."
msgstr "Adiresy mailaka tsy mety."

msgid "Invalid IP address."
msgstr "Adiresy IP tsy mety."

msgid "Invalid Mac address."
msgstr "Adiresy Mac tsy mety."

msgid "Invalid URL."
msgstr "URL tsy mety."

msgid "Invalid UUID."
msgstr "UUID tsy mety."

#, python-format
msgid "Invalid value, must be one of: %(values)s."
msgstr "Sanda tsy mety, tsy maintsy iray amin'ny: %(values)s."

#, python-format
msgid "Invalid value, can't be any of: %(values)s."
msgstr "Sanda tsy mety, tsy mety amin'ny: %(values)s."

msgid "This field cannot be edited."
msgstr "Tsy azo ovaina ity saha ity."

msgid "This field is disabled and cannot have a value."
msgstr "Ity saha ity dia kilemaina ary tsy misy sandany."

msgid "Invalid CSRF Token."
msgstr "Token CSRF tsy mety."

msgid "CSRF token missing."
msgstr "CSRF token tsy hita."

msgid "CSRF failed."
msgstr "Tsy nahomby ny CSRF."

msgid "CSRF token expired."
msgstr "Lany daty ny token'ny CSRF."

msgid "Invalid Choice: could not coerce."
msgstr "Safidy tsy mety: tsy azo terena."

msgid "Choices cannot be None."
msgstr "Tsy mety ho Tsia ny safidy."

msgid "Not a valid choice."
msgstr "Tsy safidy mitombina."

msgid "Invalid choice(s): one or more data inputs could not be coerced."
msgstr "Safidy tsy mety: tsy azo terena ny fampidirana data iray na maromaro."

#, python-format
msgid "'%(value)s' is not a valid choice for this field."
msgstr "'%(value)s' dia tsy safidy mety amin'ity saha ity."

msgid "Not a valid datetime value."
msgstr "Tsy sanda daty manan-kery."

msgid "Not a valid date value."
msgstr "Tsy sanda daty manan-kery."

msgid "Not a valid time value."
msgstr "Tsy sanda ara-potoana manan-kery."

msgid "Not a valid week value."
msgstr "Tsy sanda mety amin'ny herinandro."

msgid "Not a valid integer value."
msgstr "Tsy sanda integer manankery."

msgid "Not a valid decimal value."
msgstr "Tsy sanda desimal mitombina."

msgid "Not a valid float value."
msgstr "Tsy sanda mitsingevana mitombina."

