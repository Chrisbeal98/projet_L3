" поддържа."

msgid "Repeat for confirmation"
msgstr "Повторете за потвърждение"

msgid "Error: The two entered values do not match."
msgstr "Грешка: Двете въведени стойности не съвпадат."

msgid "Error: invalid input"
msgstr "Грешка: невалиден вход"

#, python-brace-format
msgid "Unknown color {colour!r}"
msgstr "Неизвестен цвят {color!r}"

msgid "Press any key to continue..."
msgstr "Натиснете произволен клавиш, за да продължите..."

#, python-brace-format
msgid "Choose from:\\n\\t{choices}"
msgstr "Изберете от:\\n\\t{избори}"

#, python-brace-format
msgid "{value!r} is not {choice}."
msgstr "{value!r} не е {choice}."

#, python-brace-format
msgid "Choice({choices})"
msgstr "Избор ({choices})"

#, python-brace-format
msgid "{value!r} does not match the format {format}."
msgstr "{value!r} не съответства на формата {format}."

#, python-brace-format
msgid "{value!r} is not a valid {number_type}."
msgstr "{value!r} не е валиден {number_type}."

#, python-brace-format
msgid "{value} is not in the range {range}."
msgstr "{value} не е в диапазона {range}."

#, python-brace-format
msgid "{value!r} is not a valid boolean. Recognized values: {states}"
msgstr "{value!r} не е валидно булево значение. Разпознати стойности: {състояния}"

#, python-brace-format
msgid "{value!r} is not a valid UUID."
msgstr "{value!r} не е валиден UUID."

msgid "file"
msgstr "файл"

msgid "directory"
msgstr "указател"

msgid "path"
msgstr "път"

#, python-brace-format
msgid "{name} {filename!r} does not exist."
msgstr "{name} {filename!r} не съществува."

#, python-brace-format
msgid "{name} {filename!r} is a file."
msgstr "{name} {filename!r} е файл."

#, python-brace-format
msgid "{name} {filename!r} is a directory."
msgstr "{name} {filename!r} е директория."

#, python-brace-format
msgid "{name} {filename!r} is not readable."
msgstr "{name} {filename!r} не се чете."

#, python-brace-format
msgid "{name} {filename!r} is not writable."
msgstr "{name} {filename!r} не може да се записва."

#, python-brace-format
msgid "{name} {filename!r} is not executable."
msgstr "{name} {filename!r} не е изпълним."

#, python-brace-format
msgid "{len_type} values are required, but {len_value} was given."
msgstr "Стойностите {len_type} са задължителни, но е дадено {len_value}."

#, python-brace-format
msgid "Unknown standard stream '{name}'"
msgstr "Неизвестен стандартен поток „{name}“"

msgid "This field is required."
msgstr "Това поле е задължително."

#, python-brace-format
msgid "File does not have an approved extension: {extensions}"
msgstr "Файлът няма одобрено разширение: {extensions}"

msgid "File does not have an approved extension."
msgstr "Файлът няма одобрено разширение."

#, python-brace-format
msgid "File must be between {min_size} and {max_size} bytes."
msgstr "Файлът трябва да е между {min_size} и {max_size} байта."

#, python-format
msgid "Invalid field name '%s'."
msgstr "Невалидно име на полето „%s“."

#, python-format
msgid "Field must be equal to %(other_name)s."
msgstr "Полето трябва да е равно на %(other_name)s."

#, python-format
msgid "Field must be at least %(min)d character long."
msgstr "Полето трябва да съдържа най-малко %(min)d знак."

#, python-format
msgid "Field cannot be longer than %(max)d character."
msgstr "Полето не може да бъде по-дълго от %(max)d знак."

#, python-format
msgid "Field must be exactly %(max)d character long."
msgstr "Полето трябва да съдържа точно %(max)d знак."

#, python-format
msgid "Field must be between %(min)d and %(max)d characters long."
msgstr "Полето трябва да е с дължина между %(min)d и %(max)d знака."

#, python-format
msgid "Number must be at least %(min)s."
msgstr "Числото трябва да е поне %(min)s."

#, python-format
msgid "Number must be at most %(max)s."
msgstr "Броят трябва да бъде най-много %(max)s."

#, python-format
msgid "Number must be between %(min)s and %(max)s."
msgstr "Числото трябва да е между %(min)s и %(max)s."

msgid "Invalid input."
msgstr "Невалиден вход."

msgid "Invalid email address."
msgstr "Невалиден имейл адрес."

msgid "Invalid IP address."
msgstr "Невалиден IP адрес."

msgid "Invalid Mac address."
msgstr "Невалиден Mac адрес."

msgid "Invalid URL."
msgstr "Невалиден URL адрес."

msgid "Invalid UUID."
msgstr "Невалиден UUID."

#, python-format
msgid "Invalid value, must be one of: %(values)s."
msgstr "Невалидна стойност, трябва да бъде една от: %(values)s."

#, python-format
msgid "Invalid value, can't be any of: %(values)s."
msgstr "Невалидна стойност, не може да бъде нито една от: %(values)s."

msgid "This field cannot be edited."
msgstr "Това поле не може да се редактира."

msgid "This field is disabled and cannot have a value."
msgstr "Това поле е деактивирано и не може да има стойност."

msgid "Invalid CSRF Token."
msgstr "Невалиден CSRF токен."

msgid "CSRF token missing."
msgstr "Липсва CSRF токен."

msgid "CSRF failed."
msgstr "CSRF не успя."

msgid "CSRF token expired."
msgstr "CSRF токенът е изтекъл."

msgid "Invalid Choice: could not coerce."
msgstr "Невалиден избор: не може да се принуди."

msgid "Choices cannot be None."
msgstr "Изборите не могат да бъдат никакви."

msgid "Not a valid choice."
msgstr "Невалиден избор."

msgid "Invalid choice(s): one or more data inputs could not be coerced."
msgstr ""
"Невалиден избор(и): един или повече входни данни не могат да бъдат "
"принудени."

#, python-format
msgid "'%(value)s' is not a valid choice for this field."
msgstr "„%(value)s“ не е валиден избор за това поле."

msgid "Not a valid datetime value."
msgstr "Невалидна стойност за дата и час."

msgid "Not a valid date value."
msgstr "Не е валидна стойност на датата."

msgid "Not a valid time value."
msgstr "Невалидна времева стойност."

msgid "Not a valid week value."
msgstr "Невалидна седмична стойност."

msgid "Not a valid integer value."
msgstr "Не е валидна цяло число."

msgid "Not a valid decimal value."
msgstr "Не е валидна десетична стойност."

msgid "Not a valid float value."
msgstr "Невалидна плаваща стойност."

