msgstr "Fichièr a pas una extension aprovada."

#, python-brace-format
msgid "File must be between {min_size} and {max_size} bytes."
msgstr "Lo fichièr deu èsser entre los octets {talha_min_size} e {talha_maximala}."

#, python-format
msgid "Invalid field name '%s'."
msgstr "Nom de camp « %s » invalid."

#, python-format
msgid "Field must be equal to %(other_name)s."
msgstr "Lo camp deu èsser egal a %(other_name)s."

#, python-format
msgid "Field must be at least %(min)d character long."
msgstr "Lo camp deu aver al mens %(min)d caractèr de long."

#, python-format
msgid "Field cannot be longer than %(max)d character."
msgstr "Lo camp pòt pas èsser mai long que %(max)d caractèr."

#, python-format
msgid "Field must be exactly %(max)d character long."
msgstr "Lo camp deu aver exactament %(max)d caractèr de long."

#, python-format
msgid "Field must be between %(min)d and %(max)d characters long."
msgstr "Lo camp deu aver entre %(min)d e %(max)d caractèrs de long."

#, python-format
msgid "Number must be at least %(min)s."
msgstr "Lo nombre deu èsser al mens %(min)s."

#, python-format
msgid "Number must be at most %(max)s."
msgstr "Lo nombre deu èsser al maximum %(max)s."

#, python-format
msgid "Number must be between %(min)s and %(max)s."
msgstr "Lo nombre deu èsser entre %(min)s e %(max)s."

msgid "Invalid input."
msgstr "Entrada invalida."

msgid "Invalid email address."
msgstr "Adreça electronica invalida."

msgid "Invalid IP address."
msgstr "Adreça IP invalida."

msgid "Invalid Mac address."
msgstr "Adreça Mac invalida."

msgid "Invalid URL."
msgstr "URL invalida."

msgid "Invalid UUID."
msgstr "UUID invalid."

#, python-format
msgid "Invalid value, must be one of: %(values)s."
msgstr "Valor invalida, deu èsser una de : %(values)s."

#, python-format
msgid "Invalid value, can't be any of: %(values)s."
msgstr "Valor invalida, pòt pas èsser cap de: %(values)s."

msgid "This field cannot be edited."
msgstr "Aqueste camp pòt pas èsser modificat."

msgid "This field is disabled and cannot have a value."
msgstr "Aqueste camp es desactivat e pòt pas aver una valor."

msgid "Invalid CSRF Token."
msgstr "Geton CSRF invalid."

msgid "CSRF token missing."
msgstr "Geton CSRF mancant."

msgid "CSRF failed."
msgstr "CSRF a fracassat."

msgid "CSRF token expired."
msgstr "Lo jeton CSRF expirat."

msgid "Invalid Choice: could not coerce."
msgstr "Causida invalida: poguèt pas coercir."

msgid "Choices cannot be None."
msgstr "Las causidas pòdon pas èsser Cap."

msgid "Not a valid choice."
msgstr "Pas una causida valida."

msgid "Invalid choice(s): one or more data inputs could not be coerced."
msgstr ""
"Causida(s) invalida(s): una o mai d'entradas de donadas poguèron pas "
"èsser coercidas."

#, python-format
msgid "'%(value)s' is not a valid choice for this field."
msgstr "« %(value)s » es pas una causida valida per aqueste camp."

msgid "Not a valid datetime value."
msgstr "Pas una valor de dataora valida."

msgid "Not a valid date value."
msgstr "Pas una valor de data valida."

msgid "Not a valid time value."
msgstr "Pas una valor de temps valida."

msgid "Not a valid week value."
msgstr "Pas una valor de setmana valida."

msgid "Not a valid integer value."
msgstr "Pas una valor entièra valida."

msgid "Not a valid decimal value."
msgstr "Pas una valor decimala valida."

msgid "Not a valid float value."
msgstr "Pas una valor de flotacion valida."

