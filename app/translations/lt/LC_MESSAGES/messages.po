#, python-brace-format
msgid "File does not have an approved extension: {extensions}"
msgstr "Failas neturi patvirtinto plėtinio: {extensions}"

msgid "File does not have an approved extension."
msgstr "Failas neturi patvirtinto plėtinio."

#, python-brace-format
msgid "File must be between {min_size} and {max_size} bytes."
msgstr "Failas turi būti nuo {min_size} iki {max_size} baitų."

#, python-format
msgid "Invalid field name '%s'."
msgstr "Neteisingas lauko pavadinimas „%s“."

#, python-format
msgid "Field must be equal to %(other_name)s."
msgstr "Laukas turi būti lygus %(other_name)s."

#, python-format
msgid "Field must be at least %(min)d character long."
msgstr "Lauke turi būti bent %(min)d simbolio."

#, python-format
msgid "Field cannot be longer than %(max)d character."
msgstr "Laukas negali būti ilgesnis nei %(max)d simbolio."

#, python-format
msgid "Field must be exactly %(max)d character long."
msgstr "Laukas turi būti tiksliai %(max)d simbolio ilgio."

#, python-format
msgid "Field must be between %(min)d and %(max)d characters long."
msgstr "Lauką turi sudaryti nuo %(min)d iki %(max)d simbolių."

#, python-format
msgid "Number must be at least %(min)s."
msgstr "Skaičius turi būti bent %(min)s."

#, python-format
msgid "Number must be at most %(max)s."
msgstr "Skaičius turi būti ne didesnis kaip %(max)s."

#, python-format
msgid "Number must be between %(min)s and %(max)s."
msgstr "Skaičius turi būti nuo %(min)s iki %(max)s."

