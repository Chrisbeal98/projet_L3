msgid "{name} {filename!r} is not readable."
msgstr "{name} {filename!r} ti siña ma taitai."

#, python-brace-format
msgid "{name} {filename!r} is not writable."
msgstr "{name} {filename!r} ti siña ma tuge'."

#, python-brace-format
msgid "{name} {filename!r} is not executable."
msgstr "{name} {filename!r} ti siña ma'usa."

#, python-brace-format
msgid "{len_type} values are required, but {len_value} was given."
msgstr "{len_type} na balotu siha manma nisisita, lao {len_value} ma nå'i."

#, python-brace-format
msgid "Unknown standard stream '{name}'"
msgstr "Ti ma tungo' i estao '{name}'"

msgid "This field is required."
msgstr "Este na lugåt nisisåriu."

#, python-brace-format
msgid "File does not have an approved extension: {extensions}"
msgstr "Ti ma'aprueba i ekstension i file: {extensions}"

msgid "File does not have an approved extension."
msgstr "Ti ma'aprueba i ekstension i file."

#, python-brace-format
msgid "File must be between {min_size} and {max_size} bytes."
msgstr "I file debi di u gaige gi entre {min_size} yan {max_size} bytes."

#, python-format
msgid "Invalid field name '%s'."
msgstr "Ti maolek i na'an i lugåt '%s'."

#, python-format
msgid "Field must be equal to %(other_name)s."
msgstr "I lugåt debi di u parehu yan %(other_name)s."

#, python-format
msgid "Field must be at least %(min)d character long."
msgstr "I lugåt debi di u mas ki %(min)d na letra i lina'la'-ña."

#, python-format
msgid "Field cannot be longer than %(max)d character."
msgstr "Ti siña mas takhilo' ki %(max)d na letra i lugåt."

#, python-format
msgid "Field must be exactly %(max)d character long."
msgstr "Debi di u %(max)d na letra i lina'la' i lugåt."

#, python-format
msgid "Field must be between %(min)d and %(max)d characters long."
msgstr "I lugåt debi di u gaige gi entre %(min)d yan %(max)d na letra siha."

#, python-format
msgid "Number must be at least %(min)s."
msgstr "I numero debi di u mas ki %(min)s."

#, python-format
msgid "Number must be at most %(max)s."
msgstr "I numero debi di u mas takhilo' ki %(max)s."

#, python-format
msgid "Number must be between %(min)s and %(max)s."
msgstr "I numero debi di u gaige gi entre %(min)s yan %(max)s."

msgid "Invalid input."
msgstr "Ti maolek i input."

msgid "Invalid email address."
msgstr "Ti maolek i email-mu."

msgid "Invalid IP address."
msgstr "Ti maolek i IP address."

msgid "Invalid Mac address."
msgstr "Ti maolek i direksion Mac."

msgid "Invalid URL."
msgstr "Ti maolek na URL."

msgid "Invalid UUID."
msgstr "Ti maolek i UUID."

#, python-format
msgid "Invalid value, must be one of: %(values)s."
msgstr "I balotu ni' ti maolek, debi di unu gi: %(values)s."

#, python-format
msgid "Invalid value, can't be any of: %(values)s."
msgstr "Ti maolek na balotu, ti siña ni' unu gi: %(values)s."

msgid "This field cannot be edited."
msgstr "Ti siña ma na'lå'la' este na lugåt."

msgid "This field is disabled and cannot have a value."
msgstr "Ma na'suha este na lugåt ya ti siña guaha balotu-ña."

msgid "Invalid CSRF Token."
msgstr "Ti maolek i CSRF Token."

msgid "CSRF token missing."
msgstr "Ti ma sodda' i CSRF na token."

msgid "CSRF failed."
msgstr "Ti siña i CSRF."

msgid "CSRF token expired."
msgstr "I CSRF na token esta måpos."

msgid "Invalid Choice: could not coerce."
msgstr "Ti maolek na disision: ti siña ma'a'agang."

msgid "Choices cannot be None."
msgstr "Ti siña i disision siha taya'."

msgid "Not a valid choice."
msgstr "Ti maolek na disision."

msgid "Invalid choice(s): one or more data inputs could not be coerced."
msgstr ""
"Ti maolek na disision(siha): unu pat mas na input na dañu ti siña "
"ma'a'agang."

#, python-format
msgid "'%(value)s' is not a valid choice for this field."
msgstr "'%(value)s' ti maolek na cho'cho' para este na lugåt."

msgid "Not a valid datetime value."
msgstr "Ti bali i balotu gi i fecha yan tiempo."

msgid "Not a valid date value."
msgstr "Ti bali i fecha."

msgid "Not a valid time value."
msgstr "Ti bali i tiempo."

msgid "Not a valid week value."
msgstr "Ti bali i balotu gi i simana."

msgid "Not a valid integer value."
msgstr "Ti bali i numeron enteru."

msgid "Not a valid decimal value."
msgstr "Ti bali i desimal na balotu."

msgid "Not a valid float value."
msgstr "Ti bali i balotu-ña."

