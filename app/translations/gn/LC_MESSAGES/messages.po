msgstr "Sa'y ndojekuaáiva {color!r}."

msgid "Press any key to continue..."
msgstr "Emboguejy oimeraẽ tecla eñepyrũ hag̃ua..."

#, python-brace-format
msgid "Choose from:\\n\\t{choices}"
msgstr "Eiporavo:\\n\\t{jeporavokuéra}."

#, python-brace-format
msgid "{value!r} is not {choice}."
msgstr "{valor!r} ndaha’éi {jeporavo}."

#, python-brace-format
msgid "Choice({choices})"
msgstr "Jeporavo({jeporavokuéra}) ."

#, python-brace-format
msgid "{value!r} does not match the format {format}."
