msgstr "Token CSRF ndojeporúiva."

msgid "CSRF token missing."
msgstr "CSRF token ofalta."

msgid "CSRF failed."
msgstr "CSRF ndoikói."

msgid "CSRF token expired."
msgstr "CSRF token oñemohu’ãma."

msgid "Invalid Choice: could not coerce."
