msgid "{len_type} values are required, but {len_value} was given."
msgstr "{len_type} mba’ekuaarã oñeikotevẽ, ha katu oñeme’ẽkuri {len_value}."

#, python-brace-format
msgid "Unknown standard stream '{name}'"
msgstr "Ysyry estándar ndojekuaáiva '{téra}'."

msgid "This field is required."
msgstr "Ko campo oñeikotevẽ."

#, python-brace-format
msgid "File does not have an approved extension: {extensions}"
msgstr "Archivo ndorekói peteĩ extensión oñemoneĩva: {extensions}."

msgid "File does not have an approved extension."
msgstr "Archivo ndorekói peteĩ extensión oñemoneĩva."

#, python-brace-format
msgid "File must be between {min_size} and {max_size} bytes."
msgstr "Archivo oĩva’erã {min_size} ha {max_size} byte apytépe."

#, python-format
msgid "Invalid field name '%s'."
msgstr "Campo réra ndojeporúiva '%s'."

#, python-format
msgid "Field must be equal to %(other_name)s."
msgstr "Campo ojojava’erã %(other_name)s ndive."

#, python-format
msgid "Field must be at least %(min)d character long."
msgstr "Campo ipukuva’erã %(min)d karameg̃ua jepe."

#, python-format
msgid "Field cannot be longer than %(max)d character."
msgstr "Campo ndaikatúi ipukuve karameg̃ua %(max)d-gui."

#, python-format
msgid "Field must be exactly %(max)d character long."
msgstr "Campo ipukuva’erã exactamente %(max)d karameg̃ua."

#, python-format
msgid "Field must be between %(min)d and %(max)d characters long."
msgstr "Campo ipukuva’erã %(min)d ha %(max)d karameg̃ua apytépe."

#, python-format
msgid "Number must be at least %(min)s."
msgstr "Papapy ha’eva’erã %(min)s jepe."

#, python-format
msgid "Number must be at most %(max)s."
msgstr "Papapy ha’eva’erã %(max)s hetave."

#, python-format
msgid "Number must be between %(min)s and %(max)s."
msgstr "Papapy oĩva’erã %(min)s ha %(max)s mbytépe."

msgid "Invalid input."
msgstr "Entrada ndoikóiva."

msgid "Invalid email address."
msgstr "Dirección de correo electrónico ndojeporúiva."

msgid "Invalid IP address."
msgstr "IP tenda ndoikóiva."

msgid "Invalid Mac address."
msgstr "Mac dirección ndojeporúiva."

msgid "Invalid URL."
msgstr "URL ndoikóiva."

msgid "Invalid UUID."
msgstr "UUID ndoikóiva."

#, python-format
msgid "Invalid value, must be one of: %(values)s."
msgstr "Valor ndoikóiva, haꞌevaꞌerã peteĩva: %(values)s."

#, python-format
msgid "Invalid value, can't be any of: %(values)s."
msgstr "Valor ndoikóiva, ndaikatúi ha’e mba’eveichagua: %(values)s."

msgid "This field cannot be edited."
msgstr "Ko tenda ndaikatúi oñemboheko."

msgid "This field is disabled and cannot have a value."
msgstr "Ko tenda oñembogue ha ndaikatúi oguereko peteĩ mba’ekuaarã."

