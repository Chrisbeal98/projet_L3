msgid "path"
msgstr "tapepo'i"

#, python-brace-format
msgid "{name} {filename!r} does not exist."
msgstr "{téra} {vore réra!r} ndoikói."

#, python-brace-format
msgid "{name} {filename!r} is a file."
msgstr "{téra} {vore réra!r} ha’e peteĩ vore."

#, python-brace-format
msgid "{name} {filename!r} is a directory."
msgstr "{téra} {fichero réra!r} ha’e peteĩ kundaha."

#, python-brace-format
msgid "{name} {filename!r} is not readable."
msgstr "{téra} {fichero réra!r} ndaha’éi ojeleekuaáva."

#, python-brace-format
