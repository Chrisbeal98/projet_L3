#, python-brace-format
msgid "{len_type} values are required, but {len_value} was given."
msgstr "{len_type} gildi eru nauðsynleg, en {len_value} var gefið upp."

#, python-brace-format
msgid "Unknown standard stream '{name}'"
msgstr "Óþekktur staðallstraumur '{name}'"

msgid "This field is required."
msgstr "Þessi reitur er nauðsynlegur."

#, python-brace-format
msgid "File does not have an approved extension: {extensions}"
msgstr "Skrá er ekki með samþykkta viðbót: {extensions}"

msgid "File does not have an approved extension."
msgstr "Skrá er ekki með samþykkta viðbót."

#, python-brace-format
msgid "File must be between {min_size} and {max_size} bytes."
msgstr "Skrá verður að vera á milli {min_size} og {max_size} bæta."

#, python-format
msgid "Invalid field name '%s'."
msgstr "Ógilt heiti reits '%s'."

#, python-format
msgid "Field must be equal to %(other_name)s."
msgstr "Reitur verður að vera jöfn %(other_name)s."

#, python-format
msgid "Field must be at least %(min)d character long."
msgstr "Reiturinn verður að vera að minnsta kosti %(mín)d stafa langur."

#, python-format
msgid "Field cannot be longer than %(max)d character."
msgstr "Reitur má ekki vera lengri en %(max)d stafur."

#, python-format
msgid "Field must be exactly %(max)d character long."
msgstr "Reitur verður að vera nákvæmlega %(max)d stafur að lengd."

#, python-format
msgid "Field must be between %(min)d and %(max)d characters long."
msgstr "Reitur verður að vera á milli %(min)d og %(max)d stafir að lengd."

#, python-format
msgid "Number must be at least %(min)s."
msgstr "Fjöldi verður að vera að minnsta kosti %(mín)s."

#, python-format
msgid "Number must be at most %(max)s."
msgstr "Fjöldi verður að vera að hámarki %(max)s."

#, python-format
msgid "Number must be between %(min)s and %(max)s."
msgstr "Fjöldi verður að vera á milli %(min)s og %(max)s."

msgid "Invalid input."
msgstr "Ógilt inntak."

