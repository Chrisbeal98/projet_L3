msgstr "Ógilt IP-tala."

msgid "Invalid Mac address."
msgstr "Ógilt Mac vistfang."

msgid "Invalid URL."
msgstr "Ógild vefslóð."

msgid "Invalid UUID."
msgstr "Ógilt UUID."

#, python-format
msgid "Invalid value, must be one of: %(values)s."
msgstr "Ógilt gildi, verður að vera eitt af: %(values)s."

#, python-format
msgid "Invalid value, can't be any of: %(values)s."
msgstr "Ógilt gildi, getur ekki verið eitthvað af: %(values)s."

msgid "This field cannot be edited."
