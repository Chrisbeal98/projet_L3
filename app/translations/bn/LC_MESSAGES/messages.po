msgid "CSRF failed."
msgstr "CSRF ব্যর্থ হয়েছে।"

msgid "CSRF token expired."
msgstr "CSRF টোকেনের মেয়াদ শেষ হয়ে গেছে।"

msgid "Invalid Choice: could not coerce."
msgstr "অবৈধ পছন্দ: জোর করা যায়নি।"

msgid "Choices cannot be None."
msgstr "পছন্দ কোনটি হতে পারে না।"

msgid "Not a valid choice."
msgstr "একটি বৈধ পছন্দ নয়."

msgid "Invalid choice(s): one or more data inputs could not be coerced."
msgstr "অবৈধ পছন্দ(গুলি): এক বা একাধিক ডেটা ইনপুট জোর করা যাবে না৷"

#, python-format
msgid "'%(value)s' is not a valid choice for this field."
msgstr "'%(value)s' এই ক্ষেত্রের জন্য একটি বৈধ পছন্দ নয়।"

msgid "Not a valid datetime value."
msgstr "একটি বৈধ তারিখ সময় মান নয়।"

msgid "Not a valid date value."
msgstr "একটি বৈধ তারিখ মান নয়।"

msgid "Not a valid time value."
msgstr "একটি বৈধ সময়ের মান নয়।"

msgid "Not a valid week value."
msgstr "একটি বৈধ সপ্তাহ মান নয়।"

msgid "Not a valid integer value."
msgstr "একটি বৈধ পূর্ণসংখ্যা মান নয়।"

msgid "Not a valid decimal value."
msgstr "একটি বৈধ দশমিক মান নয়।"

msgid "Not a valid float value."
msgstr "একটি বৈধ ফ্লোট মান নয়।"

