msgstr "Ang {name} {filename!r} isa ka file."

#, python-brace-format
msgid "{name} {filename!r} is a directory."
msgstr "Ang {name} {filename!r} isa ka direktoryo."

#, python-brace-format
msgid "{name} {filename!r} is not readable."
msgstr "{name} {filename!r} indi mabasa."

#, python-brace-format
msgid "{name} {filename!r} is not writable."
msgstr "{name} {filename!r} indi masulat."

#, python-brace-format
msgid "{name} {filename!r} is not executable."
msgstr "{name} {filename!r} indi ma-execute."

#, python-brace-format
msgid "{len_type} values are required, but {len_value} was given."
msgstr ""
"Ang mga balor sang {len_type} kinahanglanon, apang ang {len_value} "
"ginhatag."

#, python-brace-format
msgid "Unknown standard stream '{name}'"
msgstr "Wala mahibal-an nga sulundan nga sapa '{ngalan}'"

msgid "This field is required."
msgstr "Kinahanglan ini nga patag."

#, python-brace-format
msgid "File does not have an approved extension: {extensions}"
msgstr "Ang file wala sing gin-aprubahan nga extension: {extensions}"

msgid "File does not have an approved extension."
msgstr "Ang file wala sing gin-aprubahan nga extension."

#, python-brace-format
msgid "File must be between {min_size} and {max_size} bytes."
msgstr "Ang file dapat yara sa tunga sang {min_size} kag {max_size} bytes."

#, python-format
msgid "Invalid field name '%s'."
msgstr "Indi balido nga ngalan sang uma nga '%s'."

#, python-format
msgid "Field must be equal to %(other_name)s."
msgstr "Ang field dapat katumbas sa %(other_name)s."

#, python-format
msgid "Field must be at least %(min)d character long."
msgstr "Ang field dapat indi magnubo sa %(min)d nga karakter ang kalabaon."

#, python-format
msgid "Field cannot be longer than %(max)d character."
msgstr "Ang field indi mahimo nga mas malawig sangsa %(max)d nga karakter."

#, python-format
msgid "Field must be exactly %(max)d character long."
msgstr "Ang field dapat eksakto nga %(max)d nga karakter ang kalabaon."

#, python-format
msgid "Field must be between %(min)d and %(max)d characters long."
msgstr ""
"Ang field dapat yara sa tunga sang %(min)d kag %(max)d nga mga karakter "
"ang kalabaon."

#, python-format
msgid "Number must be at least %(min)s."
msgstr "Ang numero dapat indi magnubo sa %(min)s."

#, python-format
msgid "Number must be at most %(max)s."
msgstr "Ang numero dapat indi magdamo sa %(max)s."

#, python-format
msgid "Number must be between %(min)s and %(max)s."
msgstr "Ang numero dapat yara sa tunga sang %(min)s kag %(max)s."

msgid "Invalid input."
msgstr "Indi balido nga input."

msgid "Invalid email address."
msgstr "Indi balido nga email address."

msgid "Invalid IP address."
msgstr "Indi balido nga IP address."

msgid "Invalid Mac address."
msgstr "Indi balido nga adres sang Mac."

msgid "Invalid URL."
msgstr "Indi balido nga URL."

msgid "Invalid UUID."
msgstr "Indi balido nga UUID."

#, python-format
msgid "Invalid value, must be one of: %(values)s."
msgstr "Indi balido nga balor, dapat isa sa: %(values)s."

#, python-format
msgid "Invalid value, can't be any of: %(values)s."
msgstr "Indi balido nga balor, indi mahimo nga bisan diin sa: %(values)s."

msgid "This field cannot be edited."
msgstr "Ini nga field indi ma-edit."

msgid "This field is disabled and cannot have a value."
msgstr "Ini nga field gin-disable kag indi mahimo nga may balor."

msgid "Invalid CSRF Token."
msgstr "Indi balido nga CSRF Token."

msgid "CSRF token missing."
msgstr "Nadula ang token sang CSRF."

msgid "CSRF failed."
msgstr "Napaslawan ang CSRF."

msgid "CSRF token expired."
msgstr "Ang token sang CSRF nag-expire."

msgid "Invalid Choice: could not coerce."
msgstr "Indi balido nga pagpili: indi makapilit."

msgid "Choices cannot be None."
msgstr "Ang mga pagpili indi mahimo nga Wala."

msgid "Not a valid choice."
msgstr "Indi isa ka balido nga pagpili."

msgid "Invalid choice(s): one or more data inputs could not be coerced."
msgstr ""
"Indi balido nga pagpili: isa ukon kapin pa nga mga input sang datos ang "
"indi mapilit."

#, python-format
msgid "'%(value)s' is not a valid choice for this field."
msgstr "Ang '%(value)s' indi isa ka balido nga pagpili para sa sini nga patag."

msgid "Not a valid datetime value."
msgstr "Indi balido nga petsa-oras nga balor."

msgid "Not a valid date value."
msgstr "Indi balido nga bili sang petsa."

msgid "Not a valid time value."
msgstr "Indi balido nga bili sang oras."

msgid "Not a valid week value."
msgstr "Indi balido nga bili sang semana."

msgid "Not a valid integer value."
msgstr "Indi isa ka balido nga integer nga balor."

msgid "Not a valid decimal value."
msgstr "Indi isa ka balido nga desimal nga balor."

msgid "Not a valid float value."
msgstr "Indi balido nga float value."

