msgid "{name} {filename!r} is not writable."
msgstr "{name} {filename!r} dili masulat."

#, python-brace-format
msgid "{name} {filename!r} is not executable."
msgstr "{name} {filename!r} dili ma-executable."

#, python-brace-format
msgid "{len_type} values are required, but {len_value} was given."
msgstr "{len_type} mga bili gikinahanglan, apan {len_value} gihatag."

#, python-brace-format
msgid "Unknown standard stream '{name}'"
msgstr "Wala mailhi nga standard stream '{name}'"

msgid "This field is required."
msgstr "Kini nga field gikinahanglan."

#, python-brace-format
msgid "File does not have an approved extension: {extensions}"
msgstr "Ang file walay giaprobahan nga extension: {extensions}"

msgid "File does not have an approved extension."
msgstr "Ang file walay giaprobahan nga extension."

#, python-brace-format
msgid "File must be between {min_size} and {max_size} bytes."
msgstr "Ang file kinahanglang tali sa {min_size} ug {max_size} bytes."

#, python-format
msgid "Invalid field name '%s'."
msgstr "Dili balido nga ngalan sa field '%s'."

#, python-format
msgid "Field must be equal to %(other_name)s."
msgstr "Ang field kinahanglang katumbas sa %(other_name)s."

#, python-format
msgid "Field must be at least %(min)d character long."
msgstr "Ang field kinahanglang labing menos %(min)d nga karakter ang gitas-on."

#, python-format
msgid "Field cannot be longer than %(max)d character."
msgstr "Ang field dili molapas sa %(max)d nga karakter."

#, python-format
msgid "Field must be exactly %(max)d character long."
msgstr "Ang field kinahanglang eksaktong %(max)d nga karakter ang gitas-on."

#, python-format
msgid "Field must be between %(min)d and %(max)d characters long."
msgstr ""
"Ang field kinahanglang tali sa %(min)d ug %(max)d nga mga karakter ang "
"gitas-on."

#, python-format
msgid "Number must be at least %(min)s."
msgstr "Ang gidaghanon kinahanglang labing menos %(min)s."

#, python-format
msgid "Number must be at most %(max)s."
msgstr "Ang gidaghanon kinahanglang labing daghan sa %(max)s."

#, python-format
msgid "Number must be between %(min)s and %(max)s."
msgstr "Ang gidaghanon kinahanglang tali sa %(min)s ug %(max)s."

msgid "Invalid input."
msgstr "Dili balido nga input."

msgid "Invalid email address."
msgstr "Dili balido nga email address."

msgid "Invalid IP address."
msgstr "Dili balido nga IP adres."

msgid "Invalid Mac address."
msgstr "Dili balido nga adres sa Mac."

msgid "Invalid URL."
msgstr "Dili balido nga URL."

msgid "Invalid UUID."
msgstr "Dili balido nga UUID."

#, python-format
msgid "Invalid value, must be one of: %(values)s."
msgstr "Dili balido nga bili, kinahanglang usa sa: %(values)s."

#, python-format
msgid "Invalid value, can't be any of: %(values)s."
msgstr "Dili balido nga bili, dili mahimong bisan unsa sa: %(values)s."

msgid "This field cannot be edited."
msgstr "Kini nga field dili ma-edit."

msgid "This field is disabled and cannot have a value."
msgstr "Kini nga natad gibabagan ug dili adunay bili."

msgid "Invalid CSRF Token."
msgstr "Dili balido nga CSRF Token."

msgid "CSRF token missing."
msgstr "Nawala ang token sa CSRF."

msgid "CSRF failed."
msgstr "Napakyas ang CSRF."

msgid "CSRF token expired."
msgstr "Ang CSRF token nag-expire."

msgid "Invalid Choice: could not coerce."
msgstr "Dili balido nga Pagpili: dili makapugos."

msgid "Choices cannot be None."
msgstr "Ang mga pagpili dili mahimong Wala."

msgid "Not a valid choice."
msgstr "Dili balido nga pagpili."

msgid "Invalid choice(s): one or more data inputs could not be coerced."
msgstr ""
"Dili balido nga (mga) pagpili: usa o daghang mga input sa data dili "
"mapugos."

#, python-format
msgid "'%(value)s' is not a valid choice for this field."
msgstr "Ang '%(value)s' dili balido nga pagpili alang niini nga field."

msgid "Not a valid datetime value."
msgstr "Dili balido nga datetime value."

msgid "Not a valid date value."
msgstr "Dili balido nga kantidad sa petsa."

msgid "Not a valid time value."
msgstr "Dili balido nga kantidad sa oras."

msgid "Not a valid week value."
msgstr "Dili balido nga kantidad sa semana."

msgid "Not a valid integer value."
msgstr "Dili balido nga integer nga kantidad."

msgid "Not a valid decimal value."
msgstr "Dili balido nga desimal nga bili."

msgid "Not a valid float value."
msgstr "Dili balido nga float value."

