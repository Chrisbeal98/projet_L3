msgid "Invalid field name '%s'."
msgstr "Ongeldige veldnaam '%s'."

#, python-format
msgid "Field must be equal to %(other_name)s."
msgstr "Veld moet gelijk zijn aan %(other_name)s."

#, python-format
msgid "Field must be at least %(min)d character long."
msgstr "Het veld moet minimaal %(min)d tekens lang zijn."

#, python-format
msgid "Field cannot be longer than %(max)d character."
msgstr "Veld mag niet langer zijn dan %(max)d teken."

#, python-format
msgid "Field must be exactly %(max)d character long."
msgstr "Het veld moet precies %(max)d tekens lang zijn."

#, python-format
msgid "Field must be between %(min)d and %(max)d characters long."
msgstr "Het veld moet tussen %(min)d en %(max)d tekens lang zijn."

#, python-format
msgid "Number must be at least %(min)s."
msgstr "Het getal moet minimaal %(min)s zijn."

#, python-format
msgid "Number must be at most %(max)s."
msgstr "Het getal mag maximaal %(max)s zijn."

#, python-format
msgid "Number must be between %(min)s and %(max)s."
msgstr "Het getal moet tussen %(min)s en %(max)s liggen."

msgid "Invalid input."
msgstr "Ongeldige invoer."

msgid "Invalid email address."
msgstr "Ongeldig e-mailadres."

msgid "Invalid IP address."
msgstr "Ongeldig IP-adres."

msgid "Invalid Mac address."
msgstr "Ongeldig Mac-adres."

msgid "Invalid URL."
msgstr "Ongeldige URL."

msgid "Invalid UUID."
msgstr "Ongeldige UUID."

#, python-format
msgid "Invalid value, must be one of: %(values)s."
msgstr "Ongeldige waarde, moet een van de volgende zijn: %(values)s."

#, python-format
msgid "Invalid value, can't be any of: %(values)s."
msgstr "Ongeldige waarde, kan geen van de volgende zijn: %(values)s."

msgid "This field cannot be edited."
msgstr "Dit veld kan niet worden bewerkt."

msgid "This field is disabled and cannot have a value."
msgstr "Dit veld is uitgeschakeld en kan geen waarde bevatten."

msgid "Invalid CSRF Token."
msgstr "Ongeldig CSRF-token."

msgid "CSRF token missing."
msgstr "CSRF-token ontbreekt."

msgid "CSRF failed."
msgstr "CSRF is mislukt."

msgid "CSRF token expired."
msgstr "CSRF-token is verlopen."

msgid "Invalid Choice: could not coerce."
msgstr "Ongeldige keuze: kon niet afdwingen."

msgid "Choices cannot be None."
msgstr "Keuzes kunnen niet Geen zijn."

msgid "Not a valid choice."
msgstr "Geen geldige keuze."

msgid "Invalid choice(s): one or more data inputs could not be coerced."
msgstr ""
"Ongeldige keuze(s): een of meer gegevensinvoer kon niet worden "
"afgedwongen."

#, python-format
msgid "'%(value)s' is not a valid choice for this field."
msgstr "'%(value)s' is geen geldige keuze voor dit veld."

msgid "Not a valid datetime value."
msgstr "Geen geldige datetime-waarde."

msgid "Not a valid date value."
msgstr "Geen geldige datumwaarde."

msgid "Not a valid time value."
msgstr "Geen geldige tijdswaarde."

msgid "Not a valid week value."
msgstr "Geen geldige weekwaarde."

msgid "Not a valid integer value."
msgstr "Geen geldig geheel getal."

msgid "Not a valid decimal value."
msgstr "Geen geldige decimale waarde."

msgid "Not a valid float value."
msgstr "Geen geldige float-waarde."

