msgstr "Field mateŋu didi wu %(max)d ŋɔŋlɔdzesi o."

#, python-format
msgid "Field must be exactly %(max)d character long."
msgstr "Ele be agblea nanye %(max)d ŋɔŋlɔdzesi ƒe didime pɛpɛpɛ."

#, python-format
msgid "Field must be between %(min)d and %(max)d characters long."
