#, python-brace-format
msgid "File must be between {min_size} and {max_size} bytes."
msgstr "Ele be faɛl nanɔ {min_size} kple {max_size} bytes dome."

#, python-format
msgid "Invalid field name '%s'."
msgstr "Agble ƒe ŋkɔ si mesɔ o '%s'."

#, python-format
msgid "Field must be equal to %(other_name)s."
msgstr "Ele be agblea nasɔ kple %(other_name)s."

#, python-format
