msgstr "E archivo mester ta entre {min_size} i {max_size} bytes."

#, python-format
msgid "Invalid field name '%s'."
msgstr "Nòmber di kampo '%s' no bálido."

#, python-format
msgid "Field must be equal to %(other_name)s."
msgstr "E kampo mester ta igual na %(other_name)s."

#, python-format
msgid "Field must be at least %(min)d character long."
msgstr "E kampo mester ta por lo ménos %(min)d karakter largu."

#, python-format
msgid "Field cannot be longer than %(max)d character."
msgstr "E kampo no por ta mas largu ku %(max)d karakter."

#, python-format
msgid "Field must be exactly %(max)d character long."
msgstr "E kampo mester ta eksaktamente %(max)d karakter largu."

#, python-format
msgid "Field must be between %(min)d and %(max)d characters long."
msgstr "E kampo mester ta entre %(min)d i %(max)d karakter largu."

#, python-format
msgid "Number must be at least %(min)s."
msgstr "E kantidat mester ta por lo ménos %(min)s."

#, python-format
msgid "Number must be at most %(max)s."
msgstr "E kantidat mester ta máksimo %(max)s."

#, python-format
msgid "Number must be between %(min)s and %(max)s."
msgstr "E kantidat mester ta entre %(min)s i %(max)s."

msgid "Invalid input."
msgstr "Entrada no bálido."

msgid "Invalid email address."
msgstr "Adrès di email no bálido."

msgid "Invalid IP address."
msgstr "Adres IP no bálido."

msgid "Invalid Mac address."
msgstr "Adrès di Mac no bálido."

msgid "Invalid URL."
msgstr "URL no bálido."

msgid "Invalid UUID."
msgstr "UUID no bálido."

#, python-format
msgid "Invalid value, must be one of: %(values)s."
msgstr "Balor inválido, mester ta un di: %(balornan)s."

#, python-format
msgid "Invalid value, can't be any of: %(values)s."
msgstr "Balor inválido, no por ta ningun di: %(balornan)s."

msgid "This field cannot be edited."
msgstr "E kampo aki no por wòrdu editá."

msgid "This field is disabled and cannot have a value."
msgstr "E kampo aki ta desabilitá i no por tin un balor."

msgid "Invalid CSRF Token."
msgstr "Token di CSRF no bálido."

msgid "CSRF token missing."
msgstr "Token di CSRF ta falta."

msgid "CSRF failed."
msgstr "CSRF a frakasá."

msgid "CSRF token expired."
msgstr "E token di CSRF a kaduká."

msgid "Invalid Choice: could not coerce."
msgstr "Eskoho Inválido: no por a koerse."

msgid "Choices cannot be None."
msgstr "Eskohonan no por ta Ningun."

msgid "Not a valid choice."
msgstr "No ta un eskoho bálido."

msgid "Invalid choice(s): one or more data inputs could not be coerced."
msgstr "Eskoho(nan) inválido: un òf mas entrada di dato no por a wòrdu forsá."

#, python-format
msgid "'%(value)s' is not a valid choice for this field."
msgstr "'%(value)s' no ta un eskoho bálido pa e kampo aki."

msgid "Not a valid datetime value."
msgstr "No ta un balor di fecha ora bálido."

msgid "Not a valid date value."
msgstr "No ta un balor di fecha bálido."

msgid "Not a valid time value."
msgstr "No ta un balor di tempu bálido."

msgid "Not a valid week value."
msgstr "No ta un balor di siman bálido."

msgid "Not a valid integer value."
msgstr "No ta un balor di number kompletu bálido."

msgid "Not a valid decimal value."
msgstr "No ta un balor desimal bálido."

msgid "Not a valid float value."
msgstr "No ta un balor di flotashon bálido."

