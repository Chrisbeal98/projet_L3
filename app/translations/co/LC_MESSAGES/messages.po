msgstr "U schedariu ùn hà micca una estensione appruvata."

#, python-brace-format
msgid "File must be between {min_size} and {max_size} bytes."
msgstr "U schedariu deve esse trà {min_size} è {max_size} bytes."

#, python-format
msgid "Invalid field name '%s'."
msgstr "Nome di campu invalidu '%s'."

#, python-format
msgid "Field must be equal to %(other_name)s."
msgstr "U campu deve esse uguale à %(other_name)s."

#, python-format
msgid "Field must be at least %(min)d character long."
msgstr "U campu deve esse almenu %(min)d caratteri."

#, python-format
msgid "Field cannot be longer than %(max)d character."
msgstr "U campu ùn pò esse più longu di %(max)d caratteru."

#, python-format
msgid "Field must be exactly %(max)d character long."
msgstr "U campu deve esse esattamente %(max)d caratteri longu."

#, python-format
msgid "Field must be between %(min)d and %(max)d characters long."
msgstr "U campu deve esse longu trà %(min)d è %(max)d caratteri."

#, python-format
msgid "Number must be at least %(min)s."
msgstr "U numeru deve esse almenu %(min)s."

#, python-format
msgid "Number must be at most %(max)s."
msgstr "U numeru deve esse u massimu di %(max)s."

#, python-format
msgid "Number must be between %(min)s and %(max)s."
msgstr "U numeru deve esse trà %(min)s è %(max)s."

msgid "Invalid input."
msgstr "Input invalidu."

msgid "Invalid email address."
msgstr "Indirizzu email invalidu."

msgid "Invalid IP address."
msgstr "Indirizzu IP invalidu."

msgid "Invalid Mac address."
msgstr "Indirizzu Mac invalidu."

msgid "Invalid URL."
msgstr "URL invalidu."

msgid "Invalid UUID."
msgstr "UUID invalidu."

#, python-format
msgid "Invalid value, must be one of: %(values)s."
msgstr "Valore invalidu, deve esse unu di: %(values)s."

#, python-format
msgid "Invalid value, can't be any of: %(values)s."
msgstr "Valore invalidu, ùn pò esse unu di: %(values)s."

msgid "This field cannot be edited."
msgstr "Stu campu ùn pò esse editatu."

msgid "This field is disabled and cannot have a value."
msgstr "Stu campu hè disattivatu è ùn pò micca avè un valore."

msgid "Invalid CSRF Token."
msgstr "Token CSRF invalidu."

msgid "CSRF token missing."
msgstr "Token CSRF mancante."

msgid "CSRF failed."
msgstr "CSRF hà fiascatu."

msgid "CSRF token expired."
msgstr "U token CSRF hè scadutu."

msgid "Invalid Choice: could not coerce."
msgstr "Scelta invalida: ùn pudia micca coerce."

msgid "Choices cannot be None."
msgstr "E scelte ùn ponu esse Nimu."

msgid "Not a valid choice."
msgstr "Ùn hè micca una scelta valida."

msgid "Invalid choice(s): one or more data inputs could not be coerced."
msgstr ""
"Scelta (s) invalida (s): unu o più inputs di dati ùn anu pussutu esse "
"forzatu."

#, python-format
msgid "'%(value)s' is not a valid choice for this field."
msgstr "'%(value)s' ùn hè micca una scelta valida per stu campu."

msgid "Not a valid datetime value."
msgstr "Ùn hè micca un valore di data-time validu."

msgid "Not a valid date value."
msgstr "Ùn hè micca un valore di data validu."

msgid "Not a valid time value."
msgstr "Ùn hè micca un valore di tempu validu."

msgid "Not a valid week value."
msgstr "Ùn hè micca un valore validu di settimana."

msgid "Not a valid integer value."
msgstr "Ùn hè micca un valore interu validu."

msgid "Not a valid decimal value."
msgstr "Ùn hè micca un valore decimale validu."

msgid "Not a valid float value."
msgstr "Ùn hè micca un valore float validu."

