msgstr "Ing field dapat atin yang at least %(min)d character kaba."

#, python-format
msgid "Field cannot be longer than %(max)d character."
msgstr "E ya malyaring mas makaba ing field kesa keng %(max)d character."

#, python-format
msgid "Field must be exactly %(max)d character long."
msgstr "Ing field dapat eksaktung %(max)d character kaba."

#, python-format
msgid "Field must be between %(min)d and %(max)d characters long."
msgstr "Ing field dapat atin yang pilatan ning %(min)d ampo %(max)d a letra kaba."

#, python-format
msgid "Number must be at least %(min)s."
msgstr "Ing bilang dapat at least %(min)s."

#, python-format
msgid "Number must be at most %(max)s."
msgstr "Ing bilang dapat e ya migit keng %(max)s."

#, python-format
msgid "Number must be between %(min)s and %(max)s."
msgstr "Ing bilang dapat atyu ya pilatan ning %(min)s ampo %(max)s."

msgid "Invalid input."
msgstr "E ustu ing input."

msgid "Invalid email address."
msgstr "E ustu ing email address."

msgid "Invalid IP address."
msgstr "E ustu ing IP address."

msgid "Invalid Mac address."
msgstr "E ustu ing Mac address."

msgid "Invalid URL."
msgstr "E ustu ing URL."

msgid "Invalid UUID."
msgstr "E valid ing UUID."

#, python-format
msgid "Invalid value, must be one of: %(values)s."
msgstr "E ustu ing ulaga, dapat metung ya kareng: %(values)s."

#, python-format
msgid "Invalid value, can't be any of: %(values)s."
msgstr "E ustu ing ulaga, e malyaring metung kareng: %(values)s."

msgid "This field cannot be edited."
msgstr "E maliaring i-edit ing field a ini."

msgid "This field is disabled and cannot have a value."
msgstr "E ya maka-disable ining field at ala yang ulaga."

msgid "Invalid CSRF Token."
msgstr "E valid ing CSRF Token."

msgid "CSRF token missing."
msgstr "CSRF token kulang."

msgid "CSRF failed."
msgstr "mebigu ya ing CSRF."

msgid "CSRF token expired."
msgstr "CSRF token me expire ya."

msgid "Invalid Choice: could not coerce."
msgstr "E ustu ing pinili: e malyaring pilitan."

msgid "Choices cannot be None."
msgstr "Deng pilinan e malyaring ala."

msgid "Not a valid choice."
msgstr "ali ya valid a pilinan."

msgid "Invalid choice(s): one or more data inputs could not be coerced."
msgstr "E ustung pilinan: metung o maigit pang data inputs e malyaring pilitan."

#, python-format
msgid "'%(value)s' is not a valid choice for this field."
msgstr "'%(value)s' e ya valid a pilinan para kening field.'"

msgid "Not a valid datetime value."
msgstr "E ya valid ing datetime value."

msgid "Not a valid date value."
msgstr "E ya valid ing ulaga ning petsa."

msgid "Not a valid time value."
msgstr "E ya valid ing oras."

msgid "Not a valid week value."
msgstr "E ya valid ing week value."

msgid "Not a valid integer value."
msgstr "E ya valid ing integer value."

msgid "Not a valid decimal value."
msgstr "E ya valid a decimal value."

