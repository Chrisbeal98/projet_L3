msgstr "El file g’ha de vèss intra {dimensiun_min} e {dimensiun_max} byte."

#, python-format
msgid "Invalid field name '%s'."
msgstr "Nom del camp minga valid '%s'."

#, python-format
msgid "Field must be equal to %(other_name)s."
msgstr "El camp g’ha de vèss istess a %(olter_nom)s."

#, python-format
msgid "Field must be at least %(min)d character long."
msgstr "El camp g’ha de vèss luungh almen %(min)d de carater."

#, python-format
msgid "Field cannot be longer than %(max)d character."
msgstr "El camp pœu no vèss püsee luungh de %(max)d carater."

#, python-format
msgid "Field must be exactly %(max)d character long."
msgstr "El camp g’ha de vèss luungh esatament %(max)d de carater."

#, python-format
msgid "Field must be between %(min)d and %(max)d characters long."
msgstr "El camp g’ha de vèss luungh intra %(min)d e %(max)d carater."

#, python-format
msgid "Number must be at least %(min)s."
msgstr "El numer g’ha de vèss almen %(min)s."

#, python-format
msgid "Number must be at most %(max)s."
msgstr "El numer g’ha de vèss al massim %(max)s."

#, python-format
msgid "Number must be between %(min)s and %(max)s."
msgstr "El numer g’ha de vèss intra %(min) e %(max)."

msgid "Invalid input."
msgstr "Input minga valid."

msgid "Invalid email address."
msgstr "Indiriz e-mail minga valid."

msgid "Invalid IP address."
msgstr "Indiriz IP minga valid."

msgid "Invalid Mac address."
msgstr "Indiriz Mac minga valid."

msgid "Invalid URL."
msgstr "URL minga valid."

msgid "Invalid UUID."
msgstr "UUID minga valid."

#, python-format
msgid "Invalid value, must be one of: %(values)s."
msgstr "Valur minga valid, g’ha de vèss un di: %(valur)."

#, python-format
msgid "Invalid value, can't be any of: %(values)s."
msgstr "Valur minga valid, pœu no vèss nissun di: %(valur)."

msgid "This field cannot be edited."
msgstr "Chestu camp pœu no vèss mudificà."

msgid "This field is disabled and cannot have a value."
msgstr "Chestu camp l’è disabilità e pœu no avegh un valur."

msgid "Invalid CSRF Token."
msgstr "Geton CSRF minga valid."

msgid "CSRF token missing."
msgstr "Manca el geton CSRF."

msgid "CSRF failed."
msgstr "CSRF l’è fallì."

msgid "CSRF token expired."
msgstr "El geton CSRF l’è scadù."

msgid "Invalid Choice: could not coerce."
msgstr "Scelta minga valida: pudeva minga coercir."

msgid "Choices cannot be None."
msgstr "I scernid pœden no vèss Nissun."

msgid "Not a valid choice."
msgstr "Minga una scelta valida."

msgid "Invalid choice(s): one or more data inputs could not be coerced."
msgstr "Scelta(i) minga valida: vun o püsee input de dati pœden no vèss costrett."

#, python-format
msgid "'%(value)s' is not a valid choice for this field."
msgstr "“%(valur)s” l’è minga una scernida valida per chestu camp."

msgid "Not a valid datetime value."
msgstr "Minga un valur data-ora valid."

msgid "Not a valid date value."
msgstr "Minga un valur de data valid."

msgid "Not a valid time value."
msgstr "Minga un valur de temp valid."

msgid "Not a valid week value."
msgstr "Minga un valur settimanal valid."

msgid "Not a valid integer value."
msgstr "Minga un valur inter valid."

msgid "Not a valid decimal value."
msgstr "Minga un valur decimal valid."

msgid "Not a valid float value."
msgstr "Minga un valur float valid."

