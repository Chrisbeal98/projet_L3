msgstr "{name} {filename!r} ndi fayilo."

#, python-brace-format
msgid "{name} {filename!r} is a directory."
msgstr "{name} {filename!r} ndi chikwatu."

#, python-brace-format
msgid "{name} {filename!r} is not readable."
msgstr "{name} {filename!r} sichiwerengeka."

#, python-brace-format
msgid "{name} {filename!r} is not writable."
msgstr "{name} {filename!r} sililembedwa."

#, python-brace-format
msgid "{name} {filename!r} is not executable."
msgstr "{name} {filename!r} sichitha."

#, python-brace-format
msgid "{len_type} values are required, but {len_value} was given."
msgstr "{len_type} miyeso ndiyofunikira, koma {len_value} idaperekedwa."

#, python-brace-format
msgid "Unknown standard stream '{name}'"
msgstr "Mtsinje wokhazikika wosadziwika '{name}'"

msgid "This field is required."
msgstr "Pofunika kulembapo."

#, python-brace-format
msgid "File does not have an approved extension: {extensions}"
msgstr "Fayilo ilibe zowonjezera zovomerezeka: {extensions}"

msgid "File does not have an approved extension."
msgstr "Fayilo ilibe chowonjezera chovomerezeka."

#, python-brace-format
msgid "File must be between {min_size} and {max_size} bytes."
msgstr "Fayilo iyenera kukhala pakati pa {min_size} ndi {max_size} mabayiti."

#, python-format
msgid "Invalid field name '%s'."
msgstr "Dzina lagawo lolakwika '%s'."

#, python-format
msgid "Field must be equal to %(other_name)s."
msgstr "Munda uyenera kukhala wofanana ndi %(other_name)s."

#, python-format
msgid "Field must be at least %(min)d character long."
msgstr "Malo akuyenera kukhala osachepera %(min)d kutalika."

#, python-format
msgid "Field cannot be longer than %(max)d character."
msgstr "Munda sungathe kupitirira zilembo %(max)d."

#, python-format
msgid "Field must be exactly %(max)d character long."
msgstr "Munda uyenera kukhala ndendende %(max)d zilembo."

#, python-format
msgid "Field must be between %(min)d and %(max)d characters long."
msgstr "Munda uyenera kukhala pakati pa %(min)d ndi %(max)d zilembo zazitali."

#, python-format
msgid "Number must be at least %(min)s."
msgstr "Nambala iyenera kukhala yosachepera %(min)s."

#, python-format
msgid "Number must be at most %(max)s."
msgstr "Nambala iyenera kukhala yosachepera %(max)s."

#, python-format
msgid "Number must be between %(min)s and %(max)s."
msgstr "Nambala iyenera kukhala pakati pa %(min)s ndi %(max)s."

msgid "Invalid input."
msgstr "Zolemba zosalondola."

msgid "Invalid email address."
msgstr "Adilesi ya imelo yolakwika."

msgid "Invalid IP address."
msgstr "IP adilesi yolakwika."

msgid "Invalid Mac address."
msgstr "Mac adilesi yolakwika."

msgid "Invalid URL."
msgstr "URL yolakwika."

msgid "Invalid UUID."
msgstr "UUID yolakwika."

#, python-format
msgid "Invalid value, must be one of: %(values)s."
msgstr "Mtengo wosalondola, uyenera kukhala umodzi mwa: %(values)s."

#, python-format
msgid "Invalid value, can't be any of: %(values)s."
msgstr "Mtengo wolakwika, sungakhale uliwonse mwa: %(values)s."

msgid "This field cannot be edited."
msgstr "Gawoli silingasinthidwe."

msgid "This field is disabled and cannot have a value."
msgstr "Gawo ili ndi loyimitsidwa ndipo silingakhale ndi mtengo."

msgid "Invalid CSRF Token."
msgstr "Chizindikiro cha CSRF chosalondola."

msgid "CSRF token missing."
msgstr "Chizindikiro cha CSRF chikusowa."

msgid "CSRF failed."
msgstr "CSRF yalephera."

msgid "CSRF token expired."
msgstr "Chizindikiro cha CSRF chatha."

msgid "Invalid Choice: could not coerce."
msgstr "Kusankha Kolakwika: sikunathe kukakamiza."

msgid "Choices cannot be None."
msgstr "Zosankha sizingakhale Palibe."

msgid "Not a valid choice."
msgstr "Osati kusankha koyenera."

msgid "Invalid choice(s): one or more data inputs could not be coerced."
msgstr "Zosankha zosalondola: data imodzi kapena zingapo sizinakakamizidwe."

#, python-format
msgid "'%(value)s' is not a valid choice for this field."
msgstr "'%(value)s' si chisankho choyenera pagawoli."

msgid "Not a valid datetime value."
msgstr "Osati mtengo wovomerezeka watsiku."

msgid "Not a valid date value."
msgstr "Osati mtengo wovomerezeka."

msgid "Not a valid time value."
msgstr "Si nthawi yovomerezeka."

msgid "Not a valid week value."
msgstr "Osati mtengo wovomerezeka wa sabata."

msgid "Not a valid integer value."
msgstr "Sichiwerengero choyenera."

msgid "Not a valid decimal value."
msgstr "Sichiwerengero chovomerezeka."

msgid "Not a valid float value."
msgstr "Osati mtengo woyandama."

