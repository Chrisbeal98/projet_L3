#, python-brace-format
msgid "{name} {filename!r} is not executable."
msgstr "{name} {filename!r} ei ole suoritettava."

#, python-brace-format
msgid "{len_type} values are required, but {len_value} was given."
msgstr "{len_type}-arvot vaaditaan, mutta {len_value} annettiin."

#, python-brace-format
msgid "Unknown standard stream '{name}'"
msgstr "Tuntematon vakiovirta '{name}'"

msgid "This field is required."
msgstr "Tämä kenttä on pakollinen."

#, python-brace-format
msgid "File does not have an approved extension: {extensions}"
msgstr "Tiedostolla ei ole hyväksyttyä laajennusta: {extensions}"

msgid "File does not have an approved extension."
msgstr "Tiedostolla ei ole hyväksyttyä tunnistetta."

#, python-brace-format
msgid "File must be between {min_size} and {max_size} bytes."
msgstr "Tiedoston on oltava {min_size}–{max_size} tavua."

#, python-format
msgid "Invalid field name '%s'."
msgstr "Virheellinen kentän nimi '%s'."

#, python-format
msgid "Field must be equal to %(other_name)s."
msgstr "Kentän on oltava yhtä suuri kuin %(other_name)s."

#, python-format
msgid "Field must be at least %(min)d character long."
msgstr "Kentän on oltava vähintään %(min)d merkkiä pitkä."

#, python-format
msgid "Field cannot be longer than %(max)d character."
msgstr "Kenttä ei voi olla pidempi kuin %(max)d merkkiä."

#, python-format
msgid "Field must be exactly %(max)d character long."
msgstr "Kentän on oltava täsmälleen %(max)d merkkiä pitkä."

#, python-format
msgid "Field must be between %(min)d and %(max)d characters long."
msgstr "Kentän on oltava %(min)d–%(max)d merkkiä pitkä."

#, python-format
msgid "Number must be at least %(min)s."
msgstr "Numeron on oltava vähintään %(min)s."

#, python-format
msgid "Number must be at most %(max)s."
msgstr "Luku saa olla enintään %(max)s."

#, python-format
msgid "Number must be between %(min)s and %(max)s."
msgstr "Numeron on oltava välillä %(min)s ja %(max)s."

msgid "Invalid input."
msgstr "Virheellinen syöte."

msgid "Invalid email address."
msgstr "Virheellinen sähköpostiosoite."

msgid "Invalid IP address."
msgstr "Virheellinen IP-osoite."

msgid "Invalid Mac address."
msgstr "Virheellinen Mac-osoite."

msgid "Invalid URL."
msgstr "Virheellinen URL-osoite."

msgid "Invalid UUID."
msgstr "Virheellinen UUID."

#, python-format
msgid "Invalid value, must be one of: %(values)s."
msgstr "Virheellinen arvo, on oltava jokin seuraavista: %(values)s."

#, python-format
msgid "Invalid value, can't be any of: %(values)s."
msgstr "Virheellinen arvo, ei voi olla mikään seuraavista: %(values)s."

msgid "This field cannot be edited."
msgstr "Tätä kenttää ei voi muokata."

msgid "This field is disabled and cannot have a value."
msgstr "Tämä kenttä on poistettu käytöstä, eikä sillä voi olla arvoa."

msgid "Invalid CSRF Token."
msgstr "Virheellinen CSRF-tunnus."

msgid "CSRF token missing."
msgstr "CSRF-tunnus puuttuu."

msgid "CSRF failed."
msgstr "CSRF epäonnistui."

msgid "CSRF token expired."
msgstr "CSRF-tunnus vanhentunut."

msgid "Invalid Choice: could not coerce."
msgstr "Virheellinen valinta: ei voitu pakottaa."

msgid "Choices cannot be None."
msgstr "Valinnat eivät voi olla Ei mitään."

msgid "Not a valid choice."
msgstr "Ei kelvollinen valinta."

msgid "Invalid choice(s): one or more data inputs could not be coerced."
msgstr "Virheelliset valinnat: yhtä tai useampaa datasyöttöä ei voitu pakottaa."

#, python-format
msgid "'%(value)s' is not a valid choice for this field."
msgstr "'%(value)s' ei ole kelvollinen valinta tähän kenttään."

msgid "Not a valid datetime value."
msgstr "Ei kelvollinen päivämäärä-aika-arvo."

msgid "Not a valid date value."
msgstr "Ei kelvollinen päivämääräarvo."

msgid "Not a valid time value."
msgstr "Ei kelvollinen aika-arvo."

msgid "Not a valid week value."
msgstr "Ei kelvollinen viikon arvo."

msgid "Not a valid integer value."
msgstr "Ei kelvollinen kokonaislukuarvo."

msgid "Not a valid decimal value."
msgstr "Ei kelvollinen desimaaliarvo."

msgid "Not a valid float value."
msgstr "Ei kelvollinen kelluva arvo."

