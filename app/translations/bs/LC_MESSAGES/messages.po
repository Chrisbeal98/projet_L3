msgid "{len_type} values are required, but {len_value} was given."
msgstr "Vrijednosti {len_type} su obavezne, ali je data {len_value}."

#, python-brace-format
msgid "Unknown standard stream '{name}'"
msgstr "Nepoznati standardni prijenos '{name}'"

msgid "This field is required."
msgstr "Ovo polje je obavezno."

#, python-brace-format
msgid "File does not have an approved extension: {extensions}"
msgstr "Fajl nema odobrenu ekstenziju: {extensions}"

msgid "File does not have an approved extension."
msgstr "Fajl nema odobrenu ekstenziju."

#, python-brace-format
msgid "File must be between {min_size} and {max_size} bytes."
msgstr "Fajl mora biti između {min_size} i {max_size} bajtova."

#, python-format
msgid "Invalid field name '%s'."
