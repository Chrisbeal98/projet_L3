msgstr "{nomu} {nomu dû file!r} nun è liggìbbili."

#, python-brace-format
msgid "{name} {filename!r} is not writable."
msgstr "{nomu} {nomu dû file!r} nun è scrivìbbili."

#, python-brace-format
msgid "{name} {filename!r} is not executable."
msgstr "{nomu} {nomu dû file!r} nun è esiguibbili."

#, python-brace-format
msgid "{len_type} values are required, but {len_value} was given."
msgstr "su' nicissari li valura di {tipu_len}, ma fu datu {valuri_len}."

#, python-brace-format
msgid "Unknown standard stream '{name}'"
msgstr "Flussu standard scanusciutu '{nomu}'"

msgid "This field is required."
msgstr "Chistu campu è nicissariu."

#, python-brace-format
msgid "File does not have an approved extension: {extensions}"
msgstr "Lu file nun havi n'estenzioni appruvata: {extensions}"

msgid "File does not have an approved extension."
msgstr "Lu file nun àvi n'estensioni appruvata."

#, python-brace-format
msgid "File must be between {min_size} and {max_size} bytes."
msgstr "Lu file àvi a èssiri ntra {grannizza_min} e {grannizza_massima} byte."

#, python-format
msgid "Invalid field name '%s'."
msgstr "Nomu dû campu nun validu '%s'."

#, python-format
msgid "Field must be equal to %(other_name)s."
msgstr "Lu campu àvi a èssiri avali a %(autru_nomu)s."

#, python-format
msgid "Field must be at least %(min)d character long."
msgstr "Lu campu àvi a èssiri longu armenu %(min)d carattari."

#, python-format
msgid "Field cannot be longer than %(max)d character."
msgstr "Lu campu nun po èssiri cchiù longu dû caràttari %(max)d."

#, python-format
msgid "Field must be exactly %(max)d character long."
msgstr "Lu campu àvi a èssiri longu esattamenti %(max)d carattari."

#, python-format
msgid "Field must be between %(min)d and %(max)d characters long."
msgstr "Lu campu àvi a èssiri longu ntra %(min)d e %(max)d carattari."

#, python-format
msgid "Number must be at least %(min)s."
msgstr "U nùmmaru àvi a èssiri armenu %(min)s."

#, python-format
msgid "Number must be at most %(max)s."
msgstr "U nùmmaru àvi a èssiri ô massimu %(max)s."

#, python-format
msgid "Number must be between %(min)s and %(max)s."
msgstr "U nùmmaru àvi a èssiri ntra %(min)s e %(max)s."

msgid "Invalid input."
msgstr "Input nun validu."

msgid "Invalid email address."
msgstr "Indirizzu e-mail nun validu."

msgid "Invalid IP address."
msgstr "Indirizzu IP nun validu."

msgid "Invalid Mac address."
msgstr "Indirizzu Mac nun validu."

msgid "Invalid URL."
msgstr "URL nun validu."

msgid "Invalid UUID."
msgstr "UUID nun validu."

#, python-format
msgid "Invalid value, must be one of: %(values)s."
msgstr "Valuri nun validu, àvi a èssiri unu di: %(valura)."

#, python-format
msgid "Invalid value, can't be any of: %(values)s."
msgstr "Valuri nun validu, nun po èssiri nuḍḍu di: %(valura)."

msgid "This field cannot be edited."
msgstr "Stu campu nun pò èssiri mudificatu."

msgid "This field is disabled and cannot have a value."
msgstr "Stu campu è disattivatu e nun po aviri nuḍḍu valuri."

msgid "Invalid CSRF Token."
msgstr "Token CSRF nun validu."

msgid "CSRF token missing."
msgstr "Manca lu gettoni CSRF."

msgid "CSRF failed."
msgstr "Lu CSRF fallìu."

msgid "CSRF token expired."
msgstr "Lu token CSRF scadìu."

msgid "Invalid Choice: could not coerce."
msgstr "Scelta nun valida: nun putìa coerciri."

msgid "Choices cannot be None."
msgstr "Li scelti nun ponnu èssiri Nudda."

msgid "Not a valid choice."
msgstr "Nun è na scelta valida."

msgid "Invalid choice(s): one or more data inputs could not be coerced."
msgstr "Scelta nun valida: unu o cchiù input di dati nun putìanu èssiri custritti."

#, python-format
msgid "'%(value)s' is not a valid choice for this field."
msgstr "'%(valuri)s' nun è na scigghiuta valida pi stu campu."

msgid "Not a valid datetime value."
msgstr "Nun è nu valuri di data-ura validu."

msgid "Not a valid date value."
msgstr "Nun è nu valuri di data validu."

msgid "Not a valid time value."
msgstr "Nun è nu valuri di tempu validu."

msgid "Not a valid week value."
msgstr "Nun è nu valuri validu dâ simana."

msgid "Not a valid integer value."
msgstr "Nun è un valuri nteru validu."

msgid "Not a valid decimal value."
msgstr "Nun è un valuri dicimali validu."

msgid "Not a valid float value."
msgstr "Nun è un valuri float validu."

