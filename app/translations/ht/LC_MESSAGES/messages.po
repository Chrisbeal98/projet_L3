msgid "Field must be equal to %(other_name)s."
msgstr "Jaden dwe egal a %(other_name)s."

#, python-format
msgid "Field must be at least %(min)d character long."
msgstr "Jaden an dwe gen omwen %(min)d karaktè."

#, python-format
msgid "Field cannot be longer than %(max)d character."
msgstr "Jaden pa ka pi long pase %(max)d karaktè."

#, python-format
msgid "Field must be exactly %(max)d character long."
msgstr "Field dwe gen egzakteman %(max)d karaktè long."

#, python-format
msgid "Field must be between %(min)d and %(max)d characters long."
msgstr "Jaden dwe genyen ant %(min)d ak %(max)d karaktè."

#, python-format
msgid "Number must be at least %(min)s."
msgstr "Nimewo a dwe omwen %(min)s."

#, python-format
msgid "Number must be at most %(max)s."
msgstr "Nimewo a dwe pi plis nan %(max)s."

#, python-format
msgid "Number must be between %(min)s and %(max)s."
msgstr "Nimewo a dwe ant %(min)s ak %(max)s."

msgid "Invalid input."
msgstr "D' envalid."

msgid "Invalid email address."
msgstr "Adrès imèl ki pa valab."

msgid "Invalid IP address."
msgstr "Adrès IP envalid."

msgid "Invalid Mac address."
msgstr "Adrès Mac envalid."

msgid "Invalid URL."
msgstr "URL pa valab."

msgid "Invalid UUID."
msgstr "UUID envalid."

#, python-format
msgid "Invalid value, must be one of: %(values)s."
msgstr "Valè pa valab, dwe youn nan: %(values)s."

#, python-format
msgid "Invalid value, can't be any of: %(values)s."
msgstr "Valè pa valab, pa kapab youn nan: %(values)s."

msgid "This field cannot be edited."
msgstr "Jaden sa a pa ka modifye."

msgid "This field is disabled and cannot have a value."
msgstr "Jaden sa a enfim epi li pa ka gen yon valè."

msgid "Invalid CSRF Token."
msgstr "Token CSRF ki pa valab."

msgid "CSRF token missing."
msgstr "Siy CSRF manke."

msgid "CSRF failed."
msgstr "CSRF echwe."

msgid "CSRF token expired."
msgstr "Jeton CSRF ekspire."

msgid "Invalid Choice: could not coerce."
msgstr "Chwa envalid: pa t 'kapab fòse."

msgid "Choices cannot be None."
msgstr "Chwa yo pa ka Okenn."

msgid "Not a valid choice."
msgstr "Pa yon chwa valab."

msgid "Invalid choice(s): one or more data inputs could not be coerced."
msgstr "Chwa ki pa valab (yo): youn oswa plis done yo pa t kapab fòse."

#, python-format
msgid "'%(value)s' is not a valid choice for this field."
msgstr "'%(value)s' pa yon chwa valab pou jaden sa a."

msgid "Not a valid datetime value."
msgstr "Pa yon valè dat lè valab."

msgid "Not a valid date value."
msgstr "Pa yon valè dat valab."

msgid "Not a valid time value."
msgstr "Pa yon valè tan valab."

msgid "Not a valid week value."
msgstr "Pa yon valè semèn valab."

msgid "Not a valid integer value."
msgstr "Pa yon valè nonb antye relatif."

msgid "Not a valid decimal value."
msgstr "Pa yon valè desimal valab."

msgid "Not a valid float value."
msgstr "Pa yon valè flote valab."

