msgid "Choose from:\\n\\t{choices}"
msgstr "မှ ရွေးပါ-\\n\\t{choices}"

#, python-brace-format
msgid "{value!r} is not {choice}."
msgstr "{value!r} သည် {choice} မဟုတ်ပါ။"

#, python-brace-format
msgid "Choice({choices})"
msgstr "ရွေးချယ်မှု({choices})"

#, python-brace-format
msgid "{value!r} does not match the format {format}."
msgstr "{value!r} သည် ဖော်မက် {format} နှင့် မကိုက်ညီပါ။"

#, python-brace-format
msgid "{value!r} is not a valid {number_type}."
msgstr "{value!r} သည် တရားဝင် {number_type} မဟုတ်ပါ။"

#, python-brace-format
msgid "{value} is not in the range {range}."
msgstr "{value} သည် အပိုင်းအခြား {range} တွင် မရှိပါ။"

#, python-brace-format
msgid "{value!r} is not a valid boolean. Recognized values: {states}"
msgstr ""
"{value!r} သည် မှန်ကန်သော ဘူလီယံတစ်ခုမဟုတ်ပါ။ အသိအမှတ်ပြုထားသော "
"တန်ဖိုးများ- {states}"

#, python-brace-format
msgid "{value!r} is not a valid UUID."
msgstr "{value!r} သည် မှန်ကန်သော UUID မဟုတ်ပါ။"

msgid "file"
msgstr "ဖိုင်"

msgid "directory"
msgstr "လမ်းညွှန်"

msgid "path"
msgstr "လမ်းကြောင်း"

#, python-brace-format
msgid "{name} {filename!r} does not exist."
msgstr "{name} {filename!r} မရှိပါ။"

#, python-brace-format
msgid "{name} {filename!r} is a file."
msgstr "{name} {filename!r} သည် ဖိုင်တစ်ခုဖြစ်သည်။"

#, python-brace-format
msgid "{name} {filename!r} is a directory."
