#, python-brace-format
msgid "{name} {filename!r} is not readable."
msgstr "{name} {filename!r} ကို ဖတ်၍မရပါ။"

#, python-brace-format
msgid "{name} {filename!r} is not writable."
msgstr "{name} {filename!r} သည် စာမရေးနိုင်ပါ။"

#, python-brace-format
msgid "{name} {filename!r} is not executable."
msgstr "{name} {filename!r} ကို လုပ်ဆောင်၍မရပါ။"

#, python-brace-format
msgid "{len_type} values are required, but {len_value} was given."
msgstr "{len_type} တန်ဖိုးများ လိုအပ်သော်လည်း {len_value} ကို ပေးထားသည်။"

#, python-brace-format
