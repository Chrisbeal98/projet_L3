msgid "path"
msgstr "dalan"

#, python-brace-format
msgid "{name} {filename!r} does not exist."
msgstr "Awan ti {name} {filename!r}."

#, python-brace-format
msgid "{name} {filename!r} is a file."
msgstr "Ti {name} {nagan ti file!r} ket maysa a file."

#, python-brace-format
msgid "{name} {filename!r} is a directory."
msgstr "Ti {name} {filename!r} ket maysa a direktorio."

#, python-brace-format
msgid "{name} {filename!r} is not readable."
msgstr "Ti {name} {filename!r} ket saan a mabasa."

#, python-brace-format
msgid "{name} {filename!r} is not writable."
msgstr "Ti {name} {filename!r} ket saan a maisurat."

#, python-brace-format
msgid "{name} {filename!r} is not executable."
msgstr "Ti {name} {filename!r} ket saan a maipatungpal."

#, python-brace-format
msgid "{len_type} values are required, but {len_value} was given."
msgstr "Dagiti pateg ti {len_type} ket kasapulan, ngem naited ti {len_value}."

#, python-brace-format
msgid "Unknown standard stream '{name}'"
msgstr "Di ammo a pagalagadan nga ayus '{name}'."

msgid "This field is required."
msgstr "Masapul daytoy a tay-ak."

#, python-brace-format
msgid "File does not have an approved extension: {extensions}"
msgstr "Awan ti naaprobaran nga ekstension ti file: {extensions} ."

msgid "File does not have an approved extension."
msgstr "Awan ti naaprobaran nga ekstension ti file."

#, python-brace-format
msgid "File must be between {min_size} and {max_size} bytes."
msgstr ""
"Ti papeles ket masapul nga adda iti nagbaetan ti {min_size} ken "
"{max_size} a byte."

#, python-format
msgid "Invalid field name '%s'."
msgstr "Di umiso a nagan ti tay-ak '%s'."

#, python-format
msgid "Field must be equal to %(other_name)s."
msgstr "Ti tay-ak ket masapul a kapada ti %(other_name)s."

#, python-format
msgid "Field must be at least %(min)d character long."
msgstr ""
"Masapul a ti tay-ak ket saan a basbassit ngem %(min)d ti kaatiddog ​​ti "
"karakter."

#, python-format
msgid "Field cannot be longer than %(max)d character."
msgstr "Ti tay-ak ket saan a mabalin nga at-atiddog ​​ngem ti %(max)d a karakter."

#, python-format
msgid "Field must be exactly %(max)d character long."
msgstr "Masapul nga eksakto a %(max)d ti kaatiddog ​​ti karakter ti tay-ak."

#, python-format
msgid "Field must be between %(min)d and %(max)d characters long."
msgstr ""
"Masapul nga adda iti nagbaetan ti %(min)d ken %(max)d a karakter ti "
"kaatiddog ​​ti tay-ak."

#, python-format
msgid "Number must be at least %(min)s."
msgstr "Ti numero ket masapul a di kumurang a %(min)s."

#, python-format
msgid "Number must be at most %(max)s."
msgstr "Ti numero ket masapul nga iti kaaduan a %(max)s."

#, python-format
msgid "Number must be between %(min)s and %(max)s."
msgstr "Masapul nga adda ti numero iti nagbaetan ti %(min)s ken %(max)s."

msgid "Invalid input."
msgstr "Di umiso nga input."

msgid "Invalid email address."
msgstr "Di umiso nga email address."

msgid "Invalid IP address."
msgstr "Di umiso nga IP address."

msgid "Invalid Mac address."
msgstr "Di umiso nga adres ti Mac."

msgid "Invalid URL."
msgstr "Di umiso nga URL."

msgid "Invalid UUID."
msgstr "Di umiso nga UUID."

#, python-format
msgid "Invalid value, must be one of: %(values)s."
msgstr "Di umiso a pateg, masapul a maysa kadagiti: %(values)s."

#, python-format
msgid "Invalid value, can't be any of: %(values)s."
msgstr "Di umiso a pateg, saan a mabalin nga aniaman kadagiti: %(values)s."

msgid "This field cannot be edited."
msgstr "Saan a ma-edit daytoy a tay-ak."

msgid "This field is disabled and cannot have a value."
msgstr "Daytoy a tay-ak ket nabalbaliwan ken saan a mabalin nga addaan iti pateg."

msgid "Invalid CSRF Token."
msgstr "Di umiso a Token ti CSRF."

msgid "CSRF token missing."
msgstr "Awan ti token ti CSRF."

msgid "CSRF failed."
msgstr "Napaay ti CSRF."

msgid "CSRF token expired."
msgstr "Nagpaso ti token ti CSRF."

msgid "Invalid Choice: could not coerce."
msgstr "Invalid Choice: saan a makapilit."

msgid "Choices cannot be None."
msgstr "Saan a mabalin nga Awan dagiti pagpilian."

msgid "Not a valid choice."
msgstr "Saan a balido a pili."

msgid "Invalid choice(s): one or more data inputs could not be coerced."
msgstr ""
"Di umiso a pagpilian (dagiti): maysa wenno ad-adu pay nga input ti datos "
"ket saan a mapilit."

#, python-format
msgid "'%(value)s' is not a valid choice for this field."
msgstr "Ti '%(value)s' ket saan a balido a pili para iti daytoy a tay-ak."

msgid "Not a valid datetime value."
msgstr "Saan a balido a pateg ti datetime."

msgid "Not a valid date value."
msgstr "Saan a balido a pateg ti petsa."

msgid "Not a valid time value."
msgstr "Saan a balido a pateg ti oras."

msgid "Not a valid week value."
msgstr "Saan a balido a pateg ti lawas."

msgid "Not a valid integer value."
msgstr "Saan a balido a pateg ti intero a bilang."

msgid "Not a valid decimal value."
msgstr "Saan a balido a decimal value."

msgid "Not a valid float value."
msgstr "Saan a balido a float value."

