msgid "Field cannot be longer than %(max)d character."
msgstr "O campo non pode ter máis de %(max)d carácter."

#, python-format
msgid "Field must be exactly %(max)d character long."
msgstr "O campo debe ter exactamente %(max)d caracteres."

#, python-format
msgid "Field must be between %(min)d and %(max)d characters long."
msgstr "O campo debe ter entre %(min)d e %(max)d caracteres."

#, python-format
msgid "Number must be at least %(min)s."
msgstr "O número debe ser polo menos %(min)s."

#, python-format
msgid "Number must be at most %(max)s."
msgstr "O número debe ser como máximo %(max)s."

#, python-format
msgid "Number must be between %(min)s and %(max)s."
msgstr "O número debe estar entre %(min)s e %(max)s."

msgid "Invalid input."
msgstr "Entrada non válida."

msgid "Invalid email address."
msgstr "Enderezo de correo electrónico non válido."

msgid "Invalid IP address."
msgstr "Enderezo IP non válido."

msgid "Invalid Mac address."
msgstr "Enderezo de Mac non válido."

msgid "Invalid URL."
msgstr "URL non válido."

msgid "Invalid UUID."
msgstr "UUID non válido."

#, python-format
msgid "Invalid value, must be one of: %(values)s."
msgstr "Valor non válido, debe ser un de: %(values)s."

#, python-format
msgid "Invalid value, can't be any of: %(values)s."
msgstr "Valor non válido, non pode ser ningún dos: %(values)s."

msgid "This field cannot be edited."
msgstr "Este campo non se pode editar."

msgid "This field is disabled and cannot have a value."
msgstr "Este campo está desactivado e non pode ter un valor."

msgid "Invalid CSRF Token."
msgstr "Token CSRF non válido."

msgid "CSRF token missing."
msgstr "Falta o token CSRF."

msgid "CSRF failed."
msgstr "Fallou o CSRF."

msgid "CSRF token expired."
msgstr "O token CSRF caducou."

msgid "Invalid Choice: could not coerce."
msgstr "Elección non válida: non se puido forzar."

msgid "Choices cannot be None."
msgstr "As opcións non poden ser Ningunha."

msgid "Not a valid choice."
msgstr "Non é unha opción válida."

msgid "Invalid choice(s): one or more data inputs could not be coerced."
msgstr ""
"Opcións non válidas: non se puideron forzar unha ou máis entradas de "
"datos."

#, python-format
msgid "'%(value)s' is not a valid choice for this field."
msgstr "'%(value)s' non é unha opción válida para este campo."

msgid "Not a valid datetime value."
msgstr "Non é un valor de data e hora válido."

msgid "Not a valid date value."
msgstr "Non é un valor de data válido."

msgid "Not a valid time value."
msgstr "Non é un valor de tempo válido."

msgid "Not a valid week value."
msgstr "Non é un valor semanal válido."

msgid "Not a valid integer value."
msgstr "Non é un valor enteiro válido."

msgid "Not a valid decimal value."
msgstr "Non é un valor decimal válido."

msgid "Not a valid float value."
msgstr "Non é un valor flotante válido."

