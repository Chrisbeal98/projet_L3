msgstr "Fail tidak mempunyai sambungan yang diluluskan."

#, python-brace-format
msgid "File must be between {min_size} and {max_size} bytes."
msgstr "Fail mestilah antara {min_size} dan {max_size} bait."

#, python-format
msgid "Invalid field name '%s'."
msgstr "Nama medan '%s' tidak sah."

#, python-format
msgid "Field must be equal to %(other_name)s."
msgstr "Medan mestilah sama dengan %(other_name)s."

#, python-format
msgid "Field must be at least %(min)d character long."
msgstr "Panjang medan mestilah sekurang-kurangnya %(min)d aksara."

#, python-format
msgid "Field cannot be longer than %(max)d character."
msgstr "Medan tidak boleh lebih panjang daripada %(maks)d aksara."

#, python-format
msgid "Field must be exactly %(max)d character long."
msgstr "Panjang medan mestilah tepat %(maks)d aksara."

#, python-format
msgid "Field must be between %(min)d and %(max)d characters long."
msgstr "Panjang medan mestilah antara %(min)d dan %(maks)d aksara."

#, python-format
msgid "Number must be at least %(min)s."
msgstr "Nombor mestilah sekurang-kurangnya %(min)s."

#, python-format
msgid "Number must be at most %(max)s."
msgstr "Nombor mestilah paling banyak %(maks)s."

#, python-format
msgid "Number must be between %(min)s and %(max)s."
msgstr "Nombor mestilah antara %(min)s dan %(maks)s."

