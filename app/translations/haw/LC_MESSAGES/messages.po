msgstr "ʻAʻole kūpono ke ʻano hoʻomaka no ke koho ({koho})"

#, python-brace-format
msgid "Argument {name!r} takes {nargs} values."
msgstr "Hoʻopaʻapaʻa ʻo {name!r} i nā waiwai {nargs}."

#, python-brace-format
msgid "Option {name!r} does not take a value."
msgstr "ʻAʻole lawe ʻia ke koho {name!r} i kahi waiwai."

#, python-brace-format
msgid "Option {name!r} requires an argument."
msgstr "Pono ke koho {name!r} i ka hoʻopaʻapaʻa."

msgid "Shell completion is not supported for Bash versions older than 4.4."
msgstr "ʻAʻole kākoʻo ʻia ka hoʻopau ʻana o Shell no nā mana Bash ma mua o 4.4."

msgid "Couldn't detect Bash version, shell completion is not supported."
msgstr ""
"ʻAʻole hiki ke ʻike i ka mana Bash, ʻaʻole kākoʻo ʻia ka hoʻopau ʻana o "
"ka pūpū."

msgid "Repeat for confirmation"
msgstr "E hana hou no ka hōʻoia"

msgid "Error: The two entered values do not match."
msgstr "Hapa: ʻAʻole kūlike nā waiwai i hoʻokomo ʻia."

msgid "Error: invalid input"
msgstr "Kuʻia: kūpono ʻole ka hoʻokomo"

#, python-brace-format
msgid "Unknown color {colour!r}"
msgstr "kala ʻike ʻole ʻia {color!r}"

msgid "Press any key to continue..."
msgstr "E kaomi i kekahi kī e hoʻomau..."

#, python-brace-format
msgid "Choose from:\\n\\t{choices}"
msgstr "E koho mai:\\n\\t{choices}"

#, python-brace-format
msgid "{value!r} is not {choice}."
msgstr "ʻAʻole ʻo {value!r} {koho."

#, python-brace-format
msgid "Choice({choices})"
msgstr "Koho ({koho})"

#, python-brace-format
msgid "{value!r} does not match the format {format}."
msgstr "ʻAʻole like ka {value!r} i ke ʻano {format}."

#, python-brace-format
msgid "{value!r} is not a valid {number_type}."
msgstr "{value!r} 'a'ole he {number_type}."

#, python-brace-format
msgid "{value} is not in the range {range}."
msgstr "ʻAʻole ʻo {value} i ka laulā {range}."

#, python-brace-format
msgid "{value!r} is not a valid boolean. Recognized values: {states}"
msgstr "ʻAʻole ʻo {value!r} kahi boolean kūpono. Nā waiwai i ʻike ʻia: {states}"

#, python-brace-format
msgid "{value!r} is not a valid UUID."
msgstr "ʻAʻole ʻo {value!r} he UUID kūpono."

msgid "file"
msgstr "waihona"

msgid "directory"
msgstr "papa kuhikuhi"

msgid "path"
msgstr "alahele"

#, python-brace-format
msgid "{name} {filename!r} does not exist."
msgstr "ʻAʻole i loaʻa ʻo {name} {filename!r}."

#, python-brace-format
msgid "{name} {filename!r} is a file."
msgstr "He waihona ʻo {name} {filename!r}."

#, python-brace-format
msgid "{name} {filename!r} is a directory."
msgstr "He papa kuhikuhi ʻo {name} {filename!r}."

#, python-brace-format
msgid "{name} {filename!r} is not readable."
msgstr "ʻAʻole hiki ke heluhelu ʻia ʻo {name} {filename!r}."

#, python-brace-format
msgid "{name} {filename!r} is not writable."
msgstr "ʻAʻole hiki ke kākau ʻia ʻo {name} {filename!r}."

#, python-brace-format
msgid "{name} {filename!r} is not executable."
msgstr "ʻAʻole hiki ke hoʻokō ʻia ʻo {name} {filename!r}."

#, python-brace-format
msgid "{len_type} values are required, but {len_value} was given."
msgstr "Pono nā waiwai {len_type}, akā hā'awi 'ia {len_value}."

#, python-brace-format
msgid "Unknown standard stream '{name}'"
msgstr "ʻAʻole ʻike ʻia ke kahawai maʻamau '{name}'"

msgid "This field is required."
msgstr "Pono kēia kahua."

#, python-brace-format
msgid "File does not have an approved extension: {extensions}"
msgstr "ʻAʻohe hoʻonui i ʻāpono ʻia i ka faila: {extensions}"

msgid "File does not have an approved extension."
msgstr "ʻAʻohe hoʻonui i ʻāpono ʻia i ka faila."

#, python-brace-format
msgid "File must be between {min_size} and {max_size} bytes."
msgstr "Pono ka waihona ma waena o {min_size} a me {max_size} bytes."

#, python-format
msgid "Invalid field name '%s'."
msgstr "Hewa ka inoa kahua '%s'."

#, python-format
msgid "Field must be equal to %(other_name)s."
msgstr "Pono ke kahua me %(other_name)s."

#, python-format
msgid "Field must be at least %(min)d character long."
msgstr "Pono ke kahua he %(min)d ka lōʻihi."

#, python-format
msgid "Field cannot be longer than %(max)d character."
msgstr "ʻAʻole hiki ke lōʻihi ka mahina ma mua o %(max)d huaʻōlelo."

#, python-format
msgid "Field must be exactly %(max)d character long."
msgstr "Pono ke kahua he %(max)d ka lōʻihi."

#, python-format
msgid "Field must be between %(min)d and %(max)d characters long."
msgstr "Pono ke kahua ma waena o %(min)d a me %(max)d mau huapalapala."

#, python-format
msgid "Number must be at least %(min)s."
msgstr "Pono ka helu ma kahi o %(min)s."

#, python-format
msgid "Number must be at most %(max)s."
msgstr "Pono ka helu ma kahi o %(max)s."

#, python-format
msgid "Number must be between %(min)s and %(max)s."
msgstr "Pono ka helu ma waena o %(min)s a me %(max)s."

msgid "Invalid input."
msgstr "Hewa ka hookomo."

msgid "Invalid email address."
msgstr "Heluhelu leka uila hewa ʻole."

msgid "Invalid IP address."
msgstr "Helu IP kūpono ʻole."

msgid "Invalid Mac address."
msgstr "Helu helu Mac ʻino."

msgid "Invalid URL."
msgstr "Helu 'ole."

msgid "Invalid UUID."
msgstr "UUID hewa ʻole."

#, python-format
msgid "Invalid value, must be one of: %(values)s."
msgstr "Pono ʻole ka waiwai, pono kekahi o: %(values)s."

#, python-format
msgid "Invalid value, can't be any of: %(values)s."
msgstr "Waiwai kūpono ʻole, ʻaʻole hiki i kekahi o: %(values)s."

msgid "This field cannot be edited."
msgstr "ʻAʻole hiki ke hoʻoponopono ʻia kēia kahua."

msgid "This field is disabled and cannot have a value."
msgstr "Ua pio kēia kahua a ʻaʻole hiki ke loaʻa kahi waiwai."

msgid "Invalid CSRF Token."
msgstr "Helu CSRF Token."

msgid "CSRF token missing."
msgstr "Nalo ka hōʻailona CSRF."

msgid "CSRF failed."
msgstr "Ua hāʻule ka CSRF."

msgid "CSRF token expired."
msgstr "Ua pau ka hōʻailona CSRF."

msgid "Invalid Choice: could not coerce."
msgstr "Koho kūpono ʻole: ʻaʻole hiki ke koi."

msgid "Choices cannot be None."
msgstr "ʻAʻole hiki ke koho ʻAʻole."

msgid "Not a valid choice."
msgstr "ʻAʻole kahi koho kūpono."

msgid "Invalid choice(s): one or more data inputs could not be coerced."
msgstr ""
"Koho hewa ʻole: ʻaʻole hiki ke koi ʻia i hoʻokahi a ʻoi aku paha nā "
"hoʻokomo ʻikepili."

#, python-format
msgid "'%(value)s' is not a valid choice for this field."
msgstr "'%(value)s' 'a'ole he koho kūpono no kēia kahua."

msgid "Not a valid datetime value."
msgstr "ʻAʻole he kumu kūʻai manawa kūpono."

msgid "Not a valid date value."
msgstr "ʻAʻole kahi waiwai lā kūpono."

msgid "Not a valid time value."
msgstr "ʻAʻole kahi waiwai manawa kūpono."

msgid "Not a valid week value."
msgstr "ʻAʻole he waiwai pule kūpono."

msgid "Not a valid integer value."
msgstr "ʻAʻole he waiwai helu helu kūpono."

msgid "Not a valid decimal value."
msgstr "ʻAʻole he helu decimal kūpono."

msgid "Not a valid float value."
msgstr "ʻAʻole he waiwai lana kūpono."

