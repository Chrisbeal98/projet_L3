msgstr "Faile e sega ni dua na kena vakadonui na vakabalavutaki."

#, python-brace-format
msgid "File must be between {min_size} and {max_size} bytes."
msgstr ""
"Na faile e dodonu me tiko ena maliwa ni {min_levu} kei na {levu_levu} "
"baiti."

#, python-format
msgid "Invalid field name '%s'."
msgstr "Na yaca ni vanua e sega ni dodonu '%s'."

#, python-format
msgid "Field must be equal to %(other_name)s."
msgstr "Na vanua e dodonu me tautauvata kei na % (yaca_dua tale) s."

#, python-format
msgid "Field must be at least %(min)d character long."
msgstr "Na vanua e dodonu me lailai duadua % (min) d na ivakatakilakila balavu."

#, python-format
msgid "Field cannot be longer than %(max)d character."
msgstr "Na vanua e sega ni rawa ni balavu cake mai na % (max) d ivakatakilakila."

#, python-format
msgid "Field must be exactly %(max)d character long."
msgstr "Na vanua e dodonu me dodonu sara na % (max) d na ivakatakilakila balavu."

#, python-format
msgid "Field must be between %(min)d and %(max)d characters long."
msgstr ""
"Na vanua e dodonu me tiko ena maliwa ni% (min) d kei na% (levu duadua) d "
"na matanivola balavu."

#, python-format
msgid "Number must be at least %(min)s."
msgstr "Na iwiliwili e dodonu me lailai duadua % (miniti) s."

#, python-format
msgid "Number must be at most %(max)s."
msgstr "Na iwiliwili e dodonu me levu duadua % (levu duadua) s."

#, python-format
msgid "Number must be between %(min)s and %(max)s."
msgstr "Na naba e dodonu me tiko ena maliwa ni% (miniti) kei na% (levu duadua)."

msgid "Invalid input."
msgstr "Vakacurumi sega ni dodonu."

msgid "Invalid email address."
msgstr "Na itikotiko ni imeli sega ni dodonu."

msgid "Invalid IP address."
msgstr "Na itikotiko ni IP sega ni dodonu."

msgid "Invalid Mac address."
msgstr "Na itikotiko ni Mac sega ni dodonu."

msgid "Invalid URL."
msgstr "URL sega ni dodonu."

msgid "Invalid UUID."
msgstr "UUID sega ni dodonu."

#, python-format
msgid "Invalid value, must be one of: %(values)s."
msgstr "Na isau sega ni dodonu, e dodonu me dua vei ira na: %(ivakarau)s."

#, python-format
msgid "Invalid value, can't be any of: %(values)s."
msgstr "Na isau sega ni dodonu, e sega ni rawa ni dua vei ira na: %(ivakarau)s."

msgid "This field cannot be edited."
msgstr "E sega ni rawa ni vakadodonutaki na vanua oqo."

msgid "This field is disabled and cannot have a value."
msgstr "Na vanua oqo e vakaleqai ka sega ni rawa ni dua na kena yaga."

msgid "Invalid CSRF Token."
msgstr "Tokeni ni CSRF sega ni dodonu."

msgid "CSRF token missing."
msgstr "Yali na ivakatakilakila ni CSRF."

msgid "CSRF failed."
msgstr "E sega ni rawata na CSRF."

msgid "CSRF token expired."
msgstr "Sa oti na gauna ni ivakatakilakila ni CSRF."

msgid "Invalid Choice: could not coerce."
msgstr "Digidigi sega ni dodonu: sega ni rawa ni vakasaurarataki."

msgid "Choices cannot be None."
msgstr "Na digidigi e sega ni rawa ni Sega."

msgid "Not a valid choice."
msgstr "E sega ni digidigi dodonu."

msgid "Invalid choice(s): one or more data inputs could not be coerced."
msgstr ""
"Digidigi sega ni dodonu(s): e dua se sivia na itukutuku ni inputs e sega "
"ni rawa ni vakasaurarataki."

#, python-format
msgid "'%(value)s' is not a valid choice for this field."
msgstr "'%(ibalebale) s' e sega ni dua na digidigi dodonu me baleta na vanua oqo."

