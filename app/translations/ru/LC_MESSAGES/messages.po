#, python-brace-format
msgid "Option {name!r} requires an argument."
msgstr "Опция {name!r} требует аргумента."

msgid "Shell completion is not supported for Bash versions older than 4.4."
msgstr "Завершение оболочки не поддерживается для версий Bash старше 4.4."

msgid "Couldn't detect Bash version, shell completion is not supported."
msgstr "Не удалось определить версию Bash, завершение оболочки не поддерживается."

msgid "Repeat for confirmation"
msgstr "Повторите для подтверждения"

msgid "Error: The two entered values do not match."
msgstr "Ошибка: два введенных значения не совпадают."

msgid "Error: invalid input"
msgstr "Ошибка: неверный ввод."

#, python-brace-format
msgid "Unknown color {colour!r}"
msgstr "Неизвестный цвет {color!r}"

msgid "Press any key to continue..."
msgstr "Нажмите любую клавишу, чтобы продолжить..."

#, python-brace-format
msgid "Choose from:\\n\\t{choices}"
msgstr "Выберите из:\\n\\t{выборов}"

#, python-brace-format
msgid "{value!r} is not {choice}."
msgstr "{value!r} не является {choice}."

#, python-brace-format
msgid "Choice({choices})"
msgstr "Выбор({выбор})"

#, python-brace-format
msgid "{value!r} does not match the format {format}."
msgstr "{value!r} не соответствует формату {format}."

#, python-brace-format
msgid "{value!r} is not a valid {number_type}."
msgstr "{value!r} не является допустимым {number_type}."

#, python-brace-format
msgid "{value} is not in the range {range}."
msgstr "{value} находится за пределами диапазона {range}."

#, python-brace-format
msgid "{value!r} is not a valid boolean. Recognized values: {states}"
msgstr ""
"{value!r} не является допустимым логическим значением. Признанные "
"ценности: {states}"

#, python-brace-format
msgid "{value!r} is not a valid UUID."
msgstr "{value!r} не является допустимым UUID."

msgid "file"
msgstr "файл"

msgid "directory"
msgstr "каталог"

msgid "path"
msgstr "путь"

#, python-brace-format
msgid "{name} {filename!r} does not exist."
msgstr "{имя} {имя_файла!r} не существует."

#, python-brace-format
msgid "{name} {filename!r} is a file."
msgstr "{имя} {имя_файла!r} — это файл."

#, python-brace-format
msgid "{name} {filename!r} is a directory."
msgstr "{имя} {имя_файла!r} — это каталог."

#, python-brace-format
msgid "{name} {filename!r} is not readable."
msgstr "{имя} {имя файла!r} не читается."

#, python-brace-format
msgid "{name} {filename!r} is not writable."
msgstr "{name} {filename!r} недоступен для записи."

#, python-brace-format
msgid "{name} {filename!r} is not executable."
msgstr "{name} {filename!r} не является исполняемым."

#, python-brace-format
msgid "{len_type} values are required, but {len_value} was given."
msgstr "Значения {len_type} обязательны, но было задано {len_value}."

#, python-brace-format
msgid "Unknown standard stream '{name}'"
msgstr "Неизвестный стандартный поток '{name}'"

msgid "This field is required."
msgstr "Это поле обязательно к заполнению."

#, python-brace-format
msgid "File does not have an approved extension: {extensions}"
msgstr "У файла нет одобренного расширения: {extensions}."

msgid "File does not have an approved extension."
msgstr "Файл не имеет утвержденного расширения."

#, python-brace-format
msgid "File must be between {min_size} and {max_size} bytes."
msgstr "Размер файла должен быть от {min_size} до {max_size} байт."

#, python-format
msgid "Invalid field name '%s'."
msgstr "Недопустимое имя поля «%s»."

#, python-format
msgid "Field must be equal to %(other_name)s."
msgstr "Поле должно быть равно %(other_name)s."

#, python-format
msgid "Field must be at least %(min)d character long."
msgstr "Поле должно содержать не менее %(min)d символов."

#, python-format
msgid "Field cannot be longer than %(max)d character."
msgstr "Поле не может содержать более %(max)d символов."

#, python-format
msgid "Field must be exactly %(max)d character long."
msgstr "Поле должно содержать ровно %(max)d символов."

#, python-format
msgid "Field must be between %(min)d and %(max)d characters long."
msgstr "Поле должно содержать от %(min)d до %(max)d символов."

#, python-format
msgid "Number must be at least %(min)s."
msgstr "Число должно быть не менее %(min)s."

#, python-format
msgid "Number must be at most %(max)s."
msgstr "Число должно быть не более %(max)s."

#, python-format
msgid "Number must be between %(min)s and %(max)s."
msgstr "Число должно быть между %(min)s и %(max)s."

msgid "Invalid input."
msgstr "Неверный ввод."

msgid "Invalid email address."
msgstr "Неверный адрес электронной почты."

msgid "Invalid IP address."
msgstr "Неверный IP-адрес."

msgid "Invalid Mac address."
msgstr "Неверный Mac-адрес."

msgid "Invalid URL."
msgstr "Неверный URL-адрес."

msgid "Invalid UUID."
msgstr "Неверный UUID."

#, python-format
msgid "Invalid value, must be one of: %(values)s."
msgstr "Недопустимое значение. Должно быть одно из: %(values)s."

#, python-format
msgid "Invalid value, can't be any of: %(values)s."
msgstr "Недопустимое значение. Оно не может быть одним из: %(values)s."

msgid "This field cannot be edited."
msgstr "Это поле нельзя редактировать."

msgid "This field is disabled and cannot have a value."
msgstr "Это поле отключено и не может иметь значения."

msgid "Invalid CSRF Token."
msgstr "Неверный токен CSRF."

msgid "CSRF token missing."
msgstr "Токен CSRF отсутствует."

msgid "CSRF failed."
msgstr "CSRF не удалось."

msgid "CSRF token expired."
msgstr "Срок действия токена CSRF истек."

msgid "Invalid Choice: could not coerce."
msgstr "Неверный выбор: не удалось принудить."

msgid "Choices cannot be None."
msgstr "Варианты выбора не могут быть «Нет»."

msgid "Not a valid choice."
msgstr "Не верный выбор."

msgid "Invalid choice(s): one or more data inputs could not be coerced."
msgstr ""
"Неверный выбор: один или несколько входных данных не могут быть "
"принудительно применены."

#, python-format
msgid "'%(value)s' is not a valid choice for this field."
msgstr "'%(value)s' не является допустимым выбором для этого поля."

msgid "Not a valid datetime value."
msgstr "Недопустимое значение даты и времени."

msgid "Not a valid date value."
msgstr "Недопустимое значение даты."

msgid "Not a valid time value."
msgstr "Недопустимое значение времени."

msgid "Not a valid week value."
msgstr "Недопустимое значение недели."

msgid "Not a valid integer value."
msgstr "Недопустимое целочисленное значение."

msgid "Not a valid decimal value."
msgstr "Недопустимое десятичное значение."

msgid "Not a valid float value."
msgstr "Недопустимое значение с плавающей запятой."

