msgid "File does not have an approved extension: {extensions}"
msgstr "Failil pole kinnitatud laiendit: {extensions}"

msgid "File does not have an approved extension."
msgstr "Failil pole kinnitatud laiendit."

#, python-brace-format
msgid "File must be between {min_size} and {max_size} bytes."
msgstr "Fail peab olema vahemikus {min_size} kuni {max_size} baiti."

#, python-format
msgid "Invalid field name '%s'."
msgstr "Vale välja nimi '%s'."

#, python-format
msgid "Field must be equal to %(other_name)s."
msgstr "Väli peab olema võrdne %(muu_nimi)s."

#, python-format
msgid "Field must be at least %(min)d character long."
msgstr "Väli peab olema vähemalt %(min)d tähemärki pikk."

#, python-format
msgid "Field cannot be longer than %(max)d character."
msgstr "Väli ei tohi olla pikem kui %(max)d tähemärki."

#, python-format
msgid "Field must be exactly %(max)d character long."
msgstr "Väli peab olema täpselt %(max)d tähemärki pikk."

#, python-format
msgid "Field must be between %(min)d and %(max)d characters long."
msgstr "Väli peab olema %(min)d kuni %(max)d tähemärki pikk."

#, python-format
msgid "Number must be at least %(min)s."
msgstr "Arv peab olema vähemalt %(min)s."

#, python-format
msgid "Number must be at most %(max)s."
msgstr "Arv peab olema kuni %(max)s."

#, python-format
msgid "Number must be between %(min)s and %(max)s."
msgstr "Arv peab jääma %(min)s ja %(max)s vahele."

msgid "Invalid input."
msgstr "Vale sisend."

msgid "Invalid email address."
msgstr "Vale e-posti aadress."

msgid "Invalid IP address."
msgstr "Vale IP-aadress."

msgid "Invalid Mac address."
msgstr "Vale Maci aadress."

msgid "Invalid URL."
msgstr "Kehtetu URL."

msgid "Invalid UUID."
msgstr "Kehtetu UUID."

#, python-format
msgid "Invalid value, must be one of: %(values)s."
msgstr "Kehtetu väärtus, peab olema üks järgmistest: %(values)s."

#, python-format
msgid "Invalid value, can't be any of: %(values)s."
msgstr "Vale väärtus, ei saa olla ükski järgmistest: %(values)s."

