#, python-brace-format
msgid "File does not have an approved extension: {extensions}"
msgstr "Filen tɛ ni farankan ye min dabɔra: {extensions}."

msgid "File does not have an approved extension."
msgstr "File tɛ ni extension (dakun) ye min dabɔra."

#, python-brace-format
msgid "File must be between {min_size} and {max_size} bytes."
msgstr "Filen ka kan ka kɛ {min_size} ni {max_size} bayt cɛ."

#, python-format
msgid "Invalid field name '%s'."
msgstr "Foro tɔgɔ tiɲɛnen '%s'."

#, python-format
msgid "Field must be equal to %(other_name)s."
msgstr "Foro ka kan ka bɛn %(tɔgɔ_tɔgɔ)w ma."

#, python-format
msgid "Field must be at least %(min)d character long."
msgstr "Foro ka kan ka kɛ %(min)d taamasiyɛn janya ye a dɔgɔyalenba la."

#, python-format
msgid "Field cannot be longer than %(max)d character."
msgstr "Foro tɛ se ka janya ka tɛmɛ %(max)d taamasiyɛn kan."

#, python-format
msgid "Field must be exactly %(max)d character long."
msgstr "Foro ka kan ka kɛ %(max)d taamaʃyɛn janya tigitigi ye."

#, python-format
msgid "Field must be between %(min)d and %(max)d characters long."
msgstr "Foro ka kan ka janya %(min)d ni %(max)d cɛ."

#, python-format
msgid "Number must be at least %(min)s."
msgstr "Jate ka kan ka kɛ %(min)s ye a dɔgɔyalenba la."

#, python-format
msgid "Number must be at most %(max)s."
msgstr "Jate ka kan ka kɛ %(max)s ye a caya la."

#, python-format
msgid "Number must be between %(min)s and %(max)s."
msgstr "Jate ka kan ka kɛ %(min)s ni %(max)s cɛ."

msgid "Invalid input."
msgstr "Donan min tɛ tiɲɛ ye."

