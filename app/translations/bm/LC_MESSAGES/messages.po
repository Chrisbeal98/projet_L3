msgstr "Misali: Nafa fila minnu donna, olu tɛ bɛn ɲɔgɔn ma."

msgid "Error: invalid input"
msgstr "Misali: donnakow tiɲɛnen"

#, python-brace-format
msgid "Unknown color {colour!r}"
