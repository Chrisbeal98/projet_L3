msgstr "Sugandili tɛ se ka kɛ None ye."

msgid "Not a valid choice."
msgstr "Sugandili bɛnnen tɛ."

msgid "Invalid choice(s): one or more data inputs could not be coerced."
msgstr ""
"Sugandili (w) minnu tɛ tiɲɛ ye: kunnafonidilan kelen walima caman doncogo"
" ma se ka wajibiya."

