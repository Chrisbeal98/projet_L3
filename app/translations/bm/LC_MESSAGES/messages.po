#, python-format
msgid "Invalid value, must be one of: %(values)s."
msgstr "Nafa tiɲɛnen, ka kan ka kɛ ninnu dɔ ye: %(nafaw)w."

#, python-format
msgid "Invalid value, can't be any of: %(values)s."
msgstr "Nafa tiɲɛnen, tɛ se ka kɛ ninnu si ye: %(nafaw)w."

msgid "This field cannot be edited."
msgstr "Nin foro in tɛ se ka ladilan."

msgid "This field is disabled and cannot have a value."
msgstr "Nin foro in ye baarakɛbali ye, wa a tɛ se ka kɛ ni nafa ye."

