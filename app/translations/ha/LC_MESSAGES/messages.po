msgid "Invalid IP address."
msgstr "Adireshin IP mara inganci."

msgid "Invalid Mac address."
msgstr "Adireshin Mac mara inganci."

msgid "Invalid URL."
msgstr "URL mara inganci."

msgid "Invalid UUID."
msgstr "UUID mara inganci."

#, python-format
msgid "Invalid value, must be one of: %(values)s."
msgstr "Ƙimar mara inganci, dole ne ta kasance ɗaya daga cikin: %(daraja)s."

#, python-format
msgid "Invalid value, can't be any of: %(values)s."
