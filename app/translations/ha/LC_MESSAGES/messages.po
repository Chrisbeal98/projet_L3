msgstr "{name} {filename!r} ba za a iya aiwatar da shi ba."

#, python-brace-format
msgid "{len_type} values are required, but {len_value} was given."
msgstr "Ana buƙatar ƙimar {len_type}, amma an ba da {len_value}."

#, python-brace-format
msgid "Unknown standard stream '{name}'"
msgstr "Madaidaicin madaidaicin rafi '{name}'"

msgid "This field is required."
msgstr "Wannan fillin ana bukatansa."

#, python-brace-format
msgid "File does not have an approved extension: {extensions}"
msgstr "Fayil ba shi da ingantaccen tsawaitawa: {extensions}"

msgid "File does not have an approved extension."
msgstr "Fayil ba shi da ingantaccen tsawo."

#, python-brace-format
msgid "File must be between {min_size} and {max_size} bytes."
msgstr "Dole ne fayil ya kasance tsakanin {min_size} da {max_size} bytes."

#, python-format
msgid "Invalid field name '%s'."
msgstr "Sunan filin mara inganci '%s'."

#, python-format
msgid "Field must be equal to %(other_name)s."
msgstr "Dole ne filin ya zama daidai da %(other_name)s."

#, python-format
msgid "Field must be at least %(min)d character long."
msgstr "Dole ne filin ya kasance aƙalla tsawon harafi %(min) d."

#, python-format
msgid "Field cannot be longer than %(max)d character."
msgstr "Filin ba zai iya zama fiye da %(max) d hali ba."

#, python-format
msgid "Field must be exactly %(max)d character long."
msgstr "Dole ne filin ya kasance daidai %(max)d tsayin harafi."

#, python-format
msgid "Field must be between %(min)d and %(max)d characters long."
msgstr "Dole ne filin ya kasance tsakanin %(min) d da %(max) d tsayin haruffa."

#, python-format
msgid "Number must be at least %(min)s."
msgstr "Dole ne lamba ta zama aƙalla %(min)s."

#, python-format
msgid "Number must be at most %(max)s."
msgstr "Dole ne lamba ta kasance aƙalla %(max)s."

#, python-format
msgid "Number must be between %(min)s and %(max)s."
msgstr "Dole ne lamba ta kasance tsakanin %(min)s da %(max)s."

msgid "Invalid input."
msgstr "Shigar da ba daidai ba."

msgid "Invalid email address."
