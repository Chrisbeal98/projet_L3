#, python-format
msgid "Invalid value, must be one of: %(values)s."
msgstr "অবৈধ মান, এটা হ'ব লাগিব: %(values)s ।"

#, python-format
msgid "Invalid value, can't be any of: %(values)s."
msgstr "অবৈধ মান, কোনো হ'ব নোৱাৰে: %(values)s."

msgid "This field cannot be edited."
msgstr "এই ক্ষেত্ৰখন সম্পাদনা কৰিব নোৱাৰি।"

msgid "This field is disabled and cannot have a value."
msgstr "এই ক্ষেত্ৰ নিষ্ক্ৰিয় আৰু ইয়াৰ এটা মান থাকিব নোৱাৰে।"

msgid "Invalid CSRF Token."
msgstr "অবৈধ CSRF টোকেন।"

msgid "CSRF token missing."
msgstr "CSRF টোকেন নোহোৱা হৈছে।"

msgid "CSRF failed."
msgstr "চি এছ আৰ এফ বিফল হ’ল।"

msgid "CSRF token expired."
msgstr "CSRF টোকেনৰ ম্যাদ উকলি গৈছে।"

msgid "Invalid Choice: could not coerce."
msgstr "অবৈধ পছন্দ: জোৰ-জবৰদস্তি কৰিব পৰা নাছিল।"

msgid "Choices cannot be None."
msgstr "পছন্দবোৰ কোনো নহয় হ’ব নোৱাৰে।"

msgid "Not a valid choice."
msgstr "বৈধ পছন্দ নহয়।"

msgid "Invalid choice(s): one or more data inputs could not be coerced."
msgstr "অবৈধ পছন্দ(সমূহ): এটা বা অধিক তথ্য ইনপুট জোৰ কৰিব পৰা নগ'ল।"

#, python-format
msgid "'%(value)s' is not a valid choice for this field."
msgstr "'%(value)s' এই ক্ষেত্ৰৰ বাবে এটা বৈধ পছন্দ নহয়।"

msgid "Not a valid datetime value."
msgstr "এটা বৈধ তাৰিখসময় মান নহয়।"

msgid "Not a valid date value."
msgstr "এটা বৈধ তাৰিখ মান নহয়।"

msgid "Not a valid time value."
msgstr "বৈধ সময়ৰ মান নহয়।"

msgid "Not a valid week value."
msgstr "বৈধ সপ্তাহৰ মূল্য নহয়।"

msgid "Not a valid integer value."
msgstr "এটা বৈধ পূৰ্ণসংখ্যা মান নহয়।"

msgid "Not a valid decimal value."
msgstr "এটা বৈধ দশমিক মান নহয়।"

msgid "Not a valid float value."
msgstr "এটা বৈধ ফ্ল'ট মান নহয়।"

