msgid "{name} {filename!r} is a directory."
msgstr "{name} {filename!r} direktorio bat da."

#, python-brace-format
msgid "{name} {filename!r} is not readable."
msgstr "{name} {filename!r} ezin da irakurtzen."

#, python-brace-format
msgid "{name} {filename!r} is not writable."
msgstr "{name} {filename!r} ezin da idatzi."

#, python-brace-format
msgid "{name} {filename!r} is not executable."
msgstr "{name} {filename!r} ez da exekutagarria."

#, python-brace-format
msgid "{len_type} values are required, but {len_value} was given."
msgstr "{len_type} balioak behar dira, baina {len_value} eman da."

#, python-brace-format
msgid "Unknown standard stream '{name}'"
msgstr "\"{name}\" korronte estandar ezezaguna"

msgid "This field is required."
msgstr "Eremu hau beharrezkoa da."

#, python-brace-format
msgid "File does not have an approved extension: {extensions}"
msgstr "Fitxategiak ez du onartutako luzapenik: {extensions}"

msgid "File does not have an approved extension."
msgstr "Fitxategiak ez du onartutako luzapenik."

#, python-brace-format
msgid "File must be between {min_size} and {max_size} bytes."
msgstr "Fitxategiak {min_size} eta {max_size} byte artekoa izan behar du."

#, python-format
msgid "Invalid field name '%s'."
msgstr "'%s' eremu-izen baliogabea."

#, python-format
msgid "Field must be equal to %(other_name)s."
msgstr "Eremuak %(other_name)s-ren berdina izan behar du."

#, python-format
msgid "Field must be at least %(min)d character long."
msgstr "Eremuak %(min)d karaktere izan behar ditu gutxienez."

#, python-format
msgid "Field cannot be longer than %(max)d character."
msgstr "Eremuak ezin du izan %(max)d karaktere baino luzeagoa."

#, python-format
msgid "Field must be exactly %(max)d character long."
msgstr "Eremuak %(max)d karaktere izan behar ditu zehazki."

#, python-format
msgid "Field must be between %(min)d and %(max)d characters long."
msgstr "Eremuak %(min)d eta %(max)d karaktere arteko luzera izan behar du."

#, python-format
msgid "Number must be at least %(min)s."
msgstr "Zenbakiak %(min)s izan behar du gutxienez."

#, python-format
msgid "Number must be at most %(max)s."
msgstr "Gehienez %(max)s izan behar du zenbakiak."

#, python-format
msgid "Number must be between %(min)s and %(max)s."
msgstr "Zenbakiak %(min)s eta %(max)s artean egon behar du."

msgid "Invalid input."
msgstr "Sarrera baliogabea."

msgid "Invalid email address."
msgstr "Helbide elektroniko baliogabea."

msgid "Invalid IP address."
msgstr "IP helbide baliogabea."

msgid "Invalid Mac address."
msgstr "Mac helbide baliogabea."

msgid "Invalid URL."
msgstr "URL baliogabea."

msgid "Invalid UUID."
msgstr "UUID baliogabea."

#, python-format
msgid "Invalid value, must be one of: %(values)s."
msgstr "Balio baliogabea, hauetako bat izan behar du: %(values)s."

#, python-format
msgid "Invalid value, can't be any of: %(values)s."
msgstr "Balio baliogabea, ezin da izan hauetako bat: %(values)s."

msgid "This field cannot be edited."
msgstr "Eremu hau ezin da editatu."

msgid "This field is disabled and cannot have a value."
msgstr "Eremu hau desgaituta dago eta ezin du baliorik izan."

msgid "Invalid CSRF Token."
msgstr "CSRF Token baliogabea."

msgid "CSRF token missing."
msgstr "CSRF tokena falta da."

msgid "CSRF failed."
msgstr "CSRF huts egin du."

msgid "CSRF token expired."
msgstr "CSRF tokena iraungi da."

msgid "Invalid Choice: could not coerce."
msgstr "Aukera baliogabea: ezin izan da behartu."

msgid "Choices cannot be None."
msgstr "Aukerak ezin dira bat ere izan."

msgid "Not a valid choice."
msgstr "Ez da baliozko aukera."

msgid "Invalid choice(s): one or more data inputs could not be coerced."
msgstr "Aukera baliogabeak: ezin izan dira datu sarrera bat edo gehiago behartu."

#, python-format
msgid "'%(value)s' is not a valid choice for this field."
msgstr "'%(value)s' ez da aukera egokia eremu honetarako."

msgid "Not a valid datetime value."
msgstr "Ez da baliozko data-ordu-balioa."

msgid "Not a valid date value."
msgstr "Ez da baliozko data-balioa."

msgid "Not a valid time value."
msgstr "Ez da baliozko denbora-balioa."

msgid "Not a valid week value."
msgstr "Ez da balio asteko balio bat."

msgid "Not a valid integer value."
msgstr "Ez da balio osoko balio bat."

msgid "Not a valid decimal value."
msgstr "Ez da balio hamartar baliorik."

msgid "Not a valid float value."
msgstr "Ez da baliozko balio flotatzailea."

