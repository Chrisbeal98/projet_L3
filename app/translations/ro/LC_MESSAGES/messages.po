#, python-brace-format
msgid "File must be between {min_size} and {max_size} bytes."
msgstr "Fișierul trebuie să aibă între {min_size} și {max_size} octeți."

#, python-format
msgid "Invalid field name '%s'."
msgstr "Nume de câmp nevalid „%s”."

#, python-format
msgid "Field must be equal to %(other_name)s."
msgstr "Câmpul trebuie să fie egal cu %(other_name)s."

#, python-format
msgid "Field must be at least %(min)d character long."
msgstr "Câmpul trebuie să aibă cel puțin %(min)d caractere."

#, python-format
msgid "Field cannot be longer than %(max)d character."
msgstr "Câmpul nu poate fi mai lung de %(max)d caractere."

#, python-format
msgid "Field must be exactly %(max)d character long."
msgstr "Câmpul trebuie să aibă exact %(max)d caractere."

#, python-format
msgid "Field must be between %(min)d and %(max)d characters long."
msgstr "Câmpul trebuie să aibă între %(min)d și %(max)d caractere."

#, python-format
msgid "Number must be at least %(min)s."
msgstr "Numărul trebuie să fie de cel puțin %(min)s."

#, python-format
msgid "Number must be at most %(max)s."
msgstr "Numărul trebuie să fie cel mult %(max)s."

#, python-format
msgid "Number must be between %(min)s and %(max)s."
msgstr "Numărul trebuie să fie între %(min)s și %(max)s."

msgid "Invalid input."
msgstr "Intrare nevalidă."

msgid "Invalid email address."
msgstr "Adresă de e-mail nevalidă."

msgid "Invalid IP address."
msgstr "Adresă IP nevalidă."

msgid "Invalid Mac address."
msgstr "Adresă Mac nevalidă."

msgid "Invalid URL."
msgstr "Adresă URL nevalidă."

msgid "Invalid UUID."
msgstr "UUID nevalid."

#, python-format
msgid "Invalid value, must be one of: %(values)s."
msgstr "Valoare nevalidă, trebuie să fie una dintre: %(values)s."

#, python-format
msgid "Invalid value, can't be any of: %(values)s."
msgstr "Valoare nevalidă, nu poate fi niciuna dintre: %(values)s."

msgid "This field cannot be edited."
msgstr "Acest câmp nu poate fi editat."

msgid "This field is disabled and cannot have a value."
msgstr "Acest câmp este dezactivat și nu poate avea o valoare."

msgid "Invalid CSRF Token."
msgstr "Token CSRF nevalid."

msgid "CSRF token missing."
msgstr "Token CSRF lipsește."

msgid "CSRF failed."
msgstr "CSRF a eșuat."

msgid "CSRF token expired."
msgstr "Indicativul CSRF a expirat."

msgid "Invalid Choice: could not coerce."
msgstr "Alegere nevalidă: nu a putut constrânge."

msgid "Choices cannot be None."
msgstr "Alegerile nu pot fi Niciuna."

msgid "Not a valid choice."
msgstr "Nu este o alegere validă."

msgid "Invalid choice(s): one or more data inputs could not be coerced."
msgstr ""
"Opțiuni nevalide: una sau mai multe intrări de date nu au putut fi "
"forțate."

#, python-format
msgid "'%(value)s' is not a valid choice for this field."
msgstr "„%(value)s” nu este o alegere validă pentru acest câmp."

msgid "Not a valid datetime value."
msgstr "Nu este o valoare de dată și oră validă."

msgid "Not a valid date value."
msgstr "Nu este o valoare de dată validă."

msgid "Not a valid time value."
msgstr "Nu este o valoare de timp validă."

msgid "Not a valid week value."
msgstr "Nu este o valoare de săptămână validă."

msgid "Not a valid integer value."
msgstr "Nu este o valoare întreagă validă."

msgid "Not a valid decimal value."
msgstr "Nu este o valoare zecimală validă."

msgid "Not a valid float value."
msgstr "Nu este o valoare mobilă validă."

