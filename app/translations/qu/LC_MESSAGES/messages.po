msgstr "{value!r} mana {format} nisqawan tupanchu."

#, python-brace-format
msgid "{value!r} is not a valid {number_type}."
msgstr "{valor!r} nisqaqa manam allin {yupay_laya}chu."

#, python-brace-format
msgid "{value} is not in the range {range}."
msgstr "{valor} mana {rango} nisqapichu kachkan."

#, python-brace-format
msgid "{value!r} is not a valid boolean. Recognized values: {states}"
msgstr "{value!r} nisqaqa manam allin booleanchu. Reqsisqa chanikuna: {states}."

#, python-brace-format
msgid "{value!r} is not a valid UUID."
msgstr "{value!r} nisqaqa manam allin UUIDchu."

msgid "file"
msgstr "kipu"

msgid "directory"
msgstr "directorio nisqapi"

msgid "path"
msgstr "ñan"

#, python-brace-format
msgid "{name} {filename!r} does not exist."
msgstr "{suti} {willaqpa sutin!r} mana kanchu."

#, python-brace-format
msgid "{name} {filename!r} is a file."
msgstr "{name} {filename!r} nisqaqa huk willañiqim."

#, python-brace-format
msgid "{name} {filename!r} is a directory."
msgstr "{name} {filename!r} nisqaqa huk willañiqim."

#, python-brace-format
msgid "{name} {filename!r} is not readable."
msgstr "{suti} {filename!r} mana ñawirinapaqchu."

#, python-brace-format
msgid "{name} {filename!r} is not writable."
msgstr "{suti} {filename!r} nisqaqa manam qillqanapaqchu."

#, python-brace-format
msgid "{name} {filename!r} is not executable."
msgstr "{sutin} {willaqpa sutin!r} manam ruranachu."

#, python-brace-format
msgid "{len_type} values are required, but {len_value} was given."
msgstr "{len_type} chanikuna mañasqa, ichataq {len_value} qusqa karqan."

#, python-brace-format
msgid "Unknown standard stream '{name}'"
msgstr "Mana riqsisqa kamachiy mayu '{suti}'."

msgid "This field is required."
msgstr "Kay chakraqa mañasqam."

#, python-brace-format
msgid "File does not have an approved extension: {extensions}"
msgstr "Willañiqiqa manam aprobasqa mast'ariyniyuqchu: {extensions}."

msgid "File does not have an approved extension."
msgstr "Willañiqiqa manam aprobasqa mast'ariyniyuqchu."

#, python-brace-format
msgid "File must be between {min_size} and {max_size} bytes."
msgstr "Willañiqiqa {min_size} chaymanta {max_size} bytekuna chawpipi kanan tiyan."

#, python-format
msgid "Invalid field name '%s'."
msgstr "Mana allin pampa suti '%s'."

#, python-format
msgid "Field must be equal to %(other_name)s."
msgstr "Chakra %(huk_suti)s nisqawan kaqlla kanan tiyan."

#, python-format
msgid "Field must be at least %(min)d character long."
msgstr "Chakraqa %(min)d qillqap sayayninmi kanan."

#, python-format
msgid "Field cannot be longer than %(max)d character."
msgstr "Chakraqa manam %(max)d qillqamanta aswan hatunchu kanman."

#, python-format
msgid "Field must be exactly %(max)d character long."
msgstr "Chakraqa %(max)d qillqap sayayninmi kanan."

#, python-format
msgid "Field must be between %(min)d and %(max)d characters long."
msgstr "Chakraqa %(min)d chaymanta %(max)d qillqakunap chawpinpi kanan tiyan."

#, python-format
msgid "Number must be at least %(min)s."
msgstr "Yupayqa %(min)s nisqallapas kanan."

#, python-format
msgid "Number must be at most %(max)s."
msgstr "Yupayqa aswan %(max)s kanan tiyan."

#, python-format
msgid "Number must be between %(min)s and %(max)s."
msgstr "Yupayqa %(min)s chaymanta %(max)s chawpipi kanan tiyan."

msgid "Invalid input."
msgstr "Mana allin yaykuchiy."

msgid "Invalid email address."
msgstr "Mana allin correo electrónico nisqa."

msgid "Invalid IP address."
msgstr "Mana allin IP tiyay."

msgid "Invalid Mac address."
msgstr "Mana allin Mac direccion."

msgid "Invalid URL."
msgstr "Mana allin URL nisqa."

msgid "Invalid UUID."
msgstr "Mana allin UUID nisqa."

#, python-format
msgid "Invalid value, must be one of: %(values)s."
msgstr "Mana allin chani, hukninmi kanan: %(values)s."

#, python-format
msgid "Invalid value, can't be any of: %(values)s."
msgstr "Mana allin chani, manam mayqinpas kayta atinchu: %(values)s."

msgid "This field cannot be edited."
msgstr "Kay pampaqa manam llamk'achiyta atikunmanchu."

msgid "This field is disabled and cannot have a value."
msgstr "Kay pampaqa mana llamk'achisqam, manam chaniyuq kayta atinchu."

msgid "Invalid CSRF Token."
msgstr "Mana allin CSRF Token."

msgid "CSRF token missing."
msgstr "CSRF token faltasqa."

msgid "CSRF failed."
msgstr "CSRF mana allintachu ruwarqa."

msgid "CSRF token expired."
msgstr "CSRF tokenqa tukusqañam."

msgid "Invalid Choice: could not coerce."
msgstr "Mana allin Akllay: mana obligayta atirqachu."

msgid "Choices cannot be None."
msgstr "Akllaykuna mana kanmanchu Mana imapas."

msgid "Not a valid choice."
msgstr "Mana allin akllakuychu."

msgid "Invalid choice(s): one or more data inputs could not be coerced."
msgstr ""
"Mana allin akllana(kuna): huk icha aswan willay yaykuchiyqa manam "
"kallpachayta atirqanchu."

#, python-format
msgid "'%(value)s' is not a valid choice for this field."
msgstr "'%(value)s' nisqaqa manam allin akllanachu kay pampapaq."

msgid "Not a valid datetime value."
msgstr "Mana allin p'unchaw pacha chanichu."

msgid "Not a valid date value."
msgstr "Mana allin p'unchaw chanichu."

msgid "Not a valid time value."
msgstr "Mana allin pacha chaniyuqchu."

msgid "Not a valid week value."
msgstr "Mana allin semana valorniyuqchu."

msgid "Not a valid integer value."
msgstr "Mana allin hunt'asqa yupay chaniyuqchu."

msgid "Not a valid decimal value."
msgstr "Mana allin chunkayuq chaniyuqchu."

msgid "Not a valid float value."
msgstr "Mana allin flotador chaniyuqchu."

