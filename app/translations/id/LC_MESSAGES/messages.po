msgid "File does not have an approved extension."
msgstr "File tidak memiliki ekstensi yang disetujui."

#, python-brace-format
msgid "File must be between {min_size} and {max_size} bytes."
msgstr "File harus berukuran antara {min_size} dan {max_size} byte."

#, python-format
msgid "Invalid field name '%s'."
msgstr "Nama bidang '%s' tidak valid."

#, python-format
msgid "Field must be equal to %(other_name)s."
msgstr "Bidang harus sama dengan %(nama_lain)s."

#, python-format
msgid "Field must be at least %(min)d character long."
msgstr "Panjang bidang minimal harus %(min)d karakter."

#, python-format
msgid "Field cannot be longer than %(max)d character."
msgstr "Bidang tidak boleh lebih panjang dari %(maks)d karakter."

#, python-format
msgid "Field must be exactly %(max)d character long."
msgstr "Panjang kolom harus tepat %(maks)d karakter."

#, python-format
msgid "Field must be between %(min)d and %(max)d characters long."
msgstr "Panjang kolom harus antara %(min)d dan %(max)d karakter."

#, python-format
msgid "Number must be at least %(min)s."
msgstr "Jumlahnya minimal harus %(mnt)s."

#, python-format
msgid "Number must be at most %(max)s."
msgstr "Jumlahnya harus maksimal %(maks)s."

#, python-format
msgid "Number must be between %(min)s and %(max)s."
msgstr "Angka harus antara %(min)s dan %(max)s."

msgid "Invalid input."
msgstr "Masukan tidak valid."

msgid "Invalid email address."
msgstr "Alamat email tidak valid."

msgid "Invalid IP address."
msgstr "Alamat IP tidak valid."

msgid "Invalid Mac address."
msgstr "Alamat Mac tidak valid."

msgid "Invalid URL."
msgstr "URL tidak valid."

msgid "Invalid UUID."
msgstr "UUID tidak valid."

#, python-format
msgid "Invalid value, must be one of: %(values)s."
msgstr "Nilai tidak valid, harus berupa salah satu dari: %(nilai)s."

#, python-format
msgid "Invalid value, can't be any of: %(values)s."
msgstr "Nilai tidak valid, tidak boleh salah satu dari: %(nilai)s."

msgid "This field cannot be edited."
msgstr "Bidang ini tidak dapat diedit."

msgid "This field is disabled and cannot have a value."
msgstr "Bidang ini dinonaktifkan dan tidak dapat mempunyai nilai."

msgid "Invalid CSRF Token."
msgstr "Token CSRF tidak valid."

msgid "CSRF token missing."
msgstr "Token CSRF hilang."

msgid "CSRF failed."
msgstr "CSRF gagal."

msgid "CSRF token expired."
msgstr "Token CSRF sudah habis masa berlakunya."

msgid "Invalid Choice: could not coerce."
msgstr "Pilihan Tidak Sah: tidak bisa memaksa."

msgid "Choices cannot be None."
msgstr "Pilihan tidak boleh Tidak Ada."

msgid "Not a valid choice."
msgstr "Bukan pilihan yang valid."

msgid "Invalid choice(s): one or more data inputs could not be coerced."
msgstr "Pilihan tidak valid: satu atau lebih input data tidak dapat dipaksakan."

#, python-format
msgid "'%(value)s' is not a valid choice for this field."
msgstr "'%(value)s' bukan pilihan yang valid untuk bidang ini."

msgid "Not a valid datetime value."
msgstr "Bukan nilai tanggalwaktu yang valid."

msgid "Not a valid date value."
msgstr "Bukan nilai tanggal yang valid."

msgid "Not a valid time value."
msgstr "Bukan nilai waktu yang valid."

msgid "Not a valid week value."
msgstr "Bukan nilai minggu yang valid."

msgid "Not a valid integer value."
msgstr "Bukan nilai integer yang valid."

msgid "Not a valid decimal value."
msgstr "Bukan nilai desimal yang valid."

msgid "Not a valid float value."
msgstr "Bukan nilai float yang valid."

