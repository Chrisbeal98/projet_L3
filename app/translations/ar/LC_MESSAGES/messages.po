msgstr "خطأ غير معروف"

#, python-brace-format
msgid "Could not open file {filename!r}: {message}"
msgstr "تعذر فتح الملف {filename!r}: {message}"

msgid "Usage:"
msgstr "يستخدم:"

#, python-brace-format
msgid "Invalid start character for option ({option})"
msgstr "حرف بداية غير صالح للخيار ({option})"

#, python-brace-format
msgid "Argument {name!r} takes {nargs} values."
msgstr "الوسيطة {name!r} تأخذ قيم {nargs}."

#, python-brace-format
msgid "Option {name!r} does not take a value."
msgstr "الخيار {name!r} لا يأخذ قيمة."

#, python-brace-format
msgid "Option {name!r} requires an argument."
msgstr "يتطلب الخيار {name!r} وسيطة."

msgid "Shell completion is not supported for Bash versions older than 4.4."
msgstr "إكمال Shell غير مدعوم لإصدارات Bash الأقدم من 4.4."

msgid "Couldn't detect Bash version, shell completion is not supported."
msgstr "تعذر اكتشاف إصدار Bash، وإكمال الصدفة غير مدعوم."

msgid "Repeat for confirmation"
msgstr "كرر للتأكيد"

msgid "Error: The two entered values do not match."
msgstr "خطأ: القيمتان المدخلتان غير متطابقتين."

msgid "Error: invalid input"
msgstr "خطأ: إدخال غير صالح"

#, python-brace-format
msgid "Unknown color {colour!r}"
msgstr "لون غير معروف {color!r}"

msgid "Press any key to continue..."
msgstr "اضغط على أي مفتاح للمتابعة..."

#, python-brace-format
msgid "Choose from:\\n\\t{choices}"
msgstr "اختر من:\\n\\t{الاختيارات}"

#, python-brace-format
msgid "{value!r} is not {choice}."
msgstr "{value!r} ليس {choice}."

#, python-brace-format
msgid "Choice({choices})"
msgstr "الاختيار({الاختيارات})"

#, python-brace-format
msgid "{value!r} does not match the format {format}."
msgstr "{value!r} لا يتطابق مع التنسيق {format}."

#, python-brace-format
msgid "{value!r} is not a valid {number_type}."
msgstr "{value!r} ليس {number_type} صالحًا."

#, python-brace-format
msgid "{value} is not in the range {range}."
msgstr "{القيمة} ليست في النطاق {النطاق}."

#, python-brace-format
msgid "{value!r} is not a valid boolean. Recognized values: {states}"
msgstr "{value!r} ليس قيمة منطقية صالحة. القيم المعترف بها: {الحالات}"

#, python-brace-format
msgid "{value!r} is not a valid UUID."
msgstr "{value!r} ليس UUID صالحًا."

msgid "file"
msgstr "ملف"

msgid "directory"
msgstr "دليل"

msgid "path"
msgstr "طريق"

#, python-brace-format
msgid "{name} {filename!r} does not exist."
msgstr "{name} {filename!r} غير موجود."

#, python-brace-format
msgid "{name} {filename!r} is a file."
msgstr "{name} {filename!r} هو ملف."

#, python-brace-format
msgid "{name} {filename!r} is a directory."
msgstr "{name} {filename!r} هو دليل."

#, python-brace-format
msgid "{name} {filename!r} is not readable."
msgstr "{name} {filename!r} غير قابل للقراءة."

#, python-brace-format
msgid "{name} {filename!r} is not writable."
msgstr "{name} {filename!r} غير قابل للكتابة."

#, python-brace-format
msgid "{name} {filename!r} is not executable."
msgstr "{name} {filename!r} غير قابل للتنفيذ."

#, python-brace-format
msgid "{len_type} values are required, but {len_value} was given."
msgstr "قيم {len_type} مطلوبة، ولكن تم تقديم {len_value}."

#, python-brace-format
msgid "Unknown standard stream '{name}'"
msgstr "دفق قياسي غير معروف '{name}'"

msgid "This field is required."
msgstr "هذه الخانة مطلوبه."

#, python-brace-format
msgid "File does not have an approved extension: {extensions}"
msgstr "الملف ليس له امتداد معتمد: {extensions}"

msgid "File does not have an approved extension."
msgstr "الملف ليس له امتداد معتمد."

#, python-brace-format
msgid "File must be between {min_size} and {max_size} bytes."
msgstr "يجب أن يتراوح حجم الملف بين {min_size} و{max_size} بايت."

#, python-format
msgid "Invalid field name '%s'."
msgstr "اسم الحقل '%s' غير صالح."

#, python-format
msgid "Field must be equal to %(other_name)s."
msgstr "يجب أن يكون الحقل مساويًا لـ %(other_name)s."

#, python-format
msgid "Field must be at least %(min)d character long."
msgstr "يجب أن يكون طول الحقل %(min)d حرفًا على الأقل."

#, python-format
msgid "Field cannot be longer than %(max)d character."
msgstr "لا يمكن أن يكون الحقل أطول من %(max)d حرف."

#, python-format
msgid "Field must be exactly %(max)d character long."
msgstr "يجب أن يبلغ طول الحقل %(max)d حرفًا بالضبط."

#, python-format
msgid "Field must be between %(min)d and %(max)d characters long."
msgstr "يجب أن يتراوح طول الحقل بين %(min)d و%(max)d من الأحرف."

#, python-format
msgid "Number must be at least %(min)s."
msgstr "يجب أن يكون الرقم %(min)s على الأقل."

#, python-format
msgid "Number must be at most %(max)s."
msgstr "يجب أن يكون الرقم %(max)s على الأكثر."

#, python-format
msgid "Number must be between %(min)s and %(max)s."
msgstr "يجب أن يكون الرقم بين %(min)s و%(max)s."

msgid "Invalid input."
msgstr "إدخال غير صالح."

msgid "Invalid email address."
msgstr "عنوان البريد الإلكتروني غير صالح."

msgid "Invalid IP address."
msgstr "عنوان IP غير صالح."

msgid "Invalid Mac address."
msgstr "عنوان ماك غير صالح."

msgid "Invalid URL."
msgstr "عنوان URL غير صالح."

msgid "Invalid UUID."
msgstr "UUID غير صالح."

#, python-format
msgid "Invalid value, must be one of: %(values)s."
msgstr "قيمة غير صالحة، يجب أن تكون واحدة من: %(values)s."

#, python-format
msgid "Invalid value, can't be any of: %(values)s."
msgstr "قيمة غير صالحة، لا يمكن أن تكون أيًا من: %(values)s."

msgid "This field cannot be edited."
msgstr "لا يمكن تحرير هذا الحقل."

msgid "This field is disabled and cannot have a value."
msgstr "هذا الحقل معطل ولا يمكن أن يكون له قيمة."

msgid "Invalid CSRF Token."
msgstr "رمز CSRF غير صالح."

msgid "CSRF token missing."
msgstr "رمز CSRF مفقود."

msgid "CSRF failed."
msgstr "فشل CSRF."

msgid "CSRF token expired."
msgstr "انتهت صلاحية رمز CSRF."

msgid "Invalid Choice: could not coerce."
msgstr "اختيار غير صالح: لا يمكن الإكراه."

msgid "Choices cannot be None."
msgstr "لا يمكن أن تكون الاختيارات بلا."

msgid "Not a valid choice."
msgstr "ليس خيارا صالحا."

msgid "Invalid choice(s): one or more data inputs could not be coerced."
msgstr "اختيار (اختيارات) غير صالحة: لا يمكن فرض إدخال بيانات واحد أو أكثر."

#, python-format
msgid "'%(value)s' is not a valid choice for this field."
msgstr "إن '%(value)s' ليس اختيارًا صالحًا لهذا الحقل."

msgid "Not a valid datetime value."
msgstr "ليست قيمة تاريخ/وقت صالحة."

msgid "Not a valid date value."
msgstr "ليست قيمة تاريخ صالحة."

msgid "Not a valid time value."
msgstr "ليست قيمة زمنية صالحة."

msgid "Not a valid week value."
msgstr "ليست قيمة أسبوع صالحة."

msgid "Not a valid integer value."
msgstr "ليست قيمة عددية صالحة."

msgid "Not a valid decimal value."
msgstr "ليست قيمة عشرية صالحة."

msgid "Not a valid float value."
msgstr "ليست قيمة عائمة صالحة."

