msgstr "Sayan lawak so nakaukolan."

#, python-brace-format
msgid "File does not have an approved extension: {extensions}"
msgstr "Say file et anggapoy naaprobaan ya extension: {extensions}"

msgid "File does not have an approved extension."
msgstr "Say file et anggapoy naaprobaan ya extension to."

#, python-brace-format
msgid "File must be between {min_size} and {max_size} bytes."
msgstr "Say file et nepeg ya walad baetan na {min_size} tan {max_size} bytes."

#, python-format
msgid "Invalid field name '%s'."
msgstr "Aliwan duga so ngaran na field ya '%s'."

#, python-format
msgid "Field must be equal to %(other_name)s."
msgstr "Say field et nepeg ya mipara ed %(other_name)s."

#, python-format
msgid "Field must be at least %(min)d character long."
msgstr "Say field et nepeg ya ag-onkulang ed %(min)d ya karakter so karukey to."

#, python-format
msgid "Field cannot be longer than %(max)d character."
msgstr "Say field et ag nayarin onlampas ed %(max)d ya karakter."

#, python-format
msgid "Field must be exactly %(max)d character long."
msgstr "Say field et nepeg ya eksakton %(max)d ya karakter so karukey to."

#, python-format
msgid "Field must be between %(min)d and %(max)d characters long."
msgstr ""
"Say field et nepeg ya walad baetan na %(min)d anggad %(max)d ya karakter "
"so karukey to."

#, python-format
msgid "Number must be at least %(min)s."
msgstr "Say bilang et nepeg ya ag-onkulang ed %(min)s."

#, python-format
msgid "Number must be at most %(max)s."
msgstr "Say bilang et nepeg ya ag-onsulok ed %(max)s."

#, python-format
msgid "Number must be between %(min)s and %(max)s."
msgstr "Say bilang et nepeg ya walad baetan na %(min)s tan %(max)s."

msgid "Invalid input."
msgstr "Aliwan duga so input."

msgid "Invalid email address."
msgstr "Aliwan duga so email address."

msgid "Invalid IP address."
msgstr "Aliwan duga so IP address."

msgid "Invalid Mac address."
msgstr "Aliwan duga so Mac address."

msgid "Invalid URL."
msgstr "Aliwan duga so URL."

msgid "Invalid UUID."
msgstr "Aliwan duga so UUID."

#, python-format
msgid "Invalid value, must be one of: %(values)s."
msgstr "Aliwan duga so balor, nepeg ya sakey ed: %(values)s."

#, python-format
msgid "Invalid value, can't be any of: %(values)s."
msgstr "Aliwan duga so balor, agnayarin anggan dinan ed: %(values)s."

msgid "This field cannot be edited."
msgstr "Sayan lawak et ag nayarin i-edit."

msgid "This field is disabled and cannot have a value."
msgstr "Sayan field et ag-onkikiwas tan anggapoy balor to."

msgid "Invalid CSRF Token."
msgstr "Aliwan balido so CSRF Token."

msgid "CSRF token missing."
msgstr "Anggapoy CSRF token."

msgid "CSRF failed."
msgstr "Ag tinmalona so CSRF."

msgid "CSRF token expired."
msgstr "Say CSRF token et asumpal la."

msgid "Invalid Choice: could not coerce."
msgstr "Aliwan duga so pinili: ag nayarin piliten."

msgid "Choices cannot be None."
msgstr "Saray pilien et agnayarin Anggapo."

msgid "Not a valid choice."
msgstr "Aliwan balido so pilien."

msgid "Invalid choice(s): one or more data inputs could not be coerced."
msgstr ""
"Aliwan duga so pilien: sakey odino masulok nin data inputs so ag nayarin "
"piliten."

#, python-format
msgid "'%(value)s' is not a valid choice for this field."
msgstr "Say '%(value)s' et aliwan balidon pilien parad sayan lawak."

msgid "Not a valid datetime value."
msgstr "Aliwan balido so datetime ya balor."

msgid "Not a valid date value."
msgstr "Aliwan balido so petsa."

msgid "Not a valid time value."
msgstr "Aliwan balido so balor na panaon."

msgid "Not a valid week value."
msgstr "Aliwan balido so balor na simba."

msgid "Not a valid integer value."
msgstr "Aliwan balido so bilang na integer."

msgid "Not a valid decimal value."
msgstr "Aliwan balido so decimal value."

msgid "Not a valid float value."
msgstr "Aliwan balido so float value."

