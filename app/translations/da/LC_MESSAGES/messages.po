msgstr "Feltet skal være mellem %(min)d og %(max)d tegn langt."

#, python-format
msgid "Number must be at least %(min)s."
msgstr "Antallet skal være mindst %(min)s."

#, python-format
msgid "Number must be at most %(max)s."
msgstr "Antallet må højst være %(max)s."

#, python-format
msgid "Number must be between %(min)s and %(max)s."
msgstr "Antallet skal være mellem %(min)s og %(max)s."

msgid "Invalid input."
msgstr "Ugyldigt input."

msgid "Invalid email address."
msgstr "Ugyldig e-mailadresse."

msgid "Invalid IP address."
msgstr "Ugyldig IP-adresse."

msgid "Invalid Mac address."
msgstr "Ugyldig Mac-adresse."

msgid "Invalid URL."
msgstr "Ugyldig URL."

msgid "Invalid UUID."
msgstr "Ugyldigt UUID."

#, python-format
msgid "Invalid value, must be one of: %(values)s."
msgstr "Ugyldig værdi, skal være en af: %(values)s."

#, python-format
msgid "Invalid value, can't be any of: %(values)s."
msgstr "Ugyldig værdi, kan ikke være nogen af: %(values)s."

msgid "This field cannot be edited."
msgstr "Dette felt kan ikke redigeres."

msgid "This field is disabled and cannot have a value."
msgstr "Dette felt er deaktiveret og kan ikke have en værdi."

msgid "Invalid CSRF Token."
msgstr "Ugyldigt CSRF-token."

msgid "CSRF token missing."
msgstr "CSRF-token mangler."

msgid "CSRF failed."
msgstr "CSRF mislykkedes."

msgid "CSRF token expired."
msgstr "CSRF-token er udløbet."

msgid "Invalid Choice: could not coerce."
msgstr "Ugyldigt valg: kunne ikke tvinge."

msgid "Choices cannot be None."
msgstr "Valg kan ikke være Ingen."

msgid "Not a valid choice."
msgstr "Ikke et gyldigt valg."

msgid "Invalid choice(s): one or more data inputs could not be coerced."
msgstr "Ugyldige valg: et eller flere datainput kunne ikke tvinges."

#, python-format
msgid "'%(value)s' is not a valid choice for this field."
msgstr "'%(value)s' er ikke et gyldigt valg for dette felt."

msgid "Not a valid datetime value."
msgstr "Ikke en gyldig datetime-værdi."

msgid "Not a valid date value."
msgstr "Ikke en gyldig datoværdi."

msgid "Not a valid time value."
msgstr "Ikke en gyldig tidsværdi."

msgid "Not a valid week value."
msgstr "Ikke en gyldig ugeværdi."

msgid "Not a valid integer value."
msgstr "Ikke en gyldig heltalsværdi."

msgid "Not a valid decimal value."
msgstr "Ikke en gyldig decimalværdi."

msgid "Not a valid float value."
msgstr "Ikke en gyldig flydende værdi."

