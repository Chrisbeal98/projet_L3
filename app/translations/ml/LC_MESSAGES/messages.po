#, python-brace-format
msgid "{value!r} is not {choice}."
msgstr "{value!r} എന്നത് {choice} അല്ല."

#, python-brace-format
msgid "Choice({choices})"
msgstr "ചോയ്‌സ്({choices})"

#, python-brace-format
msgid "{value!r} does not match the format {format}."
msgstr "{value!r} ഫോർമാറ്റുമായി പൊരുത്തപ്പെടുന്നില്ല {format}."

#, python-brace-format
msgid "{value!r} is not a valid {number_type}."
msgstr "{value!r} ഒരു സാധുവായ {number_type} അല്ല."

#, python-brace-format
msgid "{value} is not in the range {range}."
msgstr "{value} എന്നത് {range} എന്ന ശ്രേണിയിലല്ല."

#, python-brace-format
msgid "{value!r} is not a valid boolean. Recognized values: {states}"
msgstr "{value!r} ഒരു സാധുവായ ബൂളിയൻ അല്ല. അംഗീകൃത മൂല്യങ്ങൾ: {states}"

#, python-brace-format
msgid "{value!r} is not a valid UUID."
msgstr "{value!r} ഒരു സാധുവായ UUID അല്ല."

msgid "file"
msgstr "ഫയൽ"

msgid "directory"
msgstr "ഡയറക്ടറി"

msgid "path"
msgstr "പാത"

#, python-brace-format
msgid "{name} {filename!r} does not exist."
msgstr "{name} {filename!r} നിലവിലില്ല."

#, python-brace-format
msgid "{name} {filename!r} is a file."
msgstr "{name} {filename!r} ഒരു ഫയലാണ്."

#, python-brace-format
msgid "{name} {filename!r} is a directory."
msgstr "{name} {filename!r} ഒരു ഡയറക്ടറിയാണ്."

#, python-brace-format
msgid "{name} {filename!r} is not readable."
msgstr "{name} {filename!r} വായിക്കാൻ കഴിയില്ല."

#, python-brace-format
msgid "{name} {filename!r} is not writable."
msgstr "{name} {filename!r} എന്നത് എഴുതാനാകില്ല."

#, python-brace-format
msgid "{name} {filename!r} is not executable."
msgstr "{name} {filename!r} എക്സിക്യൂട്ടബിൾ അല്ല."

#, python-brace-format
msgid "{len_type} values are required, but {len_value} was given."
msgstr "{len_type} മൂല്യങ്ങൾ ആവശ്യമാണ്, എന്നാൽ {len_value} നൽകിയിട്ടുണ്ട്."

#, python-brace-format
msgid "Unknown standard stream '{name}'"
msgstr "അജ്ഞാത സ്റ്റാൻഡേർഡ് സ്ട്രീം '{name}'"

msgid "This field is required."
msgstr "ഈ ഫീൽഡ് പൂരിപ്പിക്കേണ്ടതുണ്ട്."

#, python-brace-format
msgid "File does not have an approved extension: {extensions}"
msgstr "ഫയലിന് അംഗീകൃത വിപുലീകരണം ഇല്ല: {extensions}"

msgid "File does not have an approved extension."
msgstr "ഫയലിന് അംഗീകൃത വിപുലീകരണമില്ല."

#, python-brace-format
msgid "File must be between {min_size} and {max_size} bytes."
msgstr "ഫയൽ {min_size} നും {max_size} ബൈറ്റുകൾക്കും ഇടയിലായിരിക്കണം."

#, python-format
msgid "Invalid field name '%s'."
msgstr "'%s' എന്ന ഫീൽഡ് നാമം അസാധുവാണ്."

#, python-format
msgid "Field must be equal to %(other_name)s."
msgstr "ഫീൽഡ് %(other_name)s-ന് തുല്യമായിരിക്കണം."

#, python-format
msgid "Field must be at least %(min)d character long."
msgstr "ഫീൽഡിന് കുറഞ്ഞത് %(മിനിറ്റ്)d പ്രതീകമെങ്കിലും ദൈർഘ്യമുണ്ടായിരിക്കണം."

#, python-format
msgid "Field cannot be longer than %(max)d character."
msgstr "ഫീൽഡ് %(max)d പ്രതീകത്തിൽ കൂടുതലാകരുത്."

#, python-format
msgid "Field must be exactly %(max)d character long."
msgstr "ഫീൽഡ് കൃത്യമായി %(max)d പ്രതീകം ആയിരിക്കണം."

#, python-format
msgid "Field must be between %(min)d and %(max)d characters long."
msgstr "ഫീൽഡ് %(min)d, %(max)d എന്നീ അക്ഷരങ്ങൾക്കിടയിലായിരിക്കണം."

#, python-format
msgid "Number must be at least %(min)s."
msgstr "സംഖ്യ കുറഞ്ഞത് %(മിനിറ്റ്) ആയിരിക്കണം."

#, python-format
msgid "Number must be at most %(max)s."
msgstr "സംഖ്യ പരമാവധി %(പരമാവധി) ആയിരിക്കണം."

#, python-format
msgid "Number must be between %(min)s and %(max)s."
msgstr "നമ്പർ %(min)s നും %(max)s നും ഇടയിലായിരിക്കണം."

msgid "Invalid input."
msgstr "അസാധുവായ ഇൻപുട്ട്."

msgid "Invalid email address."
msgstr "ഇമെയിൽ വിലാസം അസാധുവാണ്."

msgid "Invalid IP address."
msgstr "അസാധുവായ IP വിലാസം."

msgid "Invalid Mac address."
msgstr "അസാധുവായ Mac വിലാസം."

msgid "Invalid URL."
msgstr "അസാധുവായ URL."

msgid "Invalid UUID."
msgstr "UUID അസാധുവാണ്."

#, python-format
msgid "Invalid value, must be one of: %(values)s."
msgstr "അസാധുവായ മൂല്യം, ഇവയിൽ ഒന്നായിരിക്കണം: %(values)s."

#, python-format
msgid "Invalid value, can't be any of: %(values)s."
msgstr "മൂല്യം അസാധുവാണ്, ഇതിൽ ഏതെങ്കിലും ആയിരിക്കരുത്: %(values)s."

msgid "This field cannot be edited."
msgstr "ഈ ഫീൽഡ് എഡിറ്റ് ചെയ്യാൻ കഴിയില്ല."

msgid "This field is disabled and cannot have a value."
msgstr "ഈ ഫീൽഡ് പ്രവർത്തനരഹിതമാക്കിയതിനാൽ ഒരു മൂല്യം ഉണ്ടായിരിക്കില്ല."

msgid "Invalid CSRF Token."
msgstr "അസാധുവായ CSRF ടോക്കൺ."

msgid "CSRF token missing."
msgstr "CSRF ടോക്കൺ കാണുന്നില്ല."

msgid "CSRF failed."
msgstr "CSRF പരാജയപ്പെട്ടു."

msgid "CSRF token expired."
msgstr "CSRF ടോക്കൺ കാലഹരണപ്പെട്ടു."

msgid "Invalid Choice: could not coerce."
msgstr "അസാധുവായ ചോയ്‌സ്: നിർബന്ധിക്കാൻ കഴിഞ്ഞില്ല."

msgid "Choices cannot be None."
msgstr "ചോയ്‌സുകൾ ഒന്നും ആവരുത്."

msgid "Not a valid choice."
msgstr "സാധുവായ ഒരു തിരഞ്ഞെടുപ്പല്ല."

msgid "Invalid choice(s): one or more data inputs could not be coerced."
msgstr ""
"അസാധുവായ ചോയ്‌സ്(കൾ): ഒന്നോ അതിലധികമോ ഡാറ്റ ഇൻപുട്ടുകൾ നിർബന്ധിതമാക്കാൻ "
"കഴിഞ്ഞില്ല."

#, python-format
msgid "'%(value)s' is not a valid choice for this field."
msgstr "'%(value)s' ഈ ഫീൽഡിനുള്ള സാധുവായ ചോയിസല്ല."

msgid "Not a valid datetime value."
msgstr "സാധുവായ തീയതി സമയ മൂല്യമല്ല."

msgid "Not a valid date value."
msgstr "സാധുവായ തീയതി മൂല്യമല്ല."

msgid "Not a valid time value."
msgstr "സാധുവായ സമയ മൂല്യമല്ല."

msgid "Not a valid week value."
msgstr "സാധുവായ ആഴ്‌ച മൂല്യമല്ല."

msgid "Not a valid integer value."
msgstr "സാധുവായ ഒരു പൂർണ്ണസംഖ്യ മൂല്യമല്ല."

msgid "Not a valid decimal value."
msgstr "സാധുവായ ദശാംശ മൂല്യമല്ല."

msgid "Not a valid float value."
msgstr "സാധുതയുള്ള ഫ്ലോട്ട് മൂല്യമല്ല."

