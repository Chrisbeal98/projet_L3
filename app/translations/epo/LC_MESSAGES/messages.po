msgid "This field is required."
msgstr "Ĉi tiu kampo estas postulata."

#, python-brace-format
msgid "File does not have an approved extension: {extensions}"
msgstr "Dosiero ne havas aprobitan etendon: {extensions}"

msgid "File does not have an approved extension."
msgstr "Dosiero ne havas aprobitan etendon."

#, python-brace-format
msgid "File must be between {min_size} and {max_size} bytes."
msgstr "Dosiero devas esti inter {min_size} kaj {max_size} bajtoj."

#, python-format
msgid "Invalid field name '%s'."
msgstr "Nevalida kamponomo '%s'."

#, python-format
msgid "Field must be equal to %(other_name)s."
msgstr "Kampo devas esti egala al %(other_name)s."

#, python-format
msgid "Field must be at least %(min)d character long."
msgstr "Kampo devas havi almenaŭ %(min)d signojn longa."

#, python-format
msgid "Field cannot be longer than %(max)d character."
msgstr "Kampo ne povas esti pli longa ol %(max)d signo."

#, python-format
msgid "Field must be exactly %(max)d character long."
msgstr "Kampo devas havi precize %(max)d signojn longa."

#, python-format
msgid "Field must be between %(min)d and %(max)d characters long."
msgstr "Kampo devas havi inter %(min)d kaj %(max)d signojn longa."

#, python-format
msgid "Number must be at least %(min)s."
msgstr "Nombro devas esti almenaŭ %(min)s."

#, python-format
msgid "Number must be at most %(max)s."
msgstr "Nombro devas esti maksimume %(max)s."

#, python-format
msgid "Number must be between %(min)s and %(max)s."
msgstr "Nombro devas esti inter %(min)s kaj %(max)s."

msgid "Invalid input."
msgstr "Nevalida enigo."

msgid "Invalid email address."
msgstr "Nevalida retadreso."

msgid "Invalid IP address."
msgstr "Nevalida IP-adreso."

msgid "Invalid Mac address."
msgstr "Nevalida Mac-adreso."

msgid "Invalid URL."
msgstr "Nevalida URL."

msgid "Invalid UUID."
msgstr "Nevalida UUID."

#, python-format
msgid "Invalid value, must be one of: %(values)s."
msgstr "Nevalida valoro, devas esti unu el: %(values)s."

#, python-format
msgid "Invalid value, can't be any of: %(values)s."
msgstr "Nevalida valoro, ne povas esti iu el: %(values)s."

msgid "This field cannot be edited."
msgstr "Ĉi tiu kampo ne povas esti redaktita."

msgid "This field is disabled and cannot have a value."
msgstr "Ĉi tiu kampo estas malŝaltita kaj ne povas havi valoron."

msgid "Invalid CSRF Token."
msgstr "Nevalida CSRF-Token."

msgid "CSRF token missing."
msgstr "CSRF-ĵetono mankas."

msgid "CSRF failed."
msgstr "CSRF malsukcesis."

msgid "CSRF token expired."
msgstr "CSRF-ĵetono eksvalidiĝis."

msgid "Invalid Choice: could not coerce."
msgstr "Nevalida Elekto: ne povis devigi."

msgid "Choices cannot be None."
msgstr "Elektoj ne povas esti Neniuj."

msgid "Not a valid choice."
msgstr "Ne valida elekto."

msgid "Invalid choice(s): one or more data inputs could not be coerced."
msgstr ""
"Nevalida(j) elekto(j): unu aŭ pluraj datenenigaĵoj ne povis esti "
"devigitaj."

#, python-format
msgid "'%(value)s' is not a valid choice for this field."
msgstr "'%(value)s' ne estas valida elekto por ĉi tiu kampo."

msgid "Not a valid datetime value."
msgstr "Ne valida dattempa valoro."

msgid "Not a valid date value."
msgstr "Ne valida datvaloro."

msgid "Not a valid time value."
msgstr "Ne valida tempovaloro."

msgid "Not a valid week value."
msgstr "Ne valida semajna valoro."

msgid "Not a valid integer value."
msgstr "Ne valida entjera valoro."

msgid "Not a valid decimal value."
msgstr "Ne valida dekuma valoro."

msgid "Not a valid float value."
msgstr "Ne valida flosvaloro."

