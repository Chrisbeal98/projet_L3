#, python-brace-format
msgid "{name} {filename!r} does not exist."
msgstr "{ishina} {ishina lya failo!r} talipo."

#, python-brace-format
msgid "{name} {filename!r} is a file."
msgstr "{ishina} {ishina lya failo!r} ni failo."

#, python-brace-format
msgid "{name} {filename!r} is a directory."
msgstr "{ishina} {ishina lya failo!r} ni citabo."

#, python-brace-format
msgid "{name} {filename!r} is not readable."
msgstr "{ishina} {ishina lya failo!r} talyabelenga."

#, python-brace-format
msgid "{name} {filename!r} is not writable."
msgstr "{ishina} {ishina lya failo!r} talyalembelwe."

#, python-brace-format
msgid "{name} {filename!r} is not executable."
msgstr "{ishina} {ishina lya failo!r} tekuti libomfiwe."

#, python-brace-format
msgid "{len_type} values are required, but {len_value} was given."
msgstr ""
"{umusango_wa_len} imitantikile ilefwaikwa, lelo {umutengo_uwa_len} "
"walipeelwe."

#, python-brace-format
msgid "Unknown standard stream '{name}'"
msgstr "Umumana uushaishibikwa '{ishina}'"

msgid "This field is required."
msgstr "Iyi incende ilafwaikwa."

#, python-brace-format
msgid "File does not have an approved extension: {extensions}"
msgstr "Fayelo tayakwata icakukonkanyapo icasuminishiwa: {ifyakukonkanyapo}"

msgid "File does not have an approved extension."
msgstr "Fayelo tayakwata ukulundako ukwasuminishiwa."

#, python-brace-format
msgid "File must be between {min_size} and {max_size} bytes."
msgstr ""
"Fayelo ilingile ukuba pakati ka {ubukulu_ubunono} na {ubukulu_ubukulu} "
"amabaiti."

#, python-format
msgid "Invalid field name '%s'."
msgstr "Ishina lya cifulo ilyashilinga '%s'."

#, python-format
msgid "Field must be equal to %(other_name)s."
msgstr "Iciputulwa cifwile ukulingana na %(ishina_limbi)s."

#, python-format
msgid "Field must be at least %(min)d character long."
msgstr "Iciputulwa cifwile ukuba ukufika kuli %(min)d ubutali bwa cishibilo."

#, python-format
msgid "Field cannot be longer than %(max)d character."
msgstr "Iciputulwa tekuti cibe icitali ukucila %(max)d icilangililo."

#, python-format
msgid "Field must be exactly %(max)d character long."
msgstr "Iciputulwa cifwile ukuba %(max)d ubutali bwa cishibilo."

#, python-format
msgid "Field must be between %(min)d and %(max)d characters long."
msgstr ""
"Iciputulwa cifwile ukuba pakati ka %(min)d na %(ukucilapo)d ubutali bwa "
"fishibilo."

#, python-format
msgid "Number must be at least %(min)s."
msgstr "Impendwa ilingile ukuba ukucepako %(min)s."

#, python-format
msgid "Number must be at most %(max)s."
msgstr "Impendwa ilingile ukuba ukucila pali %(ukucila)s."

#, python-format
msgid "Number must be between %(min)s and %(max)s."
msgstr "Impendwa ilingile ukuba pakati ka %(min)s na %(ukucilapo)s."

msgid "Invalid input."
msgstr "Ifya kwingilishamo ifishalinga."

msgid "Invalid email address."
msgstr "Akeyala ka email akashibomba."

msgid "Invalid IP address."
msgstr "Akeyala ka IP akashibomba."

msgid "Invalid Mac address."
msgstr "Akeyala ka Mac akashibomba."

msgid "Invalid URL."
msgstr "URL iyishilebomba."

msgid "Invalid UUID."
msgstr "UUID iyashibomba."

#, python-format
msgid "Invalid value, must be one of: %(values)s."
msgstr "Umutengo uushalinga, ufwile ukuba umo uwa: %(imitengo)s."

#, python-format
msgid "Invalid value, can't be any of: %(values)s."
msgstr "Umutengo uushalinga, tekuti ube nangu umo uwa: %(imitengo)s."

msgid "This field cannot be edited."
msgstr "Iyi incende tekuti ipilibulwe."

msgid "This field is disabled and cannot have a value."
msgstr "Iyi incende tayabomba kabili tekuti ibe no mutengo."

msgid "Invalid CSRF Token."
msgstr "Icilangililo ca CSRF icishili icalinga."

msgid "CSRF token missing."
msgstr "Icilangililo ca CSRF tacilubile."

msgid "CSRF failed."
msgstr "CSRF yalifililwe."

msgid "CSRF token expired."
msgstr "Icilangililo ca CSRF capwa."

msgid "Invalid Choice: could not coerce."
msgstr "Ukusala ukwabula bwino: tekuti kupatikishe."

msgid "Choices cannot be None."
msgstr "Ifyakusalapo tekuti fibe Ukwabula."

msgid "Not a valid choice."
msgstr "Takuli ukusala ukwalinga."

msgid "Invalid choice(s): one or more data inputs could not be coerced."
msgstr ""
"Ifyakusalapo ifishili bwino: cimo nangu ifingi ifyabikwamo tekuti "
"fipatikishiwe."

#, python-format
msgid "'%(value)s' is not a valid choice for this field."
msgstr "'%(umutengo)s' te kusalapo ukwalinga kuli iyi incende."

msgid "Not a valid datetime value."
msgstr "Tacili umutengo wa bushiku uwalinga."

msgid "Not a valid date value."
msgstr "Tacili umutengo wa bushiku uwalinga."

msgid "Not a valid time value."
msgstr "Tacili umutengo wa nshita uwalinga."

msgid "Not a valid week value."
msgstr "Tacili umutengo wa mulungu uwalinga."

msgid "Not a valid integer value."
msgstr "Tacili umutengo wa namba uwalinga."

msgid "Not a valid decimal value."
msgstr "Tacili umutengo wa cikumi uwalinga."

msgid "Not a valid float value."
msgstr "Tacili umutengo wa float uwalinga."

