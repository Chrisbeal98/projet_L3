msgstr "{umutengo!r} te {ukusalapo}."

#, python-brace-format
msgid "Choice({choices})"
msgstr "Ifyakusalapo({ifyakusalapo})"

#, python-brace-format
msgid "{value!r} does not match the format {format}."
msgstr "{umutengo!r} taulingana ne mipangilwe {imipangile}."

