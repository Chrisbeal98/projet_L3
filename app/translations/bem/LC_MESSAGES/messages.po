msgid "{value!r} is not a valid {number_type}."
msgstr "{umutengo!r} tekuti ube uwalinga {umusango_wa_namba}."

#, python-brace-format
msgid "{value} is not in the range {range}."
msgstr "{umutengo} tauli mu cipimo {umusango}."

#, python-brace-format
msgid "{value!r} is not a valid boolean. Recognized values: {states}"
msgstr "{umutengo!r} te cishinka icalinga. Imitengo iyaishibikwa: {amabuteko}"

