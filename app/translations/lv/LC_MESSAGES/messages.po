msgstr "{value!r} nav derīgs {number_type}."

#, python-brace-format
msgid "{value} is not in the range {range}."
msgstr "{value} nav diapazonā {range}."

#, python-brace-format
msgid "{value!r} is not a valid boolean. Recognized values: {states}"
msgstr "{value!r} nav derīga Būla vērtība. Atzītās vērtības: {states}"

#, python-brace-format
msgid "{value!r} is not a valid UUID."
msgstr "{value!r} nav derīgs UUID."

msgid "file"
msgstr "failu"

msgid "directory"
msgstr "direktoriju"

msgid "path"
msgstr "ceļš"

#, python-brace-format
msgid "{name} {filename!r} does not exist."
msgstr "{name} {filename!r} nepastāv."

#, python-brace-format
msgid "{name} {filename!r} is a file."
msgstr "{name} {filename!r} ir fails."

#, python-brace-format
msgid "{name} {filename!r} is a directory."
msgstr "{name} {filename!r} ir direktorijs."

#, python-brace-format
msgid "{name} {filename!r} is not readable."
msgstr "{name} {filename!r} nav lasāms."

#, python-brace-format
msgid "{name} {filename!r} is not writable."
msgstr "{name} {filename!r} nav rakstāms."

#, python-brace-format
msgid "{name} {filename!r} is not executable."
msgstr "{name} {filename!r} nav izpildāms."

#, python-brace-format
msgid "{len_type} values are required, but {len_value} was given."
msgstr "Ir nepieciešamas {len_type} vērtības, taču tika dota {len_value}."

#, python-brace-format
msgid "Unknown standard stream '{name}'"
msgstr "Nezināma standarta straume “{name}”"

msgid "This field is required."
msgstr "Šis lauks ir obligāts."

#, python-brace-format
msgid "File does not have an approved extension: {extensions}"
msgstr "Failam nav apstiprināta paplašinājuma: {extensions}"

msgid "File does not have an approved extension."
msgstr "Failam nav apstiprināta paplašinājuma."

#, python-brace-format
msgid "File must be between {min_size} and {max_size} bytes."
msgstr "Faila izmēram ir jābūt no {min_size} līdz {max_size} baitiem."

#, python-format
msgid "Invalid field name '%s'."
msgstr "Nederīgs lauka nosaukums '%s'."

#, python-format
msgid "Field must be equal to %(other_name)s."
msgstr "Laukam ir jābūt vienādam ar %(other_name)s."

#, python-format
msgid "Field must be at least %(min)d character long."
msgstr "Laukam ir jābūt vismaz %(min)d rakstzīmes garam."

#, python-format
msgid "Field cannot be longer than %(max)d character."
msgstr "Lauks nedrīkst būt garāks par %(max)d rakstzīmi."

#, python-format
msgid "Field must be exactly %(max)d character long."
msgstr "Laukam ir jābūt tieši %(maks.)d rakstzīmes garam."

#, python-format
msgid "Field must be between %(min)d and %(max)d characters long."
msgstr "Laukam ir jābūt no %(min)d līdz %(max)d rakstzīmēm."

#, python-format
msgid "Number must be at least %(min)s."
msgstr "Skaitlim ir jābūt vismaz %(min)s."

#, python-format
msgid "Number must be at most %(max)s."
msgstr "Skaitlim jābūt ne vairāk kā %(max)s."

#, python-format
msgid "Number must be between %(min)s and %(max)s."
msgstr "Skaitlim ir jābūt no %(min)s līdz %(max)s."

msgid "Invalid input."
msgstr "Nederīga ievade."

msgid "Invalid email address."
msgstr "Nederīga e-pasta adrese."

msgid "Invalid IP address."
msgstr "Nederīga IP adrese."

msgid "Invalid Mac address."
msgstr "Nederīga Mac adrese."

msgid "Invalid URL."
msgstr "Nederīgs URL."

msgid "Invalid UUID."
msgstr "Nederīgs UUID."

#, python-format
msgid "Invalid value, must be one of: %(values)s."
msgstr "Nederīga vērtība, tai ir jābūt vienai no: %(values)s."

#, python-format
msgid "Invalid value, can't be any of: %(values)s."
msgstr "Nederīga vērtība, nevar būt neviena no: %(values)s."

msgid "This field cannot be edited."
msgstr "Šo lauku nevar rediģēt."

msgid "This field is disabled and cannot have a value."
msgstr "Šis lauks ir atspējots, un tam nevar būt vērtība."

msgid "Invalid CSRF Token."
msgstr "Nederīgs CSRF marķieris."

msgid "CSRF token missing."
msgstr "Trūkst CSRF pilnvaras."

msgid "CSRF failed."
msgstr "CSRF neizdevās."

msgid "CSRF token expired."
msgstr "CSRF pilnvaras derīguma termiņš ir beidzies."

msgid "Invalid Choice: could not coerce."
msgstr "Nederīga izvēle: nevarēja piespiest."

msgid "Choices cannot be None."
msgstr "Izvēles nevar būt Nav."

msgid "Not a valid choice."
msgstr "Nav derīga izvēle."

msgid "Invalid choice(s): one or more data inputs could not be coerced."
msgstr ""
"Nederīga(-as) izvēle(-s): vienu vai vairākas datu ievades nevarēja "
"piespiest."

#, python-format
msgid "'%(value)s' is not a valid choice for this field."
msgstr "“%(value)s” nav derīga izvēle šim laukam."

msgid "Not a valid datetime value."
msgstr "Nav derīga datuma un laika vērtība."

msgid "Not a valid date value."
msgstr "Nav derīga datuma vērtība."

msgid "Not a valid time value."
msgstr "Nav derīga laika vērtība."

msgid "Not a valid week value."
msgstr "Nederīga nedēļas vērtība."

msgid "Not a valid integer value."
msgstr "Nav derīga vesela skaitļa vērtība."

msgid "Not a valid decimal value."
msgstr "Nav derīga decimālā vērtība."

msgid "Not a valid float value."
msgstr "Nav derīga peldošā vērtība."

