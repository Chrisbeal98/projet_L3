msgstr "El fitxer no té una extensió aprovada."

#, python-brace-format
msgid "File must be between {min_size} and {max_size} bytes."
msgstr "El fitxer ha de tenir entre {min_size} i {max_size} bytes."

#, python-format
msgid "Invalid field name '%s'."
msgstr "Nom de camp \"%s\" no vàlid."

#, python-format
msgid "Field must be equal to %(other_name)s."
msgstr "El camp ha de ser igual a %(other_name)s."

#, python-format
msgid "Field must be at least %(min)d character long."
msgstr "El camp ha de tenir com a mínim %(min)d caràcters."

#, python-format
msgid "Field cannot be longer than %(max)d character."
msgstr "El camp no pot tenir més de %(max)d caràcter."

#, python-format
msgid "Field must be exactly %(max)d character long."
msgstr "El camp ha de tenir exactament %(max)d caràcters."

#, python-format
msgid "Field must be between %(min)d and %(max)d characters long."
msgstr "El camp ha de tenir entre %(min)d i %(max)d caràcters."

#, python-format
msgid "Number must be at least %(min)s."
msgstr "El nombre ha de ser com a mínim %(min)s."

#, python-format
msgid "Number must be at most %(max)s."
msgstr "El nombre ha de ser com a màxim %(max)s."

#, python-format
msgid "Number must be between %(min)s and %(max)s."
msgstr "El nombre ha d'estar entre %(min)s i %(max)s."

msgid "Invalid input."
msgstr "Entrada no vàlida."

msgid "Invalid email address."
msgstr "Adreça de correu electrònic no vàlida."

msgid "Invalid IP address."
msgstr "Adreça IP no vàlida."

msgid "Invalid Mac address."
msgstr "Adreça Mac no vàlida."

msgid "Invalid URL."
msgstr "URL no vàlid."

msgid "Invalid UUID."
msgstr "UUID no vàlid."

#, python-format
msgid "Invalid value, must be one of: %(values)s."
msgstr "El valor no és vàlid, ha de ser un de: %(values)s."

#, python-format
msgid "Invalid value, can't be any of: %(values)s."
msgstr "El valor no és vàlid, no pot ser cap de: %(values)s."

msgid "This field cannot be edited."
msgstr "Aquest camp no es pot editar."

msgid "This field is disabled and cannot have a value."
msgstr "Aquest camp està desactivat i no pot tenir cap valor."

msgid "Invalid CSRF Token."
msgstr "Token CSRF no vàlid."

msgid "CSRF token missing."
msgstr "Falta el testimoni CSRF."

msgid "CSRF failed."
msgstr "CSRF ha fallat."

msgid "CSRF token expired."
msgstr "El testimoni CSRF ha caducat."

msgid "Invalid Choice: could not coerce."
msgstr "Opció no vàlida: no s'ha pogut coaccionar."

msgid "Choices cannot be None."
msgstr "Les opcions no poden ser Cap."

msgid "Not a valid choice."
msgstr "No és una opció vàlida."

msgid "Invalid choice(s): one or more data inputs could not be coerced."
msgstr "Opcions no vàlides: no s'han pogut coaccionar una o més entrades de dades."

#, python-format
msgid "'%(value)s' is not a valid choice for this field."
msgstr "'%(value)s' no és una opció vàlida per a aquest camp."

msgid "Not a valid datetime value."
msgstr "No és un valor de data i hora vàlid."

msgid "Not a valid date value."
msgstr "No és un valor de data vàlid."

msgid "Not a valid time value."
msgstr "No és un valor de temps vàlid."

msgid "Not a valid week value."
msgstr "No és un valor setmanal vàlid."

msgid "Not a valid integer value."
msgstr "No és un valor enter vàlid."

msgid "Not a valid decimal value."
msgstr "No és un valor decimal vàlid."

msgid "Not a valid float value."
msgstr "No és un valor flotant vàlid."

