msgstr "កំហុស៖ ការបញ្ចូលមិនត្រឹមត្រូវ"

#, python-brace-format
msgid "Unknown color {colour!r}"
msgstr "ពណ៌មិនស្គាល់ {color!r}"

msgid "Press any key to continue..."
msgstr "ចុចគ្រាប់ចុចណាមួយដើម្បីបន្ត..."

#, python-brace-format
msgid "Choose from:\\n\\t{choices}"
msgstr "ជ្រើសរើសពី៖\\n\\t{choices}"

#, python-brace-format
msgid "{value!r} is not {choice}."
msgstr "{value!r} មិនមែនជា {choice} ទេ។"

#, python-brace-format
msgid "Choice({choices})"
msgstr "ជម្រើស ({choices})"

#, python-brace-format
msgid "{value!r} does not match the format {format}."
msgstr "{value!r} មិនត្រូវគ្នានឹងទម្រង់ {format} ទេ។"

#, python-brace-format
msgid "{value!r} is not a valid {number_type}."
msgstr "{value!r} មិនមែនជា {number_type} ត្រឹមត្រូវ។"

#, python-brace-format
msgid "{value} is not in the range {range}."
msgstr "{value} មិនស្ថិតនៅក្នុងជួរ {range} ទេ។"

#, python-brace-format
msgid "{value!r} is not a valid boolean. Recognized values: {states}"
msgstr "{value!r} មិនមែនជាប៊ូលីនត្រឹមត្រូវទេ។ តម្លៃដែលទទួលស្គាល់៖ {states}"

#, python-brace-format
msgid "{value!r} is not a valid UUID."
msgstr "{value!r} មិនមែនជា UUID ត្រឹមត្រូវ។"

msgid "file"
msgstr "ឯកសារ"

msgid "directory"
msgstr "ថត"

msgid "path"
msgstr "ផ្លូវ"

#, python-brace-format
msgid "{name} {filename!r} does not exist."
msgstr "{name} {filename!r} មិនមានទេ។"

#, python-brace-format
msgid "{name} {filename!r} is a file."
msgstr "{name} {filename!r} គឺជាឯកសារ។"

#, python-brace-format
msgid "{name} {filename!r} is a directory."
msgstr "{name} {filename!r} គឺជាថតមួយ។"

#, python-brace-format
msgid "{name} {filename!r} is not readable."
msgstr "{name} {filename!r} មិនអាចអានបានទេ។"

#, python-brace-format
msgid "{name} {filename!r} is not writable."
msgstr "{name} {filename!r} មិនអាចសរសេរបានទេ។"

#, python-brace-format
msgid "{name} {filename!r} is not executable."
msgstr "{name} {filename!r} មិនអាចប្រតិបត្តិបានទេ។"

#, python-brace-format
msgid "{len_type} values are required, but {len_value} was given."
msgstr "តម្លៃ {len_type} ត្រូវបានទាមទារ ប៉ុន្តែ {len_value} ត្រូវបានផ្តល់ឱ្យ។"

#, python-brace-format
msgid "Unknown standard stream '{name}'"
msgstr "មិនស្គាល់ស្ទ្រីមស្តង់ដារ '{name}'"

msgid "This field is required."
msgstr "វាលនេះត្រូវបានទាមទារ។"

#, python-brace-format
msgid "File does not have an approved extension: {extensions}"
msgstr "ឯកសារមិនមានផ្នែកបន្ថែមដែលបានអនុម័តទេ៖ {extensions}"

msgid "File does not have an approved extension."
msgstr "ឯកសារមិនមានផ្នែកបន្ថែមដែលត្រូវបានអនុម័តទេ។"

#, python-brace-format
msgid "File must be between {min_size} and {max_size} bytes."
msgstr "ឯកសារត្រូវតែស្ថិតនៅចន្លោះ {min_size} និង {max_size} បៃ។"

#, python-format
msgid "Invalid field name '%s'."
msgstr "ឈ្មោះវាលមិនត្រឹមត្រូវ '%s' ។"

#, python-format
msgid "Field must be equal to %(other_name)s."
msgstr "វាលត្រូវតែស្មើនឹង %(other_name)s ។"

#, python-format
msgid "Field must be at least %(min)d character long."
msgstr "វាលត្រូវតែមានប្រវែងយ៉ាងតិច %(min)d តួអក្សរ។"

#, python-format
msgid "Field cannot be longer than %(max)d character."
msgstr "វាលមិនអាចវែងជាង %(អតិបរមា)d តួអក្សរទេ។"

#, python-format
msgid "Field must be exactly %(max)d character long."
msgstr "វាលត្រូវតែមានតួអក្សរ %(អតិបរមា)d យ៉ាងពិតប្រាកដ។"

#, python-format
msgid "Field must be between %(min)d and %(max)d characters long."
msgstr "វាលត្រូវតែស្ថិតនៅចន្លោះ %(min)d និង %(max)d តួអក្សរវែង។"

#, python-format
msgid "Number must be at least %(min)s."
msgstr "លេខត្រូវតែមានយ៉ាងហោចណាស់ %(min)s ។"

#, python-format
msgid "Number must be at most %(max)s."
msgstr "ចំនួនត្រូវតែមានច្រើនបំផុត %(អតិបរមា)s ។"

#, python-format
msgid "Number must be between %(min)s and %(max)s."
msgstr "លេខត្រូវតែស្ថិតនៅចន្លោះ %(min)s និង %(max)s។"

msgid "Invalid input."
msgstr "ការបញ្ចូលមិនត្រឹមត្រូវ។"

msgid "Invalid email address."
msgstr "អាសយដ្ឋានអ៊ីមែលមិនត្រឹមត្រូវ។"

msgid "Invalid IP address."
msgstr "អាសយដ្ឋាន IP មិនត្រឹមត្រូវ។"

msgid "Invalid Mac address."
msgstr "អាសយដ្ឋាន Mac មិនត្រឹមត្រូវ។"

msgid "Invalid URL."
msgstr "URL មិនត្រឹមត្រូវ។"

msgid "Invalid UUID."
msgstr "UUID មិនត្រឹមត្រូវ។"

#, python-format
msgid "Invalid value, must be one of: %(values)s."
msgstr "តម្លៃ​មិន​ត្រឹមត្រូវ ត្រូវ​តែ​ជា​មួយ​ក្នុង​ចំណោម៖ %(តម្លៃ)s។"

#, python-format
msgid "Invalid value, can't be any of: %(values)s."
msgstr "តម្លៃ​មិន​ត្រឹមត្រូវ មិន​អាច​ជា​មួយ​ណា​មួយ​ក្នុង​ចំណោម៖ %(values)s។"

msgid "This field cannot be edited."
msgstr "វាលនេះមិនអាចកែសម្រួលបានទេ។"

msgid "This field is disabled and cannot have a value."
msgstr "វាលនេះត្រូវបានបិទ ហើយមិនអាចមានតម្លៃបានទេ។"

msgid "Invalid CSRF Token."
msgstr "CSRF Token មិនត្រឹមត្រូវ។"

msgid "CSRF token missing."
msgstr "បាត់និមិត្តសញ្ញា CSRF ។"

msgid "CSRF failed."
msgstr "CSRF បរាជ័យ។"

msgid "CSRF token expired."
msgstr "សញ្ញាសម្ងាត់ CSRF បានផុតកំណត់។"

msgid "Invalid Choice: could not coerce."
msgstr "ជម្រើសមិនត្រឹមត្រូវ៖ មិនអាចបង្ខិតបង្ខំបានទេ។"

msgid "Choices cannot be None."
msgstr "ជម្រើសមិនអាចគ្មានទេ។"

msgid "Not a valid choice."
msgstr "មិនមែនជាជម្រើសត្រឹមត្រូវទេ។"

msgid "Invalid choice(s): one or more data inputs could not be coerced."
msgstr "ជម្រើសមិនត្រឹមត្រូវ៖ ការបញ្ចូលទិន្នន័យមួយ ឬច្រើនមិនអាចបង្ខំបានទេ។"

#, python-format
msgid "'%(value)s' is not a valid choice for this field."
msgstr "'%(value)s' មិនមែនជាជម្រើសត្រឹមត្រូវសម្រាប់វាលនេះទេ។"

msgid "Not a valid datetime value."
msgstr "មិនមែនជាតម្លៃកាលបរិច្ឆេទត្រឹមត្រូវទេ។"

msgid "Not a valid date value."
msgstr "មិនមែនជាតម្លៃកាលបរិច្ឆេទត្រឹមត្រូវ។"

msgid "Not a valid time value."
msgstr "មិនមែនជាតម្លៃពេលវេលាត្រឹមត្រូវ។"

msgid "Not a valid week value."
msgstr "មិនមែនជាតម្លៃសប្តាហ៍ត្រឹមត្រូវទេ។"

msgid "Not a valid integer value."
msgstr "មិនមែនជាតម្លៃចំនួនគត់ត្រឹមត្រូវ។"

msgid "Not a valid decimal value."
msgstr "មិនមែនជាតម្លៃទសភាគត្រឹមត្រូវ។"

msgid "Not a valid float value."
msgstr "មិនមែនជាតម្លៃអណ្តែតត្រឹមត្រូវទេ។"

