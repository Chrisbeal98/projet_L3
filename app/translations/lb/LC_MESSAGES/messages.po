msgstr "De Fichier muss tëscht {min_size} an {max_size} Bytes sinn."

#, python-format
msgid "Invalid field name '%s'."
msgstr "Ongülteg Feldnumm '%s'."

#, python-format
msgid "Field must be equal to %(other_name)s."
msgstr "Feld muss gläich wéi %(other_name)s sinn."

#, python-format
msgid "Field must be at least %(min)d character long."
msgstr "Feld muss mindestens %(min)d Charakter laang sinn."

#, python-format
msgid "Field cannot be longer than %(max)d character."
msgstr "Feld kann net méi laang wéi %(max)d Charakter sinn."

#, python-format
msgid "Field must be exactly %(max)d character long."
msgstr "Feld muss genau %(max)d Charakter laang sinn."

#, python-format
msgid "Field must be between %(min)d and %(max)d characters long."
msgstr "Feld muss tëscht %(min)d an %(max)d Zeeche laang sinn."

#, python-format
msgid "Number must be at least %(min)s."
msgstr "D'Zuel muss op d'mannst %(min)s sinn."

#, python-format
msgid "Number must be at most %(max)s."
msgstr "D'Zuel muss maximal %(max)s sinn."

#, python-format
msgid "Number must be between %(min)s and %(max)s."
msgstr "D'Zuel muss tëscht %(min)s an %(max)s sinn."

msgid "Invalid input."
msgstr "Invalid Input."

msgid "Invalid email address."
msgstr "Invalid Email Adress."

msgid "Invalid IP address."
msgstr "Ongülteg IP Adress."

msgid "Invalid Mac address."
msgstr "Ongülteg Mac Adress."

msgid "Invalid URL."
msgstr "Invalid URL."

msgid "Invalid UUID."
msgstr "Invalid UUID."

#, python-format
msgid "Invalid value, must be one of: %(values)s."
msgstr "Ongülteg Wäert, muss ee vun: %(values)s sinn."

#, python-format
msgid "Invalid value, can't be any of: %(values)s."
msgstr "Ongülteg Wäert, kann keng vun: %(values)s sinn."

msgid "This field cannot be edited."
msgstr "Dëst Feld kann net geännert ginn."

msgid "This field is disabled and cannot have a value."
msgstr "Dëst Feld ass behënnert a kann net e Wäert hunn."

msgid "Invalid CSRF Token."
msgstr "Invalid CSRF Token."

msgid "CSRF token missing."
msgstr "CSRF Token fehlt."

msgid "CSRF failed."
msgstr "CSRF gescheitert."

msgid "CSRF token expired."
msgstr "CSRF Token ofgelaaf."

msgid "Invalid Choice: could not coerce."
msgstr "Ongülteg Wiel: konnt net zwéngen."

msgid "Choices cannot be None."
msgstr "Choixen kënnen keng sinn."

msgid "Not a valid choice."
msgstr "Net eng valabel Wiel."

msgid "Invalid choice(s): one or more data inputs could not be coerced."
msgstr "Ongëlteg Choix(en): een oder méi Dateinpute konnten net gezwongen ginn."

#, python-format
msgid "'%(value)s' is not a valid choice for this field."
msgstr "'%(value)s' ass net eng valabel Wiel fir dëst Feld."

msgid "Not a valid datetime value."
msgstr "Net e gültege Datetime Wäert."

msgid "Not a valid date value."
msgstr "Net eng valabel Datum Wäert."

msgid "Not a valid time value."
msgstr "Net eng valabel Zäit Wäert."

msgid "Not a valid week value."
msgstr "Net eng valabel Woch Wäert."

msgid "Not a valid integer value."
msgstr "Net e gültege ganz Zuel Wäert."

msgid "Not a valid decimal value."
msgstr "Net e gültege Dezimalwäert."

msgid "Not a valid float value."
msgstr "Net e gültege Floatwäert."

