msgid "Invalid field name '%s'."
msgstr "Ongeldige veldnaom '%s'."

#, python-format
msgid "Field must be equal to %(other_name)s."
msgstr "‘t Veld mot geliek zien aon %(other_name)s."

#, python-format
msgid "Field must be at least %(min)d character long."
msgstr "‘t Veld mot op z’n mins %(min)d teiken laank zien."

#, python-format
msgid "Field cannot be longer than %(max)d character."
msgstr "‘t Veld kin neet langer zien es %(max)d teike."

#, python-format
msgid "Field must be exactly %(max)d character long."
msgstr "‘t Veld mot precies %(max)d teiken laank zien."

#, python-format
msgid "Field must be between %(min)d and %(max)d characters long."
msgstr "‘t Veld mot tusse %(min)d en %(max)d teikens laank zien."

#, python-format
msgid "Number must be at least %(min)s."
msgstr "‘t Getal mot op z’n mins %(min)s zien."

#, python-format
msgid "Number must be at most %(max)s."
msgstr "‘t Getal mot hoogstens %(max)s zien."

#, python-format
msgid "Number must be between %(min)s and %(max)s."
msgstr "‘t Getal mot tusse %(min)s en %(max)s ligke."

msgid "Invalid input."
msgstr "Ongeldige invoer."

msgid "Invalid email address."
msgstr "Ongeldig e-mailadres."

msgid "Invalid IP address."
msgstr "Ongeldig IP-adres."

msgid "Invalid Mac address."
msgstr "Ongeldig Mac-adres."

msgid "Invalid URL."
msgstr "Ongeldige URL."

msgid "Invalid UUID."
msgstr "Ongeldige UUID."

#, python-format
msgid "Invalid value, must be one of: %(values)s."
msgstr "Ongeldige waarde, moot ein vaan: %(values)s zien."

#, python-format
msgid "Invalid value, can't be any of: %(values)s."
msgstr "Ongeldige waarde, kin gein vaan: %(values)s zien."

msgid "This field cannot be edited."
msgstr "Dit veld kin neet were bewèrk."

msgid "This field is disabled and cannot have a value."
msgstr "Dit veld is oetgeschakeld en kin gein waerde höbbe."

msgid "Invalid CSRF Token."
msgstr "Ongeldige CSRF-token."

msgid "CSRF token missing."
msgstr "CSRF-token ontbreek."

msgid "CSRF failed."
msgstr "CSRF mislukde."

msgid "CSRF token expired."
msgstr "CSRF-token is verloupe."

msgid "Invalid Choice: could not coerce."
msgstr "Ongeldige keuze: koos neet dwinge."

msgid "Choices cannot be None."
msgstr "Keuzes kinne neet Geen zien."

msgid "Not a valid choice."
msgstr "Gein geldige keuze."

msgid "Invalid choice(s): one or more data inputs could not be coerced."
msgstr "Ongeldige keuze(s): ein of mie data-invoer kooste neet weure gedwonge."

#, python-format
msgid "'%(value)s' is not a valid choice for this field."
msgstr "'%(value)s' is gein geldige keuze veur dit veld."

msgid "Not a valid datetime value."
msgstr "Gein geldige datumtiedwaarde."

msgid "Not a valid date value."
msgstr "Gein geldige datumwaarde."

msgid "Not a valid time value."
msgstr "Gein geldige tiedswaarde."

msgid "Not a valid week value."
msgstr "Gein geldige weekwaarde."

msgid "Not a valid integer value."
msgstr "Gein geldige gehele getalwaarde."

msgid "Not a valid decimal value."
msgstr "Gein geldige decimaalwaarde."

msgid "Not a valid float value."
msgstr "Gein geldige float-waarde."

