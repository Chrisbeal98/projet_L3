#, python-brace-format
msgid "{name} {filename!r} does not exist."
msgstr "{name} {filename!r} neexistuje."

#, python-brace-format
msgid "{name} {filename!r} is a file."
msgstr "{name} {filename!r} je súbor."

#, python-brace-format
msgid "{name} {filename!r} is a directory."
msgstr "{name} {filename!r} je adresár."

#, python-brace-format
msgid "{name} {filename!r} is not readable."
msgstr "{name} {filename!r} nie je čitateľný."

#, python-brace-format
msgid "{name} {filename!r} is not writable."
msgstr "{name} {filename!r} nie je zapisovateľný."

#, python-brace-format
msgid "{name} {filename!r} is not executable."
msgstr "{name} {filename!r} nie je spustiteľný."

#, python-brace-format
msgid "{len_type} values are required, but {len_value} was given."
msgstr "Hodnoty {len_type} sú povinné, ale bolo zadané {len_value}."

#, python-brace-format
msgid "Unknown standard stream '{name}'"
msgstr "Neznámy štandardný stream '{name}'"

msgid "This field is required."
msgstr "Toto pole je povinné."

#, python-brace-format
msgid "File does not have an approved extension: {extensions}"
msgstr "Súbor nemá schválenú príponu: {extensions}"

msgid "File does not have an approved extension."
msgstr "Súbor nemá schválenú príponu."

#, python-brace-format
msgid "File must be between {min_size} and {max_size} bytes."
msgstr "Súbor musí byť medzi {min_size} a {max_size} bajtov."

#, python-format
msgid "Invalid field name '%s'."
msgstr "Neplatný názov poľa '%s'."

#, python-format
msgid "Field must be equal to %(other_name)s."
msgstr "Pole sa musí rovnať %(other_name)s."

#, python-format
msgid "Field must be at least %(min)d character long."
msgstr "Pole musí mať aspoň %(min)d znakov."

#, python-format
msgid "Field cannot be longer than %(max)d character."
msgstr "Pole nemôže byť dlhšie ako %(max)d znakov."

#, python-format
msgid "Field must be exactly %(max)d character long."
msgstr "Pole musí mať presne %(max)d znakov."

#, python-format
msgid "Field must be between %(min)d and %(max)d characters long."
msgstr "Pole musí mať dĺžku od %(min)d do %(max)d znakov."

#, python-format
msgid "Number must be at least %(min)s."
msgstr "Číslo musí byť aspoň %(min)s."

#, python-format
msgid "Number must be at most %(max)s."
msgstr "Číslo musí byť najviac %(max)s."

#, python-format
msgid "Number must be between %(min)s and %(max)s."
msgstr "Číslo musí byť medzi %(min)s a %(max)s."

msgid "Invalid input."
msgstr "Neplatný vstup."

msgid "Invalid email address."
msgstr "Neplatná e-mailová adresa."

msgid "Invalid IP address."
msgstr "Neplatná adresa IP."

msgid "Invalid Mac address."
msgstr "Neplatná adresa Mac."

msgid "Invalid URL."
msgstr "Neplatná adresa URL."

msgid "Invalid UUID."
msgstr "Neplatné UUID."

#, python-format
msgid "Invalid value, must be one of: %(values)s."
msgstr "Neplatná hodnota, musí to byť jedna z: %(values)s."

#, python-format
msgid "Invalid value, can't be any of: %(values)s."
msgstr "Neplatná hodnota, nemôže byť žiadna z: %(values)s."

msgid "This field cannot be edited."
msgstr "Toto pole nie je možné upraviť."

msgid "This field is disabled and cannot have a value."
msgstr "Toto pole je zakázané a nemôže mať hodnotu."

msgid "Invalid CSRF Token."
msgstr "Neplatný token CSRF."

msgid "CSRF token missing."
msgstr "Chýba token CSRF."

msgid "CSRF failed."
msgstr "CSRF zlyhal."

msgid "CSRF token expired."
msgstr "Platnosť tokenu CSRF vypršala."

msgid "Invalid Choice: could not coerce."
msgstr "Neplatná voľba: nepodarilo sa vynútiť."

msgid "Choices cannot be None."
msgstr "Možnosti nemôžu byť Žiadne."

msgid "Not a valid choice."
msgstr "Neplatná voľba."

msgid "Invalid choice(s): one or more data inputs could not be coerced."
msgstr "Neplatné voľby: jeden alebo viac údajových vstupov nebolo možné vynútiť."

#, python-format
msgid "'%(value)s' is not a valid choice for this field."
msgstr "'%(value)s' nie je platná voľba pre toto pole."

msgid "Not a valid datetime value."
msgstr "Neplatná hodnota dátumu a času."

msgid "Not a valid date value."
msgstr "Neplatná hodnota dátumu."

msgid "Not a valid time value."
msgstr "Neplatná časová hodnota."

msgid "Not a valid week value."
msgstr "Neplatná hodnota týždňa."

msgid "Not a valid integer value."
msgstr "Neplatná celočíselná hodnota."

msgid "Not a valid decimal value."
msgstr "Neplatná desatinná hodnota."

msgid "Not a valid float value."
msgstr "Neplatná plávajúca hodnota."

