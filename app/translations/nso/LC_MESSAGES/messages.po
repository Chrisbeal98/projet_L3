msgstr "Tobetsa konopo efe kapa efe ho tsoela pele..."

#, python-brace-format
msgid "Choose from:\\n\\t{choices}"
msgstr "Kgetha go tšwa go:\\n\\t{dikgetho}."

#, python-brace-format
msgid "{value!r} is not {choice}."
msgstr "{boleng!r} ga se {kgetho}."

#, python-brace-format
msgid "Choice({choices})"
msgstr "Kgetho ({dikgetho}) ."

#, python-brace-format
msgid "{value!r} does not match the format {format}."
msgstr "{boleng!r} ga e swane le sebopego sa {fomete}."

#, python-brace-format
msgid "{value!r} is not a valid {number_type}."
msgstr "{boleng!r} ga se {mohuta_wa_nomoro} ye e šomago."

#, python-brace-format
msgid "{value} is not in the range {range}."
msgstr "{boleng} ga bo ka gare ga legoro la {range}."

#, python-brace-format
msgid "{value!r} is not a valid boolean. Recognized values: {states}"
msgstr ""
"{boleng!r} ga se boolean ye e šomago. Ditekanyetšo tše di lemogilwego: "
"{dilete} ."

#, python-brace-format
msgid "{value!r} is not a valid UUID."
msgstr "{boleng!r} ga se UUID ye e šomago."

msgid "file"
msgstr "faele"

msgid "directory"
msgstr "tšhupamabaka"

msgid "path"
msgstr "tsela"

#, python-brace-format
msgid "{name} {filename!r} does not exist."
msgstr "{leina} {leina la faele!r} ga e gona."

#, python-brace-format
msgid "{name} {filename!r} is a file."
msgstr "{leina} {leina la faele!r} ke faele."

#, python-brace-format
msgid "{name} {filename!r} is a directory."
msgstr "{leina} {leina la faele!r} ke tšhupetšo."

#, python-brace-format
msgid "{name} {filename!r} is not readable."
msgstr "{leina} {leina la faele!r} ga e balege."

#, python-brace-format
msgid "{name} {filename!r} is not writable."
msgstr "{leina} {leina la faele!r} ga e ngwalwe."

#, python-brace-format
msgid "{name} {filename!r} is not executable."
msgstr "{leina} {leina la faele!r} ga e phethagatšwe."

#, python-brace-format
msgid "{len_type} values are required, but {len_value} was given."
msgstr "{len_type} boleng di a nyakega, eupša {len_value} e filwe."

#, python-brace-format
msgid "Unknown standard stream '{name}'"
msgstr "Moela wa maemo wo o sa tsebjego '{leina}'."

msgid "This field is required."
msgstr "Tšhemo ye e a nyakega."

#, python-brace-format
msgid "File does not have an approved extension: {extensions}"
msgstr "Faele ga e na katoloso ye e dumeletšwego: {dikatoloso} ."

msgid "File does not have an approved extension."
msgstr "Faele ga e na katoloso ye e dumeletšwego."

#, python-brace-format
msgid "File must be between {min_size} and {max_size} bytes."
msgstr "Faele e swanetše go ba magareng ga {min_size} le {max_size} di-byte."

#, python-format
msgid "Invalid field name '%s'."
msgstr "Leina la tšhemo leo le sa šomego '%s'."

#, python-format
msgid "Field must be equal to %(other_name)s."
msgstr "Tšhemo e swanetše go lekana le % (leina_le lengwe)s."

#, python-format
msgid "Field must be at least %(min)d character long."
msgstr "Tšhemo e swanetše go ba bonnyane bja botelele bja sebopego sa %(min)d."

#, python-format
msgid "Field cannot be longer than %(max)d character."
msgstr "Tšhemo e ka se be ye telele go feta semelo sa %(max)d."

#, python-format
msgid "Field must be exactly %(max)d character long."
msgstr "Tšhemo e swanetše go ba ka botelele bja sebopego sa %(max)d gabotse."

#, python-format
msgid "Field must be between %(min)d and %(max)d characters long."
msgstr ""
"Tšhemo e swanetše go ba magareng ga %(min)d le %(max)d ditlhaka tše "
"telele."

#, python-format
msgid "Number must be at least %(min)s."
msgstr "Palo e swanetše go ba bonyane %(min)s."

#, python-format
msgid "Number must be at most %(max)s."
msgstr "Palo e swanetše go ba palomoka ya %(max)s."

#, python-format
msgid "Number must be between %(min)s and %(max)s."
msgstr "Palo e swanetše go ba magareng ga %(min)s le %(max)s."

msgid "Invalid input."
msgstr "Tsenyo ye e sa šomego."

msgid "Invalid email address."
msgstr "Aterese ya imeile ye e sa šomego."

msgid "Invalid IP address."
msgstr "Aterese ya IP ye e sa šomego."

msgid "Invalid Mac address."
msgstr "Aterese ya Mac yeo e sa šomego."

msgid "Invalid URL."
msgstr "URL ye e sa šomego."

msgid "Invalid UUID."
msgstr "UUID ye e sa šomego."

#, python-format
msgid "Invalid value, must be one of: %(values)s."
msgstr "Boleng bjo bo sa šomego, bo swanetše go ba bjo bongwe bja: %(boleng)s."

#, python-format
msgid "Invalid value, can't be any of: %(values)s."
msgstr "Boleng bjo bo sa šomego, e ka se be efe goba efe ya: % (boleng)s."

msgid "This field cannot be edited."
msgstr "Tšhemo ye e ka se rulaganywe."

msgid "This field is disabled and cannot have a value."
msgstr "Tšhemo ye e šitišitšwe gomme e ka se be le boleng."

msgid "Invalid CSRF Token."
msgstr "Letshwao la CSRF leo le sa šomego."

msgid "CSRF token missing."
msgstr "Letshwao la CSRF le hlaela."

msgid "CSRF failed."
msgstr "CSRF e paletšwe."

msgid "CSRF token expired."
msgstr "Letshwao la CSRF le fedile nako."

msgid "Invalid Choice: could not coerce."
msgstr "Kgetho ye e sa šomego: o be a sa kgone go gapeletša."

msgid "Choices cannot be None."
msgstr "Dikgetho e ka se be Ga go na."

msgid "Not a valid choice."
msgstr "E sego kgetho ye e kwagalago."

msgid "Invalid choice(s): one or more data inputs could not be coerced."
msgstr ""
"Kgetho (dikgetho) ye e sa šomego: tsenyo e tee goba tše ntši tša datha di"
" be di sa kgone go gapeletšwa."

#, python-format
msgid "'%(value)s' is not a valid choice for this field."
msgstr "'%(value)s' ga se kgetho ye e šomago ya tšhemo ye."

msgid "Not a valid datetime value."
msgstr "E sego boleng bja nako ya letšatšikgwedi bjo bo šomago."

msgid "Not a valid date value."
msgstr "E sego boleng bja letšatšikgwedi bjo bo šomago."

msgid "Not a valid time value."
msgstr "E sego boleng bja nako bjo bo šomago."

msgid "Not a valid week value."
msgstr "E sego boleng bja beke bjo bo šomago."

msgid "Not a valid integer value."
msgstr "E sego boleng bja palomoka bjo bo šomago."

msgid "Not a valid decimal value."
msgstr "E sego boleng bja tesimale bjo bo šomago."

msgid "Not a valid float value."
msgstr "E sego boleng bja go phaphamala bjo bo šomago."

