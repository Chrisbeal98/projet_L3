msgstr "આ ફીલ્ડ અક્ષમ છે અને તેનું મૂલ્ય હોઈ શકતું નથી."

msgid "Invalid CSRF Token."
msgstr "અમાન્ય CSRF ટોકન."

msgid "CSRF token missing."
msgstr "CSRF ટોકન ખૂટે છે."

msgid "CSRF failed."
msgstr "CSRF નિષ્ફળ."

msgid "CSRF token expired."
msgstr "CSRF ટોકન સમાપ્ત."

msgid "Invalid Choice: could not coerce."
msgstr "અમાન્ય પસંદગી: બળજબરી કરી શકાઈ નથી."

msgid "Choices cannot be None."
msgstr "પસંદગીઓ કંઈ ન હોઈ શકે."

msgid "Not a valid choice."
msgstr "માન્ય પસંદગી નથી."

msgid "Invalid choice(s): one or more data inputs could not be coerced."
msgstr "અમાન્ય પસંદગી(ઓ): એક અથવા વધુ ડેટા ઇનપુટ્સ દબાણ કરી શકાતા નથી."

#, python-format
msgid "'%(value)s' is not a valid choice for this field."
msgstr "'%(મૂલ્ય)s' આ ક્ષેત્ર માટે માન્ય પસંદગી નથી."

msgid "Not a valid datetime value."
msgstr "માન્ય તારીખ સમય મૂલ્ય નથી."

msgid "Not a valid date value."
msgstr "માન્ય તારીખ મૂલ્ય નથી."

msgid "Not a valid time value."
msgstr "માન્ય સમય મૂલ્ય નથી."

msgid "Not a valid week value."
msgstr "માન્ય સપ્તાહ મૂલ્ય નથી."

msgid "Not a valid integer value."
msgstr "માન્ય પૂર્ણાંક મૂલ્ય નથી."

msgid "Not a valid decimal value."
msgstr "માન્ય દશાંશ મૂલ્ય નથી."

msgid "Not a valid float value."
msgstr "માન્ય ફ્લોટ મૂલ્ય નથી."

