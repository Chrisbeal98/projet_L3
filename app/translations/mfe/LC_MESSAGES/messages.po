#, python-format
msgid "Field must be exactly %(max)d character long."
msgstr "Sa domenn-la bizin ena exakteman %(max)d karakter longer."

#, python-format
msgid "Field must be between %(min)d and %(max)d characters long."
msgstr "Sa domenn-la bizin ant %(min)d ek %(max)d karakter longer."

#, python-format
msgid "Number must be at least %(min)s."
msgstr "Nimero bizin omwin %(min)s."

#, python-format
msgid "Number must be at most %(max)s."
msgstr "Nimero bizin o maximum %(max)s."

#, python-format
msgid "Number must be between %(min)s and %(max)s."
msgstr "Nimero bizin ant %(min)s ek %(max)s."

msgid "Invalid input."
msgstr "Input pa valid."

msgid "Invalid email address."
msgstr "Ladres email pa valid."

msgid "Invalid IP address."
msgstr "Ladres IP pa valid."

msgid "Invalid Mac address."
msgstr "Ladres Mac ki pa valid."

msgid "Invalid URL."
msgstr "URL pa valid."

msgid "Invalid UUID."
msgstr "UUID pa valid."

#, python-format
msgid "Invalid value, must be one of: %(values)s."
msgstr "Valer ki pa valid, bizin enn parmi: %(values)s."

#, python-format
msgid "Invalid value, can't be any of: %(values)s."
msgstr "Valer ki pa valid, pa kapav okenn parmi: %(values)s."

msgid "This field cannot be edited."
msgstr "Pa kapav modifie sa domenn-la."

msgid "This field is disabled and cannot have a value."
msgstr "Sa domenn-la finn dezaktive e li pa kapav ena enn valer."

msgid "Invalid CSRF Token."
msgstr "Token CSRF pa valid."

msgid "CSRF token missing."
msgstr "Token CSRF manke."

msgid "CSRF failed."
msgstr "CSRF finn fel."

msgid "CSRF token expired."
msgstr "Token CSRF finn expire."

msgid "Invalid Choice: could not coerce."
msgstr "Swa invalid: pa finn kapav forse."

msgid "Choices cannot be None."
msgstr "Bann swa pa kapav Okenn."

msgid "Not a valid choice."
msgstr "Pa enn swa ki valab."

msgid "Invalid choice(s): one or more data inputs could not be coerced."
msgstr "Bann swa ki pa valid: enn ou plizier input done pa finn kapav forse."

#, python-format
msgid "'%(value)s' is not a valid choice for this field."
msgstr "'%(value)s' pa enn swa valid pou sa domenn-la."

msgid "Not a valid datetime value."
msgstr "Pa enn valer dat-ler ki valid."

msgid "Not a valid date value."
msgstr "Pa enn valer dat valid."

msgid "Not a valid time value."
msgstr "Pa enn valer letan valid."

msgid "Not a valid week value."
msgstr "Pa enn valer semenn valid."

msgid "Not a valid integer value."
msgstr "Pa enn valer antie valid."

msgid "Not a valid decimal value."
msgstr "Pa enn valer desimal valid."

msgid "Not a valid float value."
msgstr "Pa enn valer flotan ki valid."

