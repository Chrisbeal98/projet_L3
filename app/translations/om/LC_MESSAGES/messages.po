msgstr "Mallattoo CSRF sirrii hin taane."

msgid "CSRF token missing."
msgstr "Mallattoon CSRF dhabame."

msgid "CSRF failed."
msgstr "CSRFn hin milkoofne."

msgid "CSRF token expired."
msgstr "Mallattoon CSRF yeroon isaa darbe."

msgid "Invalid Choice: could not coerce."
msgstr "Filannoo Sirrii Hin Taane: dirqisiisuu hin dandeenye."

msgid "Choices cannot be None."
msgstr "Filannoon Tokkollee ta'uu hin danda'u."

msgid "Not a valid choice."
msgstr "Filannoo sirrii miti."

msgid "Invalid choice(s): one or more data inputs could not be coerced."
msgstr ""
"Filannoo(wwan) sirrii hin taane: galteen deetaa tokko ykn isaa ol "
"dirqisiifamuu hin dandeenye."

