#, python-brace-format
msgid "Unknown standard stream '{name}'"
msgstr "Dhangala'aa istaandaardii hin beekamne '{name}'."

msgid "This field is required."
msgstr "Dirreen kun barbaachisaadha."

#, python-brace-format
msgid "File does not have an approved extension: {extensions}"
msgstr "Faayilii dheerina mirkanaa'e hin qabu: {extensions}."

msgid "File does not have an approved extension."
msgstr "Faayilii dheerina mirkanaa'e hin qabu."

#, python-brace-format
msgid "File must be between {min_size} and {max_size} bytes."
msgstr "Faayilii {min_size} fi {max_size} baayitii gidduutti ta'uu qaba."

#, python-format
msgid "Invalid field name '%s'."
msgstr "Maqaa dirree sirrii hin taane '%s'."

#, python-format
msgid "Field must be equal to %(other_name)s."
msgstr "Dirreen %(maqaa_kanneen) wajjin walqixa ta'uu qaba."

#, python-format
msgid "Field must be at least %(min)d character long."
msgstr "Dirreen yoo xiqqaate arfii %(min)d dheerachuu qaba."

#, python-format
msgid "Field cannot be longer than %(max)d character."
msgstr "Dirreen arfii %(max)d caalaa dheerachuu hin danda'u."

#, python-format
msgid "Field must be exactly %(max)d character long."
msgstr "Dirreen sirriitti arfii %(max)d dheerachuu qaba."

#, python-format
msgid "Field must be between %(min)d and %(max)d characters long."
msgstr "Dirreen arfiilee %(min)d fi %(max)d gidduutti dheerachuu qaba."

#, python-format
msgid "Number must be at least %(min)s."
msgstr "Lakkoofsi yoo xiqqaate %(min)s ta'uu qaba."

#, python-format
msgid "Number must be at most %(max)s."
msgstr "Lakkoofsi yoo baay'ate %(max)s ta'uu qaba."

#, python-format
msgid "Number must be between %(min)s and %(max)s."
msgstr "Lakkoofsi %(min)s fi %(max)s gidduutti ta'uu qaba."

msgid "Invalid input."
msgstr "Galtee sirrii hin taane."

msgid "Invalid email address."
msgstr "Teessoo imeelii sirrii hin taane."

msgid "Invalid IP address."
msgstr "Teessoo IP sirrii hin taane."

msgid "Invalid Mac address."
msgstr "Teessoo Mac sirrii hin taane."

msgid "Invalid URL."
msgstr "URL sirrii hin taane."

msgid "Invalid UUID."
msgstr "UUID sirrii hin taane."

#, python-format
msgid "Invalid value, must be one of: %(values)s."
msgstr "Gatiin sirrii hin taane, tokko ta'uu qaba: %(gatiiwwan)s."

#, python-format
msgid "Invalid value, can't be any of: %(values)s."
msgstr "Gatiin sirrii hin taane, kamiyyuu ta'uu hin danda'u: %(gatiiwwan)s."

msgid "This field cannot be edited."
msgstr "Dirreen kun gulaalamuu hin danda'u."

msgid "This field is disabled and cannot have a value."
msgstr "Dirreen kun hojii irraa kan hafe yoo ta'u gatii qabaachuu hin danda'u."

