#, python-brace-format
msgid "{value!r} does not match the format {format}."
msgstr "{value!r} ບໍ່ກົງກັບຮູບແບບ {format}."

#, python-brace-format
msgid "{value!r} is not a valid {number_type}."
msgstr "{value!r} ບໍ່ແມ່ນ {number_type} ທີ່ຖືກຕ້ອງ."

#, python-brace-format
msgid "{value} is not in the range {range}."
msgstr "{value} ບໍ່ຢູ່ໃນຂອບເຂດ {range}."

#, python-brace-format
msgid "{value!r} is not a valid boolean. Recognized values: {states}"
msgstr "{value!r} ບໍ່ແມ່ນ boolean ທີ່ຖືກຕ້ອງ. ຄ່າທີ່ຮັບຮູ້: {states}"

#, python-brace-format
msgid "{value!r} is not a valid UUID."
msgstr "{value!r} ບໍ່ແມ່ນ UUI ທີ່ຖືກຕ້ອງ."

msgid "file"
msgstr "ໄຟລ໌"

msgid "directory"
msgstr "ໄດເລກະທໍລີ"

msgid "path"
msgstr "ເສັ້ນທາງ"

#, python-brace-format
msgid "{name} {filename!r} does not exist."
msgstr "{name} {filename!r} ບໍ່ມີ."

#, python-brace-format
msgid "{name} {filename!r} is a file."
msgstr "{name} {filename!r} ແມ່ນໄຟລ໌."

#, python-brace-format
msgid "{name} {filename!r} is a directory."
msgstr "{name} {filename!r} ແມ່ນໄດເລກະທໍລີ."

#, python-brace-format
msgid "{name} {filename!r} is not readable."
msgstr "{name} {filename!r} ບໍ່ສາມາດອ່ານໄດ້."

#, python-brace-format
msgid "{name} {filename!r} is not writable."
msgstr "{name} {filename!r} ບໍ່ສາມາດຂຽນໄດ້."

#, python-brace-format
msgid "{name} {filename!r} is not executable."
msgstr "{name} {filename!r} ບໍ່ສາມາດປະຕິບັດໄດ້."

#, python-brace-format
msgid "{len_type} values are required, but {len_value} was given."
msgstr "{len_type} ຄ່າແມ່ນຕ້ອງການ, ແຕ່ {len_value} ໄດ້ຖືກມອບໃຫ້."

#, python-brace-format
msgid "Unknown standard stream '{name}'"
msgstr "ການຖ່າຍທອດມາດຕະຖານທີ່ບໍ່ຮູ້ຈັກ '{name}'"

msgid "This field is required."
msgstr "ຊ່ອງນີ້ຕ້ອງການ."

#, python-brace-format
msgid "File does not have an approved extension: {extensions}"
msgstr "ໄຟລ໌ບໍ່ມີສ່ວນຂະຫຍາຍທີ່ໄດ້ຮັບອະນຸມັດ: {extensions}"

msgid "File does not have an approved extension."
msgstr "ໄຟລ໌ບໍ່ມີສ່ວນຂະຫຍາຍທີ່ໄດ້ຮັບອະນຸມັດ."

#, python-brace-format
msgid "File must be between {min_size} and {max_size} bytes."
msgstr "ໄຟລ໌ຕ້ອງຢູ່ລະຫວ່າງ {min_size} ຫາ {max_size} bytes."

#, python-format
msgid "Invalid field name '%s'."
msgstr "ຊື່ຊ່ອງຂໍ້ມູນບໍ່ຖືກຕ້ອງ '%s'."

#, python-format
msgid "Field must be equal to %(other_name)s."
msgstr "ຊ່ອງຂໍ້ມູນຕ້ອງເທົ່າກັບ %(other_name)s."

#, python-format
msgid "Field must be at least %(min)d character long."
msgstr "ຊ່ອງຂໍ້ມູນຕ້ອງມີຢ່າງໜ້ອຍ %(ນາທີ)d ຕົວອັກສອນຍາວ."

#, python-format
msgid "Field cannot be longer than %(max)d character."
msgstr "ຊ່ອງຂໍ້ມູນບໍ່ສາມາດຍາວກວ່າ %(max)d ຕົວອັກສອນ."

#, python-format
msgid "Field must be exactly %(max)d character long."
msgstr "ຊ່ອງຂໍ້ມູນຕ້ອງມີຄວາມຍາວແທ້ %(max)d ຕົວອັກສອນ."

#, python-format
msgid "Field must be between %(min)d and %(max)d characters long."
msgstr "ຊ່ອງຂໍ້ມູນຕ້ອງຢູ່ລະຫວ່າງ %(min)d ແລະ %(max)d ຕົວອັກສອນຍາວ."

#, python-format
msgid "Number must be at least %(min)s."
msgstr "ຕົວເລກຕ້ອງມີຢ່າງໜ້ອຍ %(ນາທີ)s."

#, python-format
msgid "Number must be at most %(max)s."
msgstr "ຕົວເລກຈະຕ້ອງມີສູງສຸດ %(max)s."

#, python-format
msgid "Number must be between %(min)s and %(max)s."
msgstr "ຕົວເລກຈະຕ້ອງຢູ່ລະຫວ່າງ %(ນາທີ)s ແລະ %(max)s."

msgid "Invalid input."
msgstr "ການປ້ອນຂໍ້ມູນບໍ່ຖືກຕ້ອງ."

msgid "Invalid email address."
msgstr "ທີ່ຢູ່ອີເມວບໍ່ຖືກຕ້ອງ."

msgid "Invalid IP address."
msgstr "ທີ່ຢູ່ IP ບໍ່ຖືກຕ້ອງ."

msgid "Invalid Mac address."
msgstr "ທີ່ຢູ່ Mac ບໍ່ຖືກຕ້ອງ."

msgid "Invalid URL."
msgstr "URL ບໍ່ຖືກຕ້ອງ."

msgid "Invalid UUID."
msgstr "UUI ບໍ່ຖືກຕ້ອງ."

#, python-format
msgid "Invalid value, must be one of: %(values)s."
msgstr "ຄ່າບໍ່ຖືກຕ້ອງ, ຕ້ອງເປັນຫນຶ່ງໃນ: %(values)s."

#, python-format
msgid "Invalid value, can't be any of: %(values)s."
msgstr "ຄ່າບໍ່ຖືກຕ້ອງ, ບໍ່ສາມາດເປັນອັນໃດນຶ່ງຂອງ: %(values)s."

msgid "This field cannot be edited."
msgstr "ຊ່ອງຂໍ້ມູນນີ້ບໍ່ສາມາດແກ້ໄຂໄດ້."

msgid "This field is disabled and cannot have a value."
msgstr "ຊ່ອງຂໍ້ມູນນີ້ຖືກປິດໃຊ້ງານ ແລະບໍ່ສາມາດມີຄ່າໄດ້."

msgid "Invalid CSRF Token."
msgstr "CSRF Token ບໍ່ຖືກຕ້ອງ."

msgid "CSRF token missing."
msgstr "CSRF token ຫາຍໄປ."

msgid "CSRF failed."
msgstr "CSRF ລົ້ມເຫລວ."

msgid "CSRF token expired."
msgstr "ໂທເຄັນ CSRF ໝົດອາຍຸແລ້ວ."

msgid "Invalid Choice: could not coerce."
msgstr "ທາງເລືອກທີ່ບໍ່ຖືກຕ້ອງ: ບໍ່ສາມາດບີບບັງຄັບໄດ້."

msgid "Choices cannot be None."
msgstr "ທາງເລືອກບໍ່ສາມາດບໍ່ມີ."

msgid "Not a valid choice."
msgstr "ບໍ່ແມ່ນທາງເລືອກທີ່ຖືກຕ້ອງ."

msgid "Invalid choice(s): one or more data inputs could not be coerced."
msgstr ""
"ທາງ​ເລືອກ​ທີ່​ບໍ່​ຖືກ​ຕ້ອງ​: "
"ຫນຶ່ງ​ຫຼື​ຫຼາຍ​ການ​ປ້ອນ​ຂໍ້​ມູນ​ບໍ່​ສາ​ມາດ​ໄດ້​ຮັບ​ການ​ບີບ​ບັງ​ຄັບ​."

#, python-format
msgid "'%(value)s' is not a valid choice for this field."
msgstr "'%(value)s' ບໍ່ແມ່ນທາງເລືອກທີ່ຖືກຕ້ອງສຳລັບຊ່ອງຂໍ້ມູນນີ້."

msgid "Not a valid datetime value."
msgstr "ບໍ່ແມ່ນຄ່າວັນທີທີ່ຖືກຕ້ອງ."

msgid "Not a valid date value."
msgstr "ບໍ່ແມ່ນຄ່າວັນທີທີ່ຖືກຕ້ອງ."

msgid "Not a valid time value."
msgstr "ບໍ່ແມ່ນຄ່າເວລາທີ່ຖືກຕ້ອງ."

msgid "Not a valid week value."
msgstr "ບໍ່ແມ່ນຄ່າອາທິດທີ່ຖືກຕ້ອງ."

msgid "Not a valid integer value."
msgstr "ບໍ່ແມ່ນຄ່າຈຳນວນເຕັມທີ່ຖືກຕ້ອງ."

msgid "Not a valid decimal value."
msgstr "ບໍ່ແມ່ນຄ່າທົດສະນິຍົມທີ່ຖືກຕ້ອງ."

msgid "Not a valid float value."
msgstr "ບໍ່ແມ່ນຄ່າລອຍທີ່ຖືກຕ້ອງ."

