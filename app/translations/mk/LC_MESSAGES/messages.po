msgstr "Аргументот {name!r} зема {nargs} вредности."

#, python-brace-format
msgid "Option {name!r} does not take a value."
msgstr "Опцијата {име!r} не зема вредност."

#, python-brace-format
msgid "Option {name!r} requires an argument."
msgstr "Опцијата {име!r} бара аргумент."

msgid "Shell completion is not supported for Bash versions older than 4.4."
msgstr "Дополнувањето на школка не е поддржано за верзии на Bash постари од 4.4."

msgid "Couldn't detect Bash version, shell completion is not supported."
msgstr ""
"Не може да се открие верзијата на Bash, комплетирањето на школка не е "
"поддржано."

msgid "Repeat for confirmation"
msgstr "Повторете за потврда"

msgid "Error: The two entered values do not match."
msgstr "Грешка: двете внесени вредности не се совпаѓаат."

msgid "Error: invalid input"
msgstr "Грешка: неважечки влез"

#, python-brace-format
msgid "Unknown color {colour!r}"
msgstr "Непозната боја {color!r}"

msgid "Press any key to continue..."
msgstr "Притиснете кое било копче за да продолжите..."

#, python-brace-format
msgid "Choose from:\\n\\t{choices}"
msgstr "Изберете од:\\n\\t{избори}"

#, python-brace-format
msgid "{value!r} is not {choice}."
msgstr "{value!r} не е {choice}."

#, python-brace-format
msgid "Choice({choices})"
msgstr "Избор ({избори})"

#, python-brace-format
msgid "{value!r} does not match the format {format}."
msgstr "{value!r} не се совпаѓа со форматот {format}."

#, python-brace-format
msgid "{value!r} is not a valid {number_type}."
msgstr "{value!r} не е валиден {number_type}."

#, python-brace-format
msgid "{value} is not in the range {range}."
msgstr "{value} не е во опсегот {опсег}."

#, python-brace-format
msgid "{value!r} is not a valid boolean. Recognized values: {states}"
msgstr "{value!r} не е валиден бул. Препознаени вредности: {states}"

#, python-brace-format
msgid "{value!r} is not a valid UUID."
msgstr "{value!r} не е валиден UUID."

msgid "file"
msgstr "датотека"

msgid "directory"
msgstr "директориум"

msgid "path"
msgstr "патека"

#, python-brace-format
msgid "{name} {filename!r} does not exist."
msgstr "{name} {filename!r} не постои."

#, python-brace-format
msgid "{name} {filename!r} is a file."
msgstr "{name} {filename!r} е датотека."

#, python-brace-format
msgid "{name} {filename!r} is a directory."
msgstr "{name} {filename!r} е директориум."

#, python-brace-format
msgid "{name} {filename!r} is not readable."
msgstr "{name} {filename!r} не се чита."

#, python-brace-format
msgid "{name} {filename!r} is not writable."
msgstr "{name} {filename!r} не може да се запише."

#, python-brace-format
msgid "{name} {filename!r} is not executable."
msgstr "{name} {filename!r} не е извршна."

#, python-brace-format
msgid "{len_type} values are required, but {len_value} was given."
msgstr "Потребни се вредности на {len_type}, но дадена е {len_value}."

#, python-brace-format
msgid "Unknown standard stream '{name}'"
msgstr "Непознат стандарден пренос „{name}“"

msgid "This field is required."
msgstr "Ова поле е задолжително."

#, python-brace-format
msgid "File does not have an approved extension: {extensions}"
msgstr "Датотеката нема одобрена екстензија: {extensions}"

msgid "File does not have an approved extension."
msgstr "Датотеката нема одобрена екстензија."

#, python-brace-format
msgid "File must be between {min_size} and {max_size} bytes."
msgstr "Датотеката мора да биде помеѓу {min_size} и {max_size} бајти."

#, python-format
msgid "Invalid field name '%s'."
msgstr "Неважечко име на полето „%s“."

#, python-format
msgid "Field must be equal to %(other_name)s."
msgstr "Полето мора да биде еднакво на %(other_name)s."

#, python-format
msgid "Field must be at least %(min)d character long."
msgstr "Полето мора да биде долго најмалку %(min)d знак."

#, python-format
msgid "Field cannot be longer than %(max)d character."
msgstr "Полето не може да биде подолго од %(max)d знак."

#, python-format
msgid "Field must be exactly %(max)d character long."
msgstr "Полето мора да биде долго точно %(max)d знак."

#, python-format
msgid "Field must be between %(min)d and %(max)d characters long."
msgstr "Полето мора да биде долго помеѓу %(min)d и %(max)d знаци."

#, python-format
msgid "Number must be at least %(min)s."
msgstr "Бројот мора да биде најмалку %(min)s."

#, python-format
msgid "Number must be at most %(max)s."
msgstr "Бројот мора да биде најмногу %(max)s."

#, python-format
msgid "Number must be between %(min)s and %(max)s."
msgstr "Бројот мора да биде помеѓу %(min)s и %(max)s."

msgid "Invalid input."
msgstr "Неважечки влез."

msgid "Invalid email address."
msgstr "Неважечка адреса на е-пошта."

msgid "Invalid IP address."
msgstr "Неважечка IP адреса."

msgid "Invalid Mac address."
msgstr "Неважечка Mac адреса."

msgid "Invalid URL."
msgstr "Неважечка URL-адреса."

msgid "Invalid UUID."
msgstr "Неважечки UUID."

#, python-format
msgid "Invalid value, must be one of: %(values)s."
msgstr "Неважечка вредност, мора да биде една од: %(values)s."

#, python-format
msgid "Invalid value, can't be any of: %(values)s."
msgstr "Неважечка вредност, не може да биде ниту една од: %(values)s."

msgid "This field cannot be edited."
msgstr "Ова поле не може да се уредува."

msgid "This field is disabled and cannot have a value."
msgstr "Ова поле е оневозможено и не може да има вредност."

msgid "Invalid CSRF Token."
msgstr "Неважечки CSRF токен."

msgid "CSRF token missing."
msgstr "Недостасува токен CSRF."

msgid "CSRF failed."
msgstr "CSRF не успеа."

msgid "CSRF token expired."
msgstr "CSRF токенот е истечен."

msgid "Invalid Choice: could not coerce."
msgstr "Неважечки избор: не можеше да се присили."

msgid "Choices cannot be None."
msgstr "Изборот не може да биде Никој."

msgid "Not a valid choice."
msgstr "Не е валиден избор."

msgid "Invalid choice(s): one or more data inputs could not be coerced."
msgstr ""
"Неважечки избор(и): еден или повеќе влезови на податоци не може да се "
"принудат."

#, python-format
msgid "'%(value)s' is not a valid choice for this field."
msgstr "„%(value)s“ не е валиден избор за ова поле."

msgid "Not a valid datetime value."
msgstr "Не е важечка вредност на датумот."

msgid "Not a valid date value."
msgstr "Не е важечка вредност на датумот."

msgid "Not a valid time value."
msgstr "Не е валидна временска вредност."

msgid "Not a valid week value."
msgstr "Не е валидна неделна вредност."

msgid "Not a valid integer value."
msgstr "Не е валидна цел број."

msgid "Not a valid decimal value."
msgstr "Не е валидна децимална вредност."

msgid "Not a valid float value."
msgstr "Не е валидна пловечка вредност."

