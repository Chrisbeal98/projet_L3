#, python-brace-format
msgid "{len_type} values are required, but {len_value} was given."
msgstr "{len_type} ਮੁੱਲ ਲੋੜੀਂਦੇ ਹਨ, ਪਰ {len_value} ਦਿੱਤਾ ਗਿਆ ਸੀ।"

#, python-brace-format
msgid "Unknown standard stream '{name}'"
msgstr "ਅਣਜਾਣ ਮਿਆਰੀ ਸਟ੍ਰੀਮ '{name}'"

msgid "This field is required."
msgstr "ਇਸ ਫੀਲਡ ਦੀ ਲੋੜ ਹੈ."

#, python-brace-format
msgid "File does not have an approved extension: {extensions}"
msgstr "ਫ਼ਾਈਲ ਵਿੱਚ ਮਨਜ਼ੂਰਸ਼ੁਦਾ ਐਕਸਟੈਂਸ਼ਨ ਨਹੀਂ ਹੈ: {extensions}"

msgid "File does not have an approved extension."
msgstr "ਫ਼ਾਈਲ ਵਿੱਚ ਮਨਜ਼ੂਰਸ਼ੁਦਾ ਐਕਸਟੈਂਸ਼ਨ ਨਹੀਂ ਹੈ।"

#, python-brace-format
msgid "File must be between {min_size} and {max_size} bytes."
msgstr "ਫ਼ਾਈਲ {min_size} ਅਤੇ {max_size} ਬਾਈਟਾਂ ਵਿਚਕਾਰ ਹੋਣੀ ਚਾਹੀਦੀ ਹੈ।"

#, python-format
msgid "Invalid field name '%s'."
msgstr "ਅਵੈਧ ਫੀਲਡ ਨਾਮ '%s'।"

#, python-format
msgid "Field must be equal to %(other_name)s."
msgstr "ਖੇਤਰ %(other_name)s ਦੇ ਬਰਾਬਰ ਹੋਣਾ ਚਾਹੀਦਾ ਹੈ।"

#, python-format
msgid "Field must be at least %(min)d character long."
msgstr "ਫੀਲਡ ਘੱਟੋ-ਘੱਟ %(ਮਿੰਟ)d ਅੱਖਰ ਲੰਮਾ ਹੋਣਾ ਚਾਹੀਦਾ ਹੈ।"

#, python-format
msgid "Field cannot be longer than %(max)d character."
msgstr "ਫੀਲਡ %(ਅਧਿਕਤਮ)d ਅੱਖਰ ਤੋਂ ਵੱਧ ਨਹੀਂ ਹੋ ਸਕਦਾ।"

#, python-format
msgid "Field must be exactly %(max)d character long."
msgstr "ਫੀਲਡ ਬਿਲਕੁਲ %(ਅਧਿਕਤਮ)d ਅੱਖਰ ਲੰਮਾ ਹੋਣਾ ਚਾਹੀਦਾ ਹੈ।"

#, python-format
msgid "Field must be between %(min)d and %(max)d characters long."
msgstr "ਫੀਲਡ %(min)d ਅਤੇ %(max)d ਅੱਖਰਾਂ ਦੇ ਵਿਚਕਾਰ ਹੋਣੀ ਚਾਹੀਦੀ ਹੈ।"

#, python-format
msgid "Number must be at least %(min)s."
msgstr "ਸੰਖਿਆ ਘੱਟੋ-ਘੱਟ %(ਮਿੰਟ) ਹੋਣੀ ਚਾਹੀਦੀ ਹੈ।"

#, python-format
msgid "Number must be at most %(max)s."
msgstr "ਸੰਖਿਆ ਵੱਧ ਤੋਂ ਵੱਧ % (ਅਧਿਕਤਮ) ਹੋਣੀ ਚਾਹੀਦੀ ਹੈ।"

#, python-format
msgid "Number must be between %(min)s and %(max)s."
msgstr "ਸੰਖਿਆ %(min)s ਅਤੇ %(max)s ਦੇ ਵਿਚਕਾਰ ਹੋਣੀ ਚਾਹੀਦੀ ਹੈ।"

msgid "Invalid input."
msgstr "ਅਵੈਧ ਇਨਪੁਟ।"

msgid "Invalid email address."
msgstr "ਅਵੈਧ ਈਮੇਲ ਪਤਾ।"

msgid "Invalid IP address."
msgstr "ਅਵੈਧ IP ਪਤਾ।"

msgid "Invalid Mac address."
msgstr "ਅਵੈਧ ਮੈਕ ਪਤਾ।"

msgid "Invalid URL."
msgstr "ਅਵੈਧ URL।"

msgid "Invalid UUID."
msgstr "ਅਵੈਧ UUID।"

#, python-format
msgid "Invalid value, must be one of: %(values)s."
msgstr "ਅਵੈਧ ਮੁੱਲ, ਇਹਨਾਂ ਵਿੱਚੋਂ ਇੱਕ ਹੋਣਾ ਚਾਹੀਦਾ ਹੈ: %(ਮੁੱਲ)।"

#, python-format
msgid "Invalid value, can't be any of: %(values)s."
msgstr "ਅਵੈਧ ਮੁੱਲ, ਇਹਨਾਂ ਵਿੱਚੋਂ ਕੋਈ ਵੀ ਨਹੀਂ ਹੋ ਸਕਦਾ: %(ਮੁੱਲ)।"

msgid "This field cannot be edited."
msgstr "ਇਹ ਖੇਤਰ ਸੰਪਾਦਿਤ ਨਹੀਂ ਕੀਤਾ ਜਾ ਸਕਦਾ ਹੈ।"

msgid "This field is disabled and cannot have a value."
msgstr "ਇਹ ਖੇਤਰ ਅਯੋਗ ਹੈ ਅਤੇ ਇਸਦਾ ਕੋਈ ਮੁੱਲ ਨਹੀਂ ਹੋ ਸਕਦਾ।"

msgid "Invalid CSRF Token."
msgstr "ਅਵੈਧ CSRF ਟੋਕਨ।"

msgid "CSRF token missing."
msgstr "CSRF ਟੋਕਨ ਗੁੰਮ ਹੈ।"

msgid "CSRF failed."
msgstr "CSRF ਅਸਫਲ ਰਿਹਾ।"

msgid "CSRF token expired."
msgstr "CSRF ਟੋਕਨ ਦੀ ਮਿਆਦ ਪੁੱਗ ਗਈ।"

msgid "Invalid Choice: could not coerce."
msgstr "ਅਵੈਧ ਚੋਣ: ਜ਼ਬਰਦਸਤੀ ਨਹੀਂ ਕੀਤੀ ਜਾ ਸਕਦੀ।"

msgid "Choices cannot be None."
msgstr "ਚੋਣਾਂ ਕੋਈ ਨਹੀਂ ਹੋ ਸਕਦੀਆਂ।"

msgid "Not a valid choice."
msgstr "ਵੈਧ ਚੋਣ ਨਹੀਂ ਹੈ।"

msgid "Invalid choice(s): one or more data inputs could not be coerced."
msgstr ""
"ਅਵੈਧ ਵਿਕਲਪ: ਇੱਕ ਜਾਂ ਇੱਕ ਤੋਂ ਵੱਧ ਡੇਟਾ ਇਨਪੁਟਸ ਨੂੰ ਜ਼ਬਰਦਸਤੀ ਨਹੀਂ ਲਿਆ ਜਾ ਸਕਦਾ"
" ਹੈ।"

#, python-format
msgid "'%(value)s' is not a valid choice for this field."
msgstr "'%(value)s' ਇਸ ਖੇਤਰ ਲਈ ਵੈਧ ਚੋਣ ਨਹੀਂ ਹੈ।"

msgid "Not a valid datetime value."
msgstr "ਵੈਧ ਮਿਤੀ ਸਮਾਂ ਮੁੱਲ ਨਹੀਂ ਹੈ।"

msgid "Not a valid date value."
msgstr "ਵੈਧ ਮਿਤੀ ਮੁੱਲ ਨਹੀਂ ਹੈ।"

msgid "Not a valid time value."
msgstr "ਇੱਕ ਵੈਧ ਸਮਾਂ ਮੁੱਲ ਨਹੀਂ ਹੈ।"

msgid "Not a valid week value."
msgstr "ਵੈਧ ਹਫ਼ਤੇ ਦਾ ਮੁੱਲ ਨਹੀਂ ਹੈ।"

msgid "Not a valid integer value."
msgstr "ਵੈਧ ਪੂਰਨ ਅੰਕ ਮੁੱਲ ਨਹੀਂ ਹੈ।"

msgid "Not a valid decimal value."
msgstr "ਵੈਧ ਦਸ਼ਮਲਵ ਮੁੱਲ ਨਹੀਂ ਹੈ।"

msgid "Not a valid float value."
msgstr "ਵੈਧ ਫਲੋਟ ਮੁੱਲ ਨਹੀਂ ਹੈ।"

