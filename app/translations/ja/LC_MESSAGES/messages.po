msgstr "{value} は範囲 {range} 内にありません。"

#, python-brace-format
msgid "{value!r} is not a valid boolean. Recognized values: {states}"
msgstr "{value!r} は有効なブール値ではありません。認識される値: {states}"

#, python-brace-format
msgid "{value!r} is not a valid UUID."
msgstr "{value!r} は有効な UUID ではありません。"

msgid "file"
msgstr "ファイル"

msgid "directory"
msgstr "ディレクトリ"

msgid "path"
msgstr "パス"

#, python-brace-format
msgid "{name} {filename!r} does not exist."
msgstr "{name} {filename!r} は存在しません。"

#, python-brace-format
msgid "{name} {filename!r} is a file."
msgstr "{name} {filename!r} はファイルです。"

#, python-brace-format
msgid "{name} {filename!r} is a directory."
msgstr "{name} {filename!r} はディレクトリです。"

#, python-brace-format
msgid "{name} {filename!r} is not readable."
msgstr "{name} {filename!r} は読み取れません。"

#, python-brace-format
msgid "{name} {filename!r} is not writable."
msgstr "{name} {filename!r} は書き込み可能ではありません。"

#, python-brace-format
msgid "{name} {filename!r} is not executable."
msgstr "{name} {filename!r} は実行可能ではありません。"

#, python-brace-format
msgid "{len_type} values are required, but {len_value} was given."
msgstr "{len_type} 値が必要ですが、{len_value} が指定されました。"

#, python-brace-format
msgid "Unknown standard stream '{name}'"
msgstr "不明な標準ストリーム '{name}'"

msgid "This field is required."
msgstr "この項目は必須です。"

#, python-brace-format
msgid "File does not have an approved extension: {extensions}"
msgstr "ファイルには承認された拡張子がありません: {extensions}"

msgid "File does not have an approved extension."
msgstr "ファイルには承認された拡張子がありません。"

#, python-brace-format
msgid "File must be between {min_size} and {max_size} bytes."
msgstr "ファイルは {min_size} バイトから {max_size} バイトまでである必要があります。"

#, python-format
msgid "Invalid field name '%s'."
msgstr "フィールド名「%s」が無効です。"

#, python-format
msgid "Field must be equal to %(other_name)s."
msgstr "フィールドは %(other_name)s と等しくなければなりません。"

#, python-format
msgid "Field must be at least %(min)d character long."
msgstr "フィールドの長さは少なくとも %(min)d 文字である必要があります。"

#, python-format
msgid "Field cannot be longer than %(max)d character."
msgstr "フィールドは %(max)d 文字を超えることはできません。"

#, python-format
msgid "Field must be exactly %(max)d character long."
msgstr "フィールドの長さは正確に %(max)d 文字である必要があります。"

#, python-format
msgid "Field must be between %(min)d and %(max)d characters long."
msgstr "フィールドの長さは %(min)d ～ %(max)d 文字にする必要があります。"

#, python-format
msgid "Number must be at least %(min)s."
msgstr "数値は少なくとも %(min)s である必要があります。"

#, python-format
msgid "Number must be at most %(max)s."
msgstr "数値は最大 %(max)s である必要があります。"

#, python-format
msgid "Number must be between %(min)s and %(max)s."
msgstr "数値は %(min)s から %(max)s までの範囲にする必要があります。"

msgid "Invalid input."
msgstr "無効な入力です。"

msgid "Invalid email address."
msgstr "メールアドレスが無効です。"

msgid "Invalid IP address."
msgstr "無効な IP アドレスです。"

msgid "Invalid Mac address."
msgstr "無効な Mac アドレスです。"

msgid "Invalid URL."
msgstr "URLが無効です。"

msgid "Invalid UUID."
msgstr "無効な UUID。"

#, python-format
msgid "Invalid value, must be one of: %(values)s."
msgstr "無効な値です。%(values)s のいずれかである必要があります。"

#, python-format
msgid "Invalid value, can't be any of: %(values)s."
msgstr "無効な値です。%(values)s は使用できません。"

msgid "This field cannot be edited."
msgstr "このフィールドは編集できません。"

msgid "This field is disabled and cannot have a value."
msgstr "このフィールドは無効になっており、値を設定できません。"

msgid "Invalid CSRF Token."
msgstr "無効な CSRF トークンです。"

msgid "CSRF token missing."
msgstr "CSRFトークンがありません。"

msgid "CSRF failed."
msgstr "CSRF が失敗しました。"

msgid "CSRF token expired."
msgstr "CSRFトークンの有効期限が切れました。"

msgid "Invalid Choice: could not coerce."
msgstr "無効な選択: 強制できませんでした。"

msgid "Choices cannot be None."
msgstr "選択肢を「なし」にすることはできません。"

msgid "Not a valid choice."
msgstr "有効な選択ではありません。"

msgid "Invalid choice(s): one or more data inputs could not be coerced."
msgstr "無効な選択: 1 つ以上のデータ入力を強制できませんでした。"

#, python-format
msgid "'%(value)s' is not a valid choice for this field."
msgstr "'%(value)s' は、このフィールドの有効な選択ではありません。"

msgid "Not a valid datetime value."
msgstr "有効な日時値ではありません。"

msgid "Not a valid date value."
msgstr "有効な日付値ではありません。"

msgid "Not a valid time value."
msgstr "有効な時間値ではありません。"

msgid "Not a valid week value."
msgstr "有効な週の値ではありません。"

msgid "Not a valid integer value."
msgstr "有効な整数値ではありません。"

msgid "Not a valid decimal value."
msgstr "有効な 10 進数値ではありません。"

msgid "Not a valid float value."
msgstr "有効な浮動小数点値ではありません。"

