#, python-brace-format
msgid "{name} {filename!r} is not writable."
msgstr "{name} {filename!r} nije moguće pisati."

#, python-brace-format
msgid "{name} {filename!r} is not executable."
msgstr "{name} {filename!r} nije izvršna."

#, python-brace-format
msgid "{len_type} values are required, but {len_value} was given."
msgstr "Potrebne su vrijednosti {len_type}, ali dana je {len_value}."

#, python-brace-format
msgid "Unknown standard stream '{name}'"
msgstr "Nepoznati standardni tok '{name}'"

msgid "This field is required."
msgstr "Ovo polje je obavezno."

#, python-brace-format
msgid "File does not have an approved extension: {extensions}"
msgstr "Datoteka nema odobreni nastavak: {extensions}"

msgid "File does not have an approved extension."
msgstr "Datoteka nema odobrenu ekstenziju."

#, python-brace-format
msgid "File must be between {min_size} and {max_size} bytes."
msgstr "Datoteka mora biti između {min_size} i {max_size} bajtova."

#, python-format
msgid "Invalid field name '%s'."
msgstr "Nevažeći naziv polja '%s'."

#, python-format
msgid "Field must be equal to %(other_name)s."
msgstr "Polje mora biti jednako %(other_name)s."

#, python-format
msgid "Field must be at least %(min)d character long."
msgstr "Polje mora sadržavati barem %(min)d znak."

#, python-format
msgid "Field cannot be longer than %(max)d character."
msgstr "Polje ne može biti duže od %(max)d znaka."

#, python-format
msgid "Field must be exactly %(max)d character long."
msgstr "Polje mora imati točno %(max)d znakova."

#, python-format
msgid "Field must be between %(min)d and %(max)d characters long."
msgstr "Polje mora imati između %(min)d i %(max)d znakova."

#, python-format
msgid "Number must be at least %(min)s."
msgstr "Broj mora biti najmanje %(min)s."

#, python-format
msgid "Number must be at most %(max)s."
msgstr "Broj mora biti najviše %(max)s."

#, python-format
msgid "Number must be between %(min)s and %(max)s."
msgstr "Broj mora biti između %(min)s i %(max)s."

msgid "Invalid input."
msgstr "Neispravan unos."

msgid "Invalid email address."
msgstr "Nevažeća adresa e-pošte."

msgid "Invalid IP address."
msgstr "Nevažeća IP adresa."

msgid "Invalid Mac address."
msgstr "Nevažeća Mac adresa."

msgid "Invalid URL."
msgstr "Nevažeći URL."

msgid "Invalid UUID."
msgstr "Nevažeći UUID."

#, python-format
msgid "Invalid value, must be one of: %(values)s."
msgstr "Nevažeća vrijednost, mora biti jedno od: %(values)s."

#, python-format
msgid "Invalid value, can't be any of: %(values)s."
msgstr "Nevažeća vrijednost, ne može biti ništa od: %(values)s."

msgid "This field cannot be edited."
msgstr "Ovo polje se ne može uređivati."

msgid "This field is disabled and cannot have a value."
msgstr "Ovo polje je onemogućeno i ne može imati vrijednost."

msgid "Invalid CSRF Token."
msgstr "Nevažeći CSRF token."

msgid "CSRF token missing."
msgstr "Nedostaje CSRF token."

msgid "CSRF failed."
msgstr "CSRF nije uspio."

msgid "CSRF token expired."
msgstr "CSRF token je istekao."

msgid "Invalid Choice: could not coerce."
msgstr "Nevažeći izbor: nije moguće izvršiti prisilu."

msgid "Choices cannot be None."
msgstr "Izbori ne mogu biti Ništa."

msgid "Not a valid choice."
msgstr "Nije valjan izbor."

msgid "Invalid choice(s): one or more data inputs could not be coerced."
msgstr ""
"Nevažeći izbor(i): jedan ili više unosa podataka nije bilo moguće "
"prisiliti."

#, python-format
msgid "'%(value)s' is not a valid choice for this field."
msgstr "'%(value)s' nije važeći izbor za ovo polje."

msgid "Not a valid datetime value."
msgstr "Nije važeća vrijednost datuma i vremena."

msgid "Not a valid date value."
msgstr "Nije važeća vrijednost datuma."

msgid "Not a valid time value."
msgstr "Nije važeća vremenska vrijednost."

msgid "Not a valid week value."
msgstr "Nije valjana tjedna vrijednost."

msgid "Not a valid integer value."
msgstr "Nije valjana vrijednost cijelog broja."

msgid "Not a valid decimal value."
msgstr "Nije važeća decimalna vrijednost."

msgid "Not a valid float value."
msgstr "Nije važeća float vrijednost."

