msgstr "ଏକ ବ valid ଧ ସମୟ ମୂଲ୍ୟ ନୁହେଁ |"

msgid "Not a valid week value."
msgstr "ଏକ ବ week ଧ ସପ୍ତାହ ମୂଲ୍ୟ ନୁହେଁ |"

msgid "Not a valid integer value."
msgstr "ଏକ ବ valid ଧ ପୂର୍ଣ୍ଣ ମୂଲ୍ୟ ନୁହେଁ |"

msgid "Not a valid decimal value."
msgstr "ଏକ ବ valid ଧ ଦଶମିକ ମୂଲ୍ୟ ନୁହେଁ |"

msgid "Not a valid float value."
msgstr "ଏକ ବ valid ଧ ଫ୍ଲୋଟ୍ ମୂଲ୍ୟ ନୁହେଁ |"

