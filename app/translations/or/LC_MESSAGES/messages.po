msgstr "ଫାଇଲ୍ {ଫାଇଲନାମ! R}: {ସନ୍ଦେଶ} ଖୋଲି ପାରିଲା ନାହିଁ |"

msgid "Usage:"
msgstr "ବ୍ୟବହାର:"

#, python-brace-format
msgid "Invalid start character for option ({option})"
msgstr "ବିକଳ୍ପ ପାଇଁ ଅବ val ଧ ପ୍ରାରମ୍ଭ ବର୍ଣ୍ଣ ({ବିକଳ୍ପ})"

#, python-brace-format
msgid "Argument {name!r} takes {nargs} values."
msgstr "ଯୁକ୍ତି {ନାମ! R {{nargs} ମୂଲ୍ୟ ନେଇଥାଏ |"

#, python-brace-format
msgid "Option {name!r} does not take a value."
msgstr "ବିକଳ୍ପ {ନାମ! R a ଏକ ମୂଲ୍ୟ ନିଏ ନାହିଁ |"

#, python-brace-format
msgid "Option {name!r} requires an argument."
msgstr "ବିକଳ୍ପ {ନାମ! R an ଏକ ଯୁକ୍ତି ଆବଶ୍ୟକ କରେ |"

msgid "Shell completion is not supported for Bash versions older than 4.4."
msgstr "4.4 ରୁ ଅଧିକ ପୁରୁଣା ସଂସ୍କରଣ ପାଇଁ ସେଲ୍ ସମାପ୍ତି ସମର୍ଥିତ ନୁହେଁ |"

msgid "Couldn't detect Bash version, shell completion is not supported."
msgstr "ବାସ୍ ସଂସ୍କରଣ ଚିହ୍ନଟ କରିପାରିଲା ନାହିଁ, ସେଲ୍ ସମାପ୍ତି ସମର୍ଥିତ ନୁହେଁ |"

msgid "Repeat for confirmation"
msgstr "ନିଶ୍ଚିତକରଣ ପାଇଁ ପୁନରାବୃତ୍ତି କରନ୍ତୁ |"

msgid "Error: The two entered values do not match."
msgstr "ତ୍ରୁଟି: ଦୁଇଟି ପ୍ରବିଷ୍ଟ ମୂଲ୍ୟ ମେଳ ଖାଉ ନାହିଁ |"

msgid "Error: invalid input"
msgstr "ତ୍ରୁଟି: ଅବ inv ଧ ଇନପୁଟ୍ |"

#, python-brace-format
msgid "Unknown color {colour!r}"
msgstr "ଅଜ୍ଞାତ ରଙ୍ଗ {ରଙ୍ଗ! R}"

msgid "Press any key to continue..."
msgstr "ଜାରି ରଖିବାକୁ ଯେକ key ଣସି ଚାବିକୁ ଦବାନ୍ତୁ ..."

#, python-brace-format
msgid "Choose from:\\n\\t{choices}"
msgstr "ଏଥିରୁ ବାଛନ୍ତୁ: \\ n \\ t {ପସନ୍ଦ}"

#, python-brace-format
msgid "{value!r} is not {choice}."
msgstr "{ମୂଲ୍ୟ! r} {ପସନ୍ଦ} ନୁହେଁ |"

#, python-brace-format
msgid "Choice({choices})"
msgstr "ପସନ୍ଦ ({ପସନ୍ଦ})"

#, python-brace-format
msgid "{value!r} does not match the format {format}."
msgstr "{ମୂଲ୍ୟ! r} ଫର୍ମାଟ୍ {ଫର୍ମାଟ୍ match ସହିତ ମେଳ ଖାଉ ନାହିଁ |"

#, python-brace-format
msgid "{value!r} is not a valid {number_type}."
msgstr "{ମୂଲ୍ୟ! r a ଏକ ବ valid ଧ {ସଂଖ୍ୟା_ ପ୍ରକାର ନୁହେଁ |"

#, python-brace-format
msgid "{value} is not in the range {range}."
msgstr "{ମୂଲ୍ୟ} ପରିସର {ପରିସର} ରେ ନାହିଁ |"

#, python-brace-format
msgid "{value!r} is not a valid boolean. Recognized values: {states}"
msgstr "{ମୂଲ୍ୟ! r a ଏକ ବ valid ଧ ବୁଲିଅନ୍ ନୁହେଁ | ସ୍ୱୀକୃତିପ୍ରାପ୍ତ ମୂଲ୍ୟ: {ରାଜ୍ୟ}"

#, python-brace-format
msgid "{value!r} is not a valid UUID."
msgstr "{ମୂଲ୍ୟ! r a ଏକ ବ valid ଧ UUID ନୁହେଁ |"

msgid "file"
msgstr "ଫାଇଲ୍ |"

msgid "directory"
msgstr "ଡିରେକ୍ଟୋରୀ"

msgid "path"
msgstr "ପଥ"

#, python-brace-format
msgid "{name} {filename!r} does not exist."
msgstr "{ନାମ} {ଫାଇଲନାମ! r exist ବିଦ୍ୟମାନ ନାହିଁ |"

#, python-brace-format
msgid "{name} {filename!r} is a file."
msgstr "{ନାମ} {ଫାଇଲନାମ! r} ହେଉଛି ଏକ ଫାଇଲ୍ |"

#, python-brace-format
msgid "{name} {filename!r} is a directory."
msgstr "{ନାମ} {ଫାଇଲନାମ! r} ଏକ ଡିରେକ୍ଟୋରୀ |"

#, python-brace-format
msgid "{name} {filename!r} is not readable."
msgstr "{ନାମ} {ଫାଇଲନାମ! r read ପଠନୀୟ ନୁହେଁ |"

#, python-brace-format
msgid "{name} {filename!r} is not writable."
msgstr "{ନାମ} {ଫାଇଲନାମ! r write ଲେଖା ଯୋଗ୍ୟ ନୁହେଁ |"

#, python-brace-format
msgid "{name} {filename!r} is not executable."
msgstr "{ନାମ} {ଫାଇଲନାମ! r} ଏକଜେକ୍ୟୁଟେବଲ୍ ନୁହେଁ |"

#, python-brace-format
msgid "{len_type} values are required, but {len_value} was given."
msgstr "{len_type} ମୂଲ୍ୟଗୁଡ଼ିକ ଆବଶ୍ୟକ, କିନ୍ତୁ {len_value} ଦିଆଯାଇଥିଲା |"

#, python-brace-format
msgid "Unknown standard stream '{name}'"
msgstr "ଅଜ୍ଞାତ ମାନକ ଷ୍ଟ୍ରିମ୍ '{ନାମ}'"

msgid "This field is required."
msgstr "ଏହି କ୍ଷେତ୍ର ଆବଶ୍ୟକ |"

#, python-brace-format
msgid "File does not have an approved extension: {extensions}"
msgstr "ଫାଇଲର ଏକ ଅନୁମୋଦିତ ବିସ୍ତୃତକରଣ ନାହିଁ: {ବିସ୍ତୃତକରଣ}"

msgid "File does not have an approved extension."
msgstr "ଫାଇଲର ଏକ ଅନୁମୋଦିତ ବିସ୍ତୃତକରଣ ନାହିଁ |"

#, python-brace-format
msgid "File must be between {min_size} and {max_size} bytes."
msgstr "ଫାଇଲ୍ {min_size} ଏବଂ {max_size} ବାଇଟ୍ ମଧ୍ୟରେ ହେବା ଜରୁରୀ |"

#, python-format
msgid "Invalid field name '%s'."
msgstr "ଅବ% ଧ କ୍ଷେତ୍ର ନାମ '% s' |"

#, python-format
msgid "Field must be equal to %(other_name)s."
msgstr "କ୍ଷେତ୍ର ନିଶ୍ଚିତ ଭାବରେ% (ଅନ୍ୟ_ନାମ) s ସହିତ ସମାନ ହେବା ଉଚିତ |"

#, python-format
msgid "Field must be at least %(min)d character long."
msgstr "କ୍ଷେତ୍ର ଅତିକମରେ% (ମିନିଟ୍) d ଅକ୍ଷର ଲମ୍ବା ହେବା ଜରୁରୀ |"

#, python-format
msgid "Field cannot be longer than %(max)d character."
msgstr "କ୍ଷେତ୍ର% (ସର୍ବାଧିକ) d ବର୍ଣ୍ଣରୁ ଅଧିକ ହୋଇପାରିବ ନାହିଁ |"

#, python-format
msgid "Field must be exactly %(max)d character long."
msgstr "ଫିଲ୍ଡ ନିଶ୍ଚିତ ଭାବରେ% (ସର୍ବାଧିକ) d ଅକ୍ଷର ଲମ୍ବା ହେବା ଜରୁରୀ |"

#, python-format
msgid "Field must be between %(min)d and %(max)d characters long."
msgstr ""
"କ୍ଷେତ୍ର ନିଶ୍ଚିତ ଭାବରେ% (ମିନିଟ୍) d ରୁ% (ସର୍ବାଧିକ) d ଅକ୍ଷର ଲମ୍ବା ହେବା "
"ଆବଶ୍ୟକ |"

#, python-format
msgid "Number must be at least %(min)s."
msgstr "ସଂଖ୍ୟା ଅତିକମରେ% (ମିନିଟ୍) s ହେବା ଜରୁରୀ |"

#, python-format
msgid "Number must be at most %(max)s."
msgstr "ସଂଖ୍ୟା ନିଶ୍ଚିତ ଭାବରେ ସର୍ବାଧିକ% (ସର୍ବାଧିକ) s ହେବା ଆବଶ୍ୟକ |"

#, python-format
msgid "Number must be between %(min)s and %(max)s."
msgstr "ସଂଖ୍ୟା ନିଶ୍ଚିତ ଭାବରେ% (ମିନିଟ୍) s ଏବଂ% (ସର୍ବାଧିକ) s ମଧ୍ୟରେ ହେବା ଆବଶ୍ୟକ |"

msgid "Invalid input."
msgstr "ଅବ val ଧ ଇନପୁଟ୍ |"

msgid "Invalid email address."
msgstr "ଅବ val ଧ ଇମେଲ ଠିକଣା |"

msgid "Invalid IP address."
msgstr "ଅବ IP ଧ IP ଠିକଣା |"

msgid "Invalid Mac address."
msgstr "ଅବ val ଧ ମ୍ୟାକ୍ ଠିକଣା |"

msgid "Invalid URL."
msgstr "ଅବ val ଧ URL"

msgid "Invalid UUID."
msgstr "ଅବ U ଧ UUID |"

#, python-format
msgid "Invalid value, must be one of: %(values)s."
msgstr "ଅବ val ଧ ମୂଲ୍ୟ, ନିଶ୍ଚିତ ଭାବରେ ଗୋଟିଏ:% (ମୂଲ୍ୟ) ଗୁଡିକ |"

#, python-format
msgid "Invalid value, can't be any of: %(values)s."
msgstr "ଅବ val ଧ ମୂଲ୍ୟ, କ% ଣସି ହୋଇପାରିବ ନାହିଁ:% (ମୂଲ୍ୟ) s |"

msgid "This field cannot be edited."
msgstr "ଏହି କ୍ଷେତ୍ର ସମ୍ପାଦିତ ହୋଇପାରିବ ନାହିଁ |"

msgid "This field is disabled and cannot have a value."
msgstr "ଏହି କ୍ଷେତ୍ର ଅକ୍ଷମ ହୋଇଛି ଏବଂ ଏହାର ମୂଲ୍ୟ ରହିପାରିବ ନାହିଁ |"

msgid "Invalid CSRF Token."
msgstr "ଅବ val ଧ CSRF ଟୋକେନ୍ |"

msgid "CSRF token missing."
msgstr "CSRF ଟୋକେନ୍ ନିଖୋଜ |"

msgid "CSRF failed."
msgstr "CSRF ବିଫଳ ହେଲା |"

msgid "CSRF token expired."
msgstr "CSRF ଟୋକେନ୍ ମିଆଦ ପୂର୍ଣ୍ଣ ହୋଇଛି |"

msgid "Invalid Choice: could not coerce."
msgstr "ଅବ val ଧ ପସନ୍ଦ: ବାଧ୍ୟ କରିପାରିଲା ନାହିଁ |"

msgid "Choices cannot be None."
msgstr "ପସନ୍ଦ କିଛି ହୋଇପାରିବ ନାହିଁ |"

msgid "Not a valid choice."
msgstr "ଏକ ବ valid ଧ ପସନ୍ଦ ନୁହେଁ |"

msgid "Invalid choice(s): one or more data inputs could not be coerced."
msgstr ""
"ଅବ val ଧ ପସନ୍ଦ (ଗୁଡିକ): ଗୋଟିଏ କିମ୍ବା ଅଧିକ ଡାଟା ଇନପୁଟ୍ ବାଧ୍ୟ ହୋଇପାରିବ "
"ନାହିଁ |"

#, python-format
msgid "'%(value)s' is not a valid choice for this field."
msgstr "'% (ମୂଲ୍ୟ) s' ଏହି କ୍ଷେତ୍ର ପାଇଁ ଏକ ବ valid ଧ ପସନ୍ଦ ନୁହେଁ |"

msgid "Not a valid datetime value."
msgstr "ଏକ ବ valid ଧ ଡାଟାଇଟ୍ ମୂଲ୍ୟ ନୁହେଁ |"

msgid "Not a valid date value."
msgstr "ଏକ ବ date ଧ ତାରିଖ ମୂଲ୍ୟ ନୁହେଁ |"

