#, python-brace-format
msgid "{value!r} does not match the format {format}."
msgstr "{value!r} ma jaqbilx mal-format {format}."

#, python-brace-format
msgid "{value!r} is not a valid {number_type}."
msgstr "{value!r} mhuwiex {number_type} validu."

#, python-brace-format
msgid "{value} is not in the range {range}."
msgstr "{valur} mhuwiex fil-medda {firxa}."

#, python-brace-format
msgid "{value!r} is not a valid boolean. Recognized values: {states}"
msgstr "{value!r} mhuwiex boolean validu. Valuri rikonoxxuti: {states}"

#, python-brace-format
msgid "{value!r} is not a valid UUID."
msgstr "{value!r} mhuwiex UUID validu."

msgid "file"
msgstr "fajl"

msgid "directory"
msgstr "direttorju"

msgid "path"
msgstr "mogħdija"

#, python-brace-format
msgid "{name} {filename!r} does not exist."
msgstr "{name} {filename!r} ma jeżistix."

#, python-brace-format
msgid "{name} {filename!r} is a file."
msgstr "{name} {filename!r} huwa fajl."

#, python-brace-format
msgid "{name} {filename!r} is a directory."
msgstr "{name} {filename!r} huwa direttorju."

#, python-brace-format
msgid "{name} {filename!r} is not readable."
msgstr "{name} {filename!r} ma jinqarax."

#, python-brace-format
msgid "{name} {filename!r} is not writable."
msgstr "{name} {filename!r} ma jistax jinkiteb."

#, python-brace-format
msgid "{name} {filename!r} is not executable."
msgstr "{name} {filename!r} mhux eżekutibbli."

#, python-brace-format
msgid "{len_type} values are required, but {len_value} was given."
msgstr "Il-valuri {len_type} huma meħtieġa, iżda {len_value} ingħatat."

#, python-brace-format
msgid "Unknown standard stream '{name}'"
msgstr "Fluss standard mhux magħruf '{name}'"

msgid "This field is required."
msgstr "Dan il-qasam huwa meħtieġ."

#, python-brace-format
msgid "File does not have an approved extension: {extensions}"
msgstr "Il-fajl m'għandux estensjoni approvata: {extensions}"

msgid "File does not have an approved extension."
msgstr "Il-fajl m'għandux estensjoni approvata."

#, python-brace-format
msgid "File must be between {min_size} and {max_size} bytes."
msgstr "Il-fajl irid ikun bejn {min_size} u {max_size} bytes."

#, python-format
msgid "Invalid field name '%s'."
msgstr "Isem tal-qasam invalidu '%s'."

#, python-format
msgid "Field must be equal to %(other_name)s."
msgstr "Il-qasam irid ikun ugwali għal %(other_name)s."

#, python-format
msgid "Field must be at least %(min)d character long."
msgstr "Il-qasam għandu jkun twil mill-inqas %(min)d karattru."

#, python-format
msgid "Field cannot be longer than %(max)d character."
msgstr "Il-qasam ma jistax ikun itwal minn %(max)d karattru."

#, python-format
msgid "Field must be exactly %(max)d character long."
msgstr "Il-qasam għandu jkun twil eżattament %(max)d karattru."

#, python-format
msgid "Field must be between %(min)d and %(max)d characters long."
msgstr "Il-qasam irid ikun twil bejn %(min)d u %(max)d karattri."

#, python-format
msgid "Number must be at least %(min)s."
msgstr "In-numru għandu jkun mill-inqas %(min)s."

#, python-format
msgid "Number must be at most %(max)s."
msgstr "In-numru għandu jkun l-aktar %(max)s."

#, python-format
msgid "Number must be between %(min)s and %(max)s."
msgstr "In-numru għandu jkun bejn %(min)s u %(max)s."

msgid "Invalid input."
msgstr "Input mhux validu."

msgid "Invalid email address."
msgstr "Indirizz elettroniku mhux validu."

msgid "Invalid IP address."
msgstr "Indirizz IP invalidu."

msgid "Invalid Mac address."
msgstr "Indirizz Mac invalidu."

msgid "Invalid URL."
msgstr "URL invalidu."

msgid "Invalid UUID."
msgstr "UUID invalidu."

#, python-format
msgid "Invalid value, must be one of: %(values)s."
msgstr "Valur mhux validu, irid ikun wieħed minn: %(values)s."

#, python-format
msgid "Invalid value, can't be any of: %(values)s."
msgstr "Valur mhux validu, ma jistax ikun xi wieħed minn: %(values)s."

msgid "This field cannot be edited."
msgstr "Dan il-qasam ma jistax jiġi editjat."

msgid "This field is disabled and cannot have a value."
msgstr "Dan il-qasam huwa diżattivat u ma jistax ikollu valur."

msgid "Invalid CSRF Token."
msgstr "Token CSRF invalidu."

msgid "CSRF token missing."
msgstr "Token CSRF nieqes."

msgid "CSRF failed."
msgstr "CSRF falla."

msgid "CSRF token expired."
msgstr "It-token CSRF skada."

msgid "Invalid Choice: could not coerce."
msgstr "Għażla Invalida: ma setgħetx tiġġiegħel."

msgid "Choices cannot be None."
msgstr "Għażliet ma jistgħux ikunu Xejn."

msgid "Not a valid choice."
msgstr "Mhux għażla valida."

msgid "Invalid choice(s): one or more data inputs could not be coerced."
msgstr ""
"Għażla(jiet) invalida(i): input tad-dejta wieħed jew aktar ma setgħux "
"jiġu sfurzati."

#, python-format
msgid "'%(value)s' is not a valid choice for this field."
msgstr "'%(value)s' mhix għażla valida għal dan il-qasam."

msgid "Not a valid datetime value."
msgstr "Mhux valur validu ta' data-ħin."

msgid "Not a valid date value."
msgstr "Mhux valur ta' data valida."

msgid "Not a valid time value."
msgstr "Mhux valur tal-ħin validu."

msgid "Not a valid week value."
msgstr "Mhux valur validu tal-ġimgħa."

msgid "Not a valid integer value."
msgstr "Mhux valur sħiħ validu."

msgid "Not a valid decimal value."
msgstr "Mhux valur deċimali validu."

msgid "Not a valid float value."
msgstr "Mhux valur float validu."

