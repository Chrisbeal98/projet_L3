msgid "Invalid IP address."
msgstr "ᓈᒻᒪᖏᑦᑐᖅ IP ᑐᕌᕈᑎᖓ."

msgid "Invalid Mac address."
msgstr "ᐊᑐᙱᑦᑐᖅ ᒪᒃ ᑐᕌᕈᑎᖓ."

msgid "Invalid URL."
msgstr "ᓈᒻᒪᖏᑦᑐᖅ URL."

msgid "Invalid UUID."
msgstr "ᐊᑐᙱᑦᑐᖅ UUID."

#, python-format
msgid "Invalid value, must be one of: %(values)s."
msgstr "ᓈᒻᒪᖏᑦᑐᖅ ᓈᓴᐅᑎ, ᐊᑕᐅᓯᐅᔭᕆᐊᖃᖅᐳᖅ: %(ᖃᑦᓯᐅᓂᖏᑦ)s."

#, python-format
msgid "Invalid value, can't be any of: %(values)s."
