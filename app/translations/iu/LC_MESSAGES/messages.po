#, python-format
msgid "Field must be exactly %(max)d character long."
msgstr "ᑕᑭᓂᖃᕆᐊᖃᖅᐳᖅ %(max)d ᑎᑎᕋᖅᓯᒪᔪᓂᒃ."

#, python-format
msgid "Field must be between %(min)d and %(max)d characters long."
msgstr "ᑎᑎᕋᖅᓯᒪᔪᖅ ᐊᑯᓐᓂᖓᓃᑦᑕᕆᐊᖃᖅᐳᖅ %(ᒥᑭᓛᖅ)d ᐊᒻᒪ %(ᐊᖏᓛᖅ)d ᑎᑎᕋᖅᓯᒪᔪᑦ ᑕᑭᓂᖃᕐᓗᓂ."

#, python-format
msgid "Number must be at least %(min)s."
msgstr "ᓈᓴᐅᑎᖓ ᒥᑭᓛᖑᔭᕆᐊᖃᖅᐳᖅ %(ᒥᓂᑦ)s."

#, python-format
msgid "Number must be at most %(max)s."
