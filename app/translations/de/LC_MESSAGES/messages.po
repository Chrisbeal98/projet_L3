#, python-brace-format
msgid "File must be between {min_size} and {max_size} bytes."
msgstr "Die Datei muss zwischen {min_size} und {max_size} Byte groß sein."

#, python-format
msgid "Invalid field name '%s'."
msgstr "Ungültiger Feldname „%s“."

#, python-format
msgid "Field must be equal to %(other_name)s."
msgstr "Das Feld muss gleich %(other_name)s sein."

#, python-format
msgid "Field must be at least %(min)d character long."
msgstr "Das Feld muss mindestens %(min)d Zeichen lang sein."

#, python-format
msgid "Field cannot be longer than %(max)d character."
msgstr "Das Feld darf nicht länger als %(max)d Zeichen sein."

#, python-format
msgid "Field must be exactly %(max)d character long."
msgstr "Das Feld muss genau %(max)d Zeichen lang sein."

#, python-format
msgid "Field must be between %(min)d and %(max)d characters long."
msgstr "Das Feld muss zwischen %(min)d und %(max)d Zeichen lang sein."

#, python-format
msgid "Number must be at least %(min)s."
msgstr "Die Zahl muss mindestens %(min)s betragen."

#, python-format
msgid "Number must be at most %(max)s."
msgstr "Die Zahl darf höchstens %(max)s betragen."

#, python-format
msgid "Number must be between %(min)s and %(max)s."
msgstr "Die Zahl muss zwischen %(min)s und %(max)s liegen."

msgid "Invalid input."
msgstr "Ungültige Eingabe."

msgid "Invalid email address."
msgstr "Ungültige E-Mail-Adresse."

msgid "Invalid IP address."
msgstr "Ungültige IP-Adresse."

msgid "Invalid Mac address."
msgstr "Ungültige Mac-Adresse."

msgid "Invalid URL."
msgstr "Ungültige URL."

msgid "Invalid UUID."
msgstr "Ungültige UUID."

#, python-format
msgid "Invalid value, must be one of: %(values)s."
msgstr "Ungültiger Wert, muss einer von %(values)s sein."

#, python-format
msgid "Invalid value, can't be any of: %(values)s."
msgstr "Ungültiger Wert, darf keiner von %(values)s sein."

msgid "This field cannot be edited."
msgstr "Dieses Feld kann nicht bearbeitet werden."

msgid "This field is disabled and cannot have a value."
msgstr "Dieses Feld ist deaktiviert und kann keinen Wert haben."

msgid "Invalid CSRF Token."
msgstr "Ungültiges CSRF-Token."

msgid "CSRF token missing."
msgstr "CSRF-Token fehlt."

msgid "CSRF failed."
msgstr "CSRF ist fehlgeschlagen."

msgid "CSRF token expired."
msgstr "CSRF-Token ist abgelaufen."

msgid "Invalid Choice: could not coerce."
msgstr "Ungültige Auswahl: konnte nicht erzwungen werden."

msgid "Choices cannot be None."
msgstr "Auswahlmöglichkeiten können nicht „Keine“ sein."

msgid "Not a valid choice."
msgstr "Keine gültige Wahl."

msgid "Invalid choice(s): one or more data inputs could not be coerced."
msgstr ""
"Ungültige Auswahl(en): Eine oder mehrere Dateneingaben konnten nicht "
"erzwungen werden."

#, python-format
msgid "'%(value)s' is not a valid choice for this field."
msgstr "„%(value)s“ ist keine gültige Auswahl für dieses Feld."

msgid "Not a valid datetime value."
msgstr "Kein gültiger Datums-/Uhrzeitwert."

msgid "Not a valid date value."
msgstr "Kein gültiger Datumswert."

msgid "Not a valid time value."
msgstr "Kein gültiger Zeitwert."

msgid "Not a valid week value."
msgstr "Kein gültiger Wochenwert."

msgid "Not a valid integer value."
msgstr "Kein gültiger ganzzahliger Wert."

msgid "Not a valid decimal value."
msgstr "Kein gültiger Dezimalwert."

msgid "Not a valid float value."
msgstr "Kein gültiger Float-Wert."

