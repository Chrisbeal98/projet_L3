msgstr "{value} nuk është në intervalin {range}."

#, python-brace-format
msgid "{value!r} is not a valid boolean. Recognized values: {states}"
msgstr "{value!r} nuk është një boolean i vlefshëm. Vlerat e njohura: {states}"

#, python-brace-format
msgid "{value!r} is not a valid UUID."
msgstr "{value!r} nuk është një UUID e vlefshme."

msgid "file"
msgstr "dosje"

msgid "directory"
msgstr "drejtoria"

msgid "path"
msgstr "shteg"

#, python-brace-format
msgid "{name} {filename!r} does not exist."
msgstr "{name} {filename!r} nuk ekziston."

#, python-brace-format
msgid "{name} {filename!r} is a file."
msgstr "{name} {filename!r} është një skedar."

#, python-brace-format
msgid "{name} {filename!r} is a directory."
msgstr "{name} {filename!r} është një direktori."

#, python-brace-format
msgid "{name} {filename!r} is not readable."
msgstr "{name} {filename!r} nuk lexohet."

#, python-brace-format
msgid "{name} {filename!r} is not writable."
msgstr "{name} {filename!r} nuk mund të shkruhet."

#, python-brace-format
msgid "{name} {filename!r} is not executable."
msgstr "{name} {filename!r} nuk është i ekzekutueshëm."

#, python-brace-format
msgid "{len_type} values are required, but {len_value} was given."
msgstr "Kërkohen vlera {len_type}, por u dha {len_value}."

#, python-brace-format
msgid "Unknown standard stream '{name}'"
msgstr "Transmetim standard i panjohur \"{name}\""

msgid "This field is required."
msgstr "Kjo fushë është e nevojshme."

#, python-brace-format
msgid "File does not have an approved extension: {extensions}"
msgstr "Skedari nuk ka një shtesë të miratuar: {extensions}"

msgid "File does not have an approved extension."
msgstr "Skedari nuk ka një shtesë të miratuar."

#, python-brace-format
msgid "File must be between {min_size} and {max_size} bytes."
msgstr "Skedari duhet të jetë ndërmjet {min_size} dhe {max_size} byte."

#, python-format
msgid "Invalid field name '%s'."
msgstr "Emri i pavlefshëm i fushës '%s'."

#, python-format
msgid "Field must be equal to %(other_name)s."
msgstr "Fusha duhet të jetë e barabartë me %(other_name)s."

#, python-format
msgid "Field must be at least %(min)d character long."
msgstr "Fusha duhet të jetë e gjatë të paktën %(min)d karakter."

#, python-format
msgid "Field cannot be longer than %(max)d character."
msgstr "Fusha nuk mund të jetë më e gjatë se %(max)d karakter."

#, python-format
msgid "Field must be exactly %(max)d character long."
msgstr "Fusha duhet të jetë saktësisht %(max)d e gjatë."

#, python-format
msgid "Field must be between %(min)d and %(max)d characters long."
msgstr "Fusha duhet të jetë e gjatë ndërmjet %(min)d dhe %(max)d karaktereve."

#, python-format
msgid "Number must be at least %(min)s."
msgstr "Numri duhet të jetë të paktën %(min)s."

#, python-format
msgid "Number must be at most %(max)s."
msgstr "Numri duhet të jetë maksimumi %(max)s."

#, python-format
msgid "Number must be between %(min)s and %(max)s."
msgstr "Numri duhet të jetë ndërmjet %(min)s dhe %(maks)s."

msgid "Invalid input."
msgstr "Hyrja e pavlefshme."

msgid "Invalid email address."
msgstr "Adresë e pavlefshme emaili."

msgid "Invalid IP address."
msgstr "Adresa IP e pavlefshme."

msgid "Invalid Mac address."
msgstr "Adresa e pavlefshme Mac."

msgid "Invalid URL."
msgstr "URL e pavlefshme."

msgid "Invalid UUID."
msgstr "UUID e pavlefshme."

#, python-format
msgid "Invalid value, must be one of: %(values)s."
msgstr "Vlera e pavlefshme, duhet të jetë një nga: %(values)s."

#, python-format
msgid "Invalid value, can't be any of: %(values)s."
msgstr "Vlera e pavlefshme, nuk mund të jetë asnjë nga: %(values)s."

msgid "This field cannot be edited."
msgstr "Kjo fushë nuk mund të modifikohet."

msgid "This field is disabled and cannot have a value."
msgstr "Kjo fushë është e çaktivizuar dhe nuk mund të ketë vlerë."

msgid "Invalid CSRF Token."
msgstr "Shenja CSRF e pavlefshme."

msgid "CSRF token missing."
msgstr "Mungon token CSRF."

msgid "CSRF failed."
msgstr "CSRF dështoi."

msgid "CSRF token expired."
msgstr "Shenja CSRF ka skaduar."

msgid "Invalid Choice: could not coerce."
msgstr "Zgjedhja e pavlefshme: nuk mund të detyrohej."

msgid "Choices cannot be None."
msgstr "Zgjedhjet nuk mund të jenë Asnjë."

msgid "Not a valid choice."
msgstr "Nuk është një zgjedhje e vlefshme."

msgid "Invalid choice(s): one or more data inputs could not be coerced."
msgstr ""
"Zgjedhje(at) e pavlefshme: një ose më shumë hyrje të dhënash nuk mund të "
"detyroheshin."

#, python-format
msgid "'%(value)s' is not a valid choice for this field."
msgstr "'%(value)s' nuk është një zgjedhje e vlefshme për këtë fushë."

msgid "Not a valid datetime value."
msgstr "Nuk është një vlerë e vlefshme e datës."

msgid "Not a valid date value."
msgstr "Nuk është një vlerë e vlefshme e datës."

msgid "Not a valid time value."
msgstr "Nuk është një vlerë kohore e vlefshme."

msgid "Not a valid week value."
msgstr "Vlera jo e vlefshme e javës."

msgid "Not a valid integer value."
msgstr "Nuk është një vlerë e plotë e vlefshme."

msgid "Not a valid decimal value."
msgstr "Nuk është një vlerë dhjetore e vlefshme."

msgid "Not a valid float value."
msgstr "Nuk është një vlerë e vlefshme notuese."

