"Ifayela kufanele libe hlangana kwamabhayithi we-{min_size} kanye "
"ne-{max_size}."

#, python-format
msgid "Invalid field name '%s'."
msgstr "Ibizo lesimu elingakalungi '%s'."

#, python-format
msgid "Field must be equal to %(other_name)s."
msgstr "Indawo kufanele ilingana ne-%(other_name)s."

#, python-format
msgid "Field must be at least %(min)d character long."
msgstr "Insimu kufanele ibe okungenani %(min)d yamagama ubude."

#, python-format
msgid "Field cannot be longer than %(max)d character."
msgstr "Insimu angeze yaba yinde ukudlula i-%(max)d yehlamvu."

#, python-format
msgid "Field must be exactly %(max)d character long."
msgstr "Insimu kufanele ibe yi-%(max)d yeenhlamvu ubude."

#, python-format
msgid "Field must be between %(min)d and %(max)d characters long."
msgstr "Insimu kufanele ibe phakathi kwe-%(min)d kanye ne-%(max)d yamagama ubude."

#, python-format
msgid "Number must be at least %(min)s."
msgstr "Inomboro kufanele ibe okungenani %(min)s."

#, python-format
msgid "Number must be at most %(max)s."
msgstr "Inomboro kufanele ibe yi-%(max)s."

#, python-format
msgid "Number must be between %(min)s and %(max)s."
msgstr "Inomboro kufanele ibe hlangana ne-%(min)s kanye ne-%(max)s."

