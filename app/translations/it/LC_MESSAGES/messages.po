#, python-format
msgid "Field cannot be longer than %(max)d character."
msgstr "Il campo non può essere più lungo di %(max)d carattere."

#, python-format
msgid "Field must be exactly %(max)d character long."
msgstr "Il campo deve contenere esattamente %(max)d caratteri."

#, python-format
msgid "Field must be between %(min)d and %(max)d characters long."
msgstr "Il campo deve contenere tra %(min)d e %(max)d caratteri."

#, python-format
msgid "Number must be at least %(min)s."
msgstr "Il numero deve essere almeno %(min)s."

#, python-format
msgid "Number must be at most %(max)s."
msgstr "Il numero deve essere al massimo %(max)s."

#, python-format
msgid "Number must be between %(min)s and %(max)s."
msgstr "Il numero deve essere compreso tra %(min)s e %(max)s."

msgid "Invalid input."
msgstr "Immissione non valida."

msgid "Invalid email address."
msgstr "Indirizzo e-mail non valido."

msgid "Invalid IP address."
msgstr "Indirizzo IP non valido."

msgid "Invalid Mac address."
msgstr "Indirizzo Mac non valido."

msgid "Invalid URL."
msgstr "URL non valido."

msgid "Invalid UUID."
msgstr "UUID non valido."

#, python-format
msgid "Invalid value, must be one of: %(values)s."
msgstr "Valore non valido, deve essere uno di: %(valori)s."

#, python-format
msgid "Invalid value, can't be any of: %(values)s."
msgstr "Valore non valido, non può essere nessuno tra: %(valori)s."

msgid "This field cannot be edited."
msgstr "Questo campo non può essere modificato."

msgid "This field is disabled and cannot have a value."
msgstr "Questo campo è disabilitato e non può avere un valore."

msgid "Invalid CSRF Token."
msgstr "Token CSRF non valido."

msgid "CSRF token missing."
msgstr "Token CSRF mancante."

msgid "CSRF failed."
msgstr "CSRF non riuscito."

msgid "CSRF token expired."
msgstr "Il token CSRF è scaduto."

msgid "Invalid Choice: could not coerce."
msgstr "Scelta non valida: impossibile forzare."

msgid "Choices cannot be None."
msgstr "Le scelte non possono essere Nessuna."

msgid "Not a valid choice."
msgstr "Non è una scelta valida."

msgid "Invalid choice(s): one or more data inputs could not be coerced."
msgstr "Scelte non valide: uno o più input di dati non possono essere forzati."

#, python-format
msgid "'%(value)s' is not a valid choice for this field."
msgstr "'%(value)s' non è una scelta valida per questo campo."

msgid "Not a valid datetime value."
msgstr "Non è un valore data/ora valido."

msgid "Not a valid date value."
msgstr "Non è un valore di data valido."

msgid "Not a valid time value."
msgstr "Non è un valore temporale valido."

msgid "Not a valid week value."
msgstr "Valore della settimana non valido."

msgid "Not a valid integer value."
msgstr "Non è un valore intero valido."

msgid "Not a valid decimal value."
msgstr "Non è un valore decimale valido."

msgid "Not a valid float value."
msgstr "Non è un valore float valido."

