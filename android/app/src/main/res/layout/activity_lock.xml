<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="40dp">

        <TextView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:gravity="center"
            android:text="&#x1F512;"
            android:textSize="48dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:text="APPAREIL VERROUILLÉ"
            android:textColor="#ef4444"
            android:textSize="24dp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:text="Cet appareil a été verrouillé à distance.\nEntrez le code de déverrouillage."
            android:textColor="#94a3b8"
            android:textSize="15dp" />

        <EditText
            android:id="@+id/unlockCodeInput"
            android:layout_width="220dp"
            android:layout_height="56dp"
            android:layout_marginTop="40dp"
            android:background="#1a1a2e"
            android:gravity="center"
            android:hint="Code"
            android:inputType="number"
            android:maxLength="6"
            android:padding="14dp"
            android:textColor="#ffffff"
            android:textColorHint="#555555"
            android:textSize="32dp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/unlockButton"
            android:layout_width="220dp"
            android:layout_height="52dp"
            android:layout_marginTop="20dp"
            android:backgroundTint="#3b82f6"
            android:text="DÉVERROUILLER"
            android:textColor="#ffffff"
            android:textSize="16dp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/unlockError"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Code incorrect"
            android:textColor="#ef4444"
            android:textSize="14dp"
            android:visibility="gone" />

    </LinearLayout>
</RelativeLayout>
